@model IEnumerable<KasaManager.Domain.Identity.KasaUser>
@{
    ViewData["Title"] = "Kullanıcı Yönetimi";
}

<div class="kasa-page-header">
    <div>
        <h1 class="kasa-page-title"><i class="fas fa-users-cog me-2"></i>Kullanıcı Yönetimi</h1>
        <p class="kasa-page-subtitle">Sistem kullanıcılarını yönetin</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="fas fa-user-plus me-1"></i> Yeni Kullanıcı
    </a>
</div>

@if (TempData["Success"] is string success)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle me-1"></i> @success
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] is string error)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-triangle me-1"></i> @error
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="kasa-card">
    <div class="kasa-card-body p-0">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>Kullanıcı Adı</th>
                    <th>Görünen Ad</th>
                    <th>Rol</th>
                    <th>Durum</th>
                    <th>Son Giriş</th>
                    <th>Oluşturulma</th>
                    <th class="text-end">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td>
                            <i class="fas fa-user-circle me-1 text-muted"></i>
                            <strong>@user.Username</strong>
                        </td>
                        <td>@user.DisplayName</td>
                        <td>
                            @if (user.Role == "Admin")
                            {
                                <span class="badge bg-danger"><i class="fas fa-shield-alt me-1"></i>Admin</span>
                            }
                            else
                            {
                                <span class="badge bg-info"><i class="fas fa-user me-1"></i>User</span>
                            }
                        </td>
                        <td>
                            @if (user.IsActive)
                            {
                                <span class="badge bg-success">Aktif</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Pasif</span>
                            }
                        </td>
                        <td>
                            @if (user.LastLoginAt.HasValue)
                            {
                                <small class="text-muted">@user.LastLoginAt.Value.ToString("dd.MM.yyyy HH:mm")</small>
                            }
                            else
                            {
                                <small class="text-muted">—</small>
                            }
                        </td>
                        <td><small class="text-muted">@user.CreatedAt.ToString("dd.MM.yyyy")</small></td>
                        <td class="text-end">
                            <div class="btn-group btn-group-sm">
                                <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-outline-primary" title="Düzenle">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <button type="button" class="btn btn-outline-warning" title="Şifre Sıfırla"
                                        data-bs-toggle="modal" data-bs-target="#resetModal-@user.Id">
                                    <i class="fas fa-key"></i>
                                </button>
                                @if (!user.Username.Equals(User.Identity?.Name, StringComparison.OrdinalIgnoreCase))
                                {
                                    <button type="button" class="btn btn-outline-danger" title="Sil"
                                            data-bs-toggle="modal" data-bs-target="#deleteModal-@user.Id">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                }
                            </div>
                        </td>
                    </tr>

                    <!-- Şifre Sıfırla Modal -->
                    <div class="modal fade" id="resetModal-@user.Id" tabindex="-1">
                        <div class="modal-dialog">
                            <div class="modal-content">
                                <form asp-action="ResetPassword" method="post">
                                    <input type="hidden" name="id" value="@user.Id" />
                                    <div class="modal-header">
                                        <h5 class="modal-title"><i class="fas fa-key me-2"></i>Şifre Sıfırla — @user.Username</h5>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                    </div>
                                    <div class="modal-body">
                                        <div class="mb-3">
                                            <label class="form-label">Yeni Şifre</label>
                                            <input type="password" name="newPassword" class="form-control"
                                                   minlength="6" required placeholder="En az 6 karakter" />
                                        </div>
                                    </div>
                                    <div class="modal-footer">
                                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                                        <button type="submit" class="btn btn-warning"><i class="fas fa-key me-1"></i>Sıfırla</button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>

                    <!-- Sil Modal -->
                    <div class="modal fade" id="deleteModal-@user.Id" tabindex="-1">
                        <div class="modal-dialog">
                            <div class="modal-content">
                                <form asp-action="Delete" method="post">
                                    <input type="hidden" name="id" value="@user.Id" />
                                    <div class="modal-header">
                                        <h5 class="modal-title text-danger"><i class="fas fa-exclamation-triangle me-2"></i>Kullanıcı Sil</h5>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                    </div>
                                    <div class="modal-body">
                                        <p><strong>@user.Username</strong> kullanıcısını silmek istediğinize emin misiniz?</p>
                                        <p class="text-muted">Bu işlem geri alınamaz.</p>
                                    </div>
                                    <div class="modal-footer">
                                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                                        <button type="submit" class="btn btn-danger"><i class="fas fa-trash me-1"></i>Sil</button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            </tbody>
        </table>
    </div>
</div>
