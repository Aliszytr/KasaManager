@model KasaManager.Web.Controllers.CreateUserViewModel
@{
    ViewData["Title"] = "Yeni Kullanıcı";
}

<div class="kasa-page-header">
    <div>
        <h1 class="kasa-page-title"><i class="fas fa-user-plus me-2"></i>Yeni Kullanıcı Oluştur</h1>
        <p class="kasa-page-subtitle">Sisteme yeni bir kullanıcı ekleyin</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="fas fa-arrow-left me-1"></i> Geri
    </a>
</div>

<div class="kasa-card" style="max-width: 600px;">
    <div class="kasa-card-body">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Username" class="form-label">Kullanıcı Adı</label>
                <input asp-for="Username" class="form-control" placeholder="örn: ahmet.yilmaz" autocomplete="off" />
                <span asp-validation-for="Username" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="DisplayName" class="form-label">Görünen Ad</label>
                <input asp-for="DisplayName" class="form-control" placeholder="örn: Ahmet Yılmaz" />
                <span asp-validation-for="DisplayName" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label">Şifre</label>
                <input asp-for="Password" type="password" class="form-control" placeholder="En az 6 karakter" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Role" class="form-label">Rol</label>
                <select asp-for="Role" class="form-select">
                    <option value="User">User — Normal kullanıcı</option>
                    <option value="Admin">Admin — Tam yetki</option>
                </select>
            </div>

            <div class="mb-4 form-check form-switch">
                <input asp-for="IsActive" class="form-check-input" />
                <label asp-for="IsActive" class="form-check-label">Aktif</label>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-user-plus me-1"></i> Oluştur
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">İptal</a>
            </div>
        </form>
    </div>
</div>
