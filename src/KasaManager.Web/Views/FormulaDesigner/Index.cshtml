    .fd-pool-tab:hover { background: rgba(255,255,255,0.06); }
    .fd-pool-tab-active {
        background: var(--kasa-primary) !important;
        color: #fff !important;
        border-color: var(--kasa-primary) !important;
    }

    /* ── Pool Table ── */
    .fd-pool-key {
        font-family: 'Fira Code', monospace;
        font-size: 11px;
        cursor: pointer;
        transition: background 0.15s;
