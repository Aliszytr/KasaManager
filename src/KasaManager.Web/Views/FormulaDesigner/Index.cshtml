        border-radius: 6px !important;
        transition: all 0.2s ease !important;
        white-space: nowrap;
    }
    .fd-tool-btn:hover { transform: translateY(-1px); box-shadow: 0 3px 8px rgba(0,0,0,0.3); }
    .fd-run-btn {
        min-width: 140px;
        font-size: 13px !important;
        font-weight: 600 !important;
