    }
    .fd-run-btn:hover {
        box-shadow: 0 4px 16px rgba(99, 102, 241, 0.5) !important;
    }

    /* ── Formula Rows ── */
    .fd-row { transition: all 0.2s ease; }
    .fd-row-formula {
        background: rgba(16, 185, 129, 0.03) !important;
        border-left: 3px solid var(--kasa-success) !important;
    }
    .fd-row-map {
        border-left: 3px solid transparent;
    }
    .fd-row:hover {
        background: rgba(255,255,255,0.03) !important;
    }
    .fd-row-hidden {
        opacity: 0.35;
        background: rgba(0,0,0,0.1) !important;
    }
    .fd-row-hidden td {
        padding-top: 2px !important;
        padding-bottom: 2px !important;
    }

    /* ── Highlight (test result with value) ── */
    .fd-row-highlight {
        background: rgba(16, 185, 129, 0.06) !important;
    }

    /* ── Expression Styling ── */
    .fd-expr-formula {
        color: var(--kasa-success) !important;
    }
    .fd-expr-map {
        color: var(--text-muted) !important;
    }
    .fd-expr-code {
        font-family: 'Fira Code', monospace;
        font-size: 11px;
        color: var(--kasa-success);
        background: rgba(16,185,129,0.08);
        padding: 2px 6px;
        border-radius: 4px;
        white-space: nowrap;
    }

    /* ── Result Cell ── */
    .fd-result-cell {
        font-family: 'Fira Code', monospace;
        font-size: 13px;
        padding-right: 12px !important;
    }
    .fd-result-active {
        font-weight: 700;
    }
    .fd-result-formula {
        color: var(--kasa-success) !important;
        text-shadow: 0 0 20px rgba(16, 185, 129, 0.3);
    }
    .fd-result-value { }
    .fd-result-zero {
        color: var(--text-muted) !important;
        font-weight: 400 !important;
        opacity: 0.5;
    }
    .fd-result-currency {
        font-size: 10px;
        color: var(--text-muted);
        margin-left: 2px;
    }

    /* ── Remove Button ── */
    .fd-remove-btn {
        padding: 2px 6px !important;
        font-size: 10px !important;
        opacity: 0.5;
        transition: opacity 0.15s;
    }
    .fd-row:hover .fd-remove-btn { opacity: 1; }

    /* ── Hidden Check ── */
    .fd-hidden-check {
        accent-color: var(--kasa-primary);
        width: 15px;
        height: 15px;
        cursor: pointer;
    }

    /* ── Pool Filters ── */
    .fd-pool-filters {
        padding: 8px 12px;
        border-bottom: 1px solid rgba(255,255,255,0.06);
        display: flex;
        flex-direction: column;
        gap: 6px;
    }
    .fd-pool-tabs {
        display: flex;
        gap: 4px;
        flex-wrap: wrap;
    }
    .fd-pool-tab {
        padding: 3px 10px;
        font-size: 10px;
        border-radius: 12px;
        border: 1px solid rgba(255,255,255,0.1);
        background: transparent;
