                {
                    <div style="margin-top: 8px; font-size: 12px; color: var(--kasa-success);">
                        <i class="fas fa-check-circle me-1"></i> Mutabakat tamam — fark yok
                    </div>
                }
                else
                {
                    <div style="margin-top: 8px; font-size: 12px; color: var(--kasa-danger);">
                        <i class="fas fa-exclamation-triangle me-1"></i> Mutabakat farkı mevcut — kontrol gerekli
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- ═══════════════════════════════════════════════════════════════════ -->
<!-- UYARILAR (sadece gerçek sorunlar varsa)                             -->
<!-- ═══════════════════════════════════════════════════════════════════ -->
@if (Model.Issues.Count > 0)
{
    <div class="kasa-alert kasa-alert-warning" style="border-radius: var(--radius-md); margin-top: 12px;">
        <i class="fas fa-exclamation-circle" style="font-size: 18px; flex-shrink: 0;"></i>
        <div>
            <strong style="font-size: 13px;">Uyarılar</strong>
            <ul style="margin: 4px 0 0 0; padding-left: 18px; font-size: 12px;">
                @foreach (var issue in Model.Issues)
                {
                    <li>@issue</li>
                }
            </ul>
        </div>
    </div>
}


