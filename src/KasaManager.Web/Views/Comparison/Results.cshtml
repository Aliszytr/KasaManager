@section Scripts {
    <script>
        // ═══════════════════════════════════════════════════════════════
        // Sabitler
        // ═══════════════════════════════════════════════════════════════
        const comparisonType = @((int)Model.Type);
        let savedDecisionCount = 0;

        // İstatistik sayaçları (sunucudan gelen değerler)
        let statMatched = @Model.MatchedCount;
        let statPartial = @Model.PartialMatchCount;
        let statNotFound = @Model.NotFoundCount;
        let statMatchedAmt = @Model.TotalMatchedAmount.ToString(System.Globalization.CultureInfo.InvariantCulture);
        let statUnmatchedAmt = @Model.UnmatchedAmount.ToString(System.Globalization.CultureInfo.InvariantCulture);

        // ═══════════════════════════════════════════════════════════════
        // AJAX: Karar Kaydet (Onayla / Reddet)
        // ═══════════════════════════════════════════════════════════════
        async function saveDecisionAjax(btn, decision) {
            const actions = btn.closest('.decision-actions');
            const card = btn.closest('.match-card');

            const payload = {
                comparisonType: comparisonType,
                dosyaNo: actions.dataset.dosyaNo,
                miktar: parseFloat(actions.dataset.miktar) || 0,
                birimAdi: actions.dataset.birim || null,
                bankaTutar: actions.dataset.bankaTutar ? parseFloat(actions.dataset.bankaTutar) : null,
                bankaAciklama: actions.dataset.bankaAciklama || null,
                confidence: parseFloat(actions.dataset.confidence) || 0,
                matchReason: actions.dataset.matchReason || null,
                decision: decision
            };

            // UI feedback — butonları devre dışı bırak
            actions.querySelectorAll('button').forEach(b => { b.disabled = true; });

            try {
                const res = await fetch('@Url.Action("SaveDecision", "Comparison")', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                if (!res.ok) throw new Error('Karar kaydedilemedi');

                // Başarılı — kartı animasyonla gizle
                card.style.transition = 'opacity 0.4s ease, transform 0.4s ease';
                card.style.opacity = '0';
                card.style.transform = 'translateX(' + (decision === 'approved' ? '50px' : '-50px') + ')';
                setTimeout(() => {
                    card.style.display = 'none';
                    // İstatistikleri güncelle
                    // NOT: Backend TotalMatchedAmount = Matched + PartialMatch + MultipleMatches
                    // Yani partial kayıtların tutarı ZATEN matchedAmt'te dahil.
                    // Onay: sadece sayısal kategori değişir (Partial→Matched), tutar zaten dahil.
                    // Red: tutar matchedAmt'ten çıkarılıp unmatchedAmt'e eklenir.
                    statPartial--;
                    if (decision === 'approved') {
                        statMatched++;
                        // Tutar zaten matchedAmt'te — mükerrer ekleme yapma
                    } else {
                        statNotFound++;
                        // Rejected: PartialMatch → NotFound — tutar matched'dan unmatched'a taşınır
                        statMatchedAmt -= payload.miktar;
                        statUnmatchedAmt += payload.miktar;
                    }
                    updateStatsUI();
                }, 400);

                savedDecisionCount++;
                updateDecisionBadge();

            } catch (err) {
                console.error(err);
                actions.querySelectorAll('button').forEach(b => { b.disabled = false; });
                alert('Karar kaydedilirken hata oluştu.');
            }
        }

        // ═══════════════════════════════════════════════════════════════
        // İstatistik Kartlarını Güncelle
        // ═══════════════════════════════════════════════════════════════
        function updateStatsUI() {
            // Eşleşme oranını yeniden hesapla
            const totalRecords = @Model.TotalOnlineRecords;
            const newMatchRate = totalRecords > 0 
                ? Math.round((statMatched + statPartial) * 100 / totalRecords) 
                : 0;

            // Eşleşme oranı kartını güncelle
            const matchRateEl = document.querySelector('[data-stat="matchRate"]');
            if (matchRateEl) matchRateEl.textContent = '%' + newMatchRate;
            const matchRateBar = document.querySelector('[data-stat="matchRateBar"]');
            if (matchRateBar) matchRateBar.style.width = newMatchRate + '%';

            // Stat kartlarındaki sayıları güncelle
            const statEls = document.querySelectorAll('[data-stat]');
            statEls.forEach(el => {
                switch (el.dataset.stat) {
                    case 'matched': el.textContent = statMatched; break;
                    case 'partial': el.textContent = statPartial; break;
                    case 'notfound': el.textContent = statNotFound; break;
                    case 'matchedAmt': el.textContent = statMatchedAmt.toLocaleString('tr-TR', { minimumFractionDigits: 2 }) + ' ₺'; break;
                    case 'unmatchedAmt': el.textContent = statUnmatchedAmt.toLocaleString('tr-TR', { minimumFractionDigits: 2 }) + ' ₺'; break;
                }
            });
            // Filter badge'lerini güncelle
            const filterBtns = document.querySelectorAll('[data-filter-count]');
            filterBtns.forEach(el => {
                switch (el.dataset.filterCount) {
                    case 'matched': el.textContent = statMatched; break;
                    case 'partial': el.textContent = statPartial; break;
                    case 'notfound': el.textContent = statNotFound; break;
                }
            });
        }

        function updateDecisionBadge() {
            const badge = document.getElementById('userDecisionBadge');
            if (badge) badge.textContent = savedDecisionCount;
        }

        // ═══════════════════════════════════════════════════════════════
        // Kullanıcı Seçimleri Modal
        // ═══════════════════════════════════════════════════════════════
        async function showUserDecisions() {
            const modal = new bootstrap.Modal(document.getElementById('userDecisionsModal'));
            modal.show();

            document.getElementById('decisionsLoading').style.display = '';
            document.getElementById('decisionsEmpty').style.display = 'none';
            document.getElementById('decisionsTableWrap').style.display = 'none';

            try {
                const res = await fetch(`@Url.Action("UserDecisions", "Comparison")?type=${comparisonType}`);
                const data = await res.json();

                document.getElementById('decisionsLoading').style.display = 'none';

                if (!data || data.length === 0) {
                    document.getElementById('decisionsEmpty').style.display = '';
                    return;
                }

                savedDecisionCount = data.length;
                updateDecisionBadge();

                const tbody = document.getElementById('decisionsTableBody');
                tbody.innerHTML = '';
                data.forEach(d => {
                    const decisionIcon = d.decision === 'approved'
                        ? '<span class="badge bg-success"><i class="fas fa-check me-1"></i>Onay</span>'
                        : '<span class="badge bg-danger"><i class="fas fa-times me-1"></i>Red</span>';
                    const oppositeLabel = d.decision === 'approved' ? 'Reddet' : 'Onayla';
                    const oppositeDecision = d.decision === 'approved' ? 'rejected' : 'approved';
                    const oppositeClass = d.decision === 'approved' ? 'btn-outline-danger' : 'btn-outline-success';

                    const tr = document.createElement('tr');
                    tr.innerHTML = `
                        <td><code>${d.onlineDosyaNo}</code></td>
                        <td class="text-end">${parseFloat(d.onlineMiktar).toLocaleString('tr-TR', {minimumFractionDigits:2})} ₺</td>
                        <td class="text-truncate" style="max-width:200px" title="${d.onlineBirimAdi || ''}">${d.onlineBirimAdi || '-'}</td>
                        <td class="text-end">${d.bankaTutar ? parseFloat(d.bankaTutar).toLocaleString('tr-TR',{minimumFractionDigits:2})+' ₺' : '-'}</td>
                        <td class="text-center">${decisionIcon}</td>
                        <td><small>${d.decidedAt}</small></td>
                        <td class="text-center">
                            <button class="btn btn-sm ${oppositeClass} me-1" onclick="changeDecision(${d.id},'${oppositeDecision}','${d.onlineDosyaNo}',${d.onlineMiktar},'${d.onlineBirimAdi||''}',${d.bankaTutar||'null'},'${(d.bankaAciklamaSummary||'').replace(/'/g,'')}',${d.confidence||0},'${(d.originalMatchReason||'').replace(/'/g,'')}')"><i class="fas fa-exchange-alt me-1"></i>${oppositeLabel}</button>
                            <button class="btn btn-sm btn-outline-warning" onclick="revertDecision(${d.id})"><i class="fas fa-undo me-1"></i>Geri Al</button>
                        </td>
                    `;
                    tbody.appendChild(tr);
                });

                document.getElementById('decisionsTableWrap').style.display = '';
            } catch (err) {
                document.getElementById('decisionsLoading').style.display = 'none';
                document.getElementById('decisionsEmpty').textContent = 'Kararlar yüklenirken hata oluştu.';
                document.getElementById('decisionsEmpty').style.display = '';
            }
        }

        async function changeDecision(id, newDecision, dosyaNo, miktar, birim, bankaTutar, bankaAciklama, confidence, matchReason) {
            // Önce eski kararı sil, sonra yenisini kaydet
            try {
                await fetch('@Url.Action("DeleteDecision", "Comparison")', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ id: id })
                });

                await fetch('@Url.Action("SaveDecision", "Comparison")', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        comparisonType: comparisonType,
                        dosyaNo: dosyaNo,
                        miktar: miktar,
                        birimAdi: birim || null,
                        bankaTutar: bankaTutar,
                        bankaAciklama: bankaAciklama || null,
                        confidence: confidence,
                        matchReason: matchReason || null,
                        decision: newDecision
                    })
                });

                // Modal'ı yenile
                showUserDecisions();
            } catch (err) {
                alert('Karar değiştirilirken hata oluştu.');
            }
        }

        async function revertDecision(id) {
            if (!confirm('Bu kararı geri almak istediğinize emin misiniz? Kayıt tekrar kısmi eşleşmeler arasında görünecek.')) return;
            try {
                await fetch('@Url.Action("DeleteDecision", "Comparison")', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ id: id })
                });

                savedDecisionCount = Math.max(0, savedDecisionCount - 1);
                updateDecisionBadge();

                // Modal'ı yenile
                showUserDecisions();

                // Not: Sayfayı yenilemeden kart geri görünmez — 
                // kullanıcıya bilgi ver
                alert('Karar geri alındı. Değişikliğin tam yansıması için sayfayı yeniden yükleyiniz.');
            } catch (err) {
                alert('Karar geri alınırken hata oluştu.');
            }
        }

        // ═══════════════════════════════════════════════════════════════
        // PDF Export
        // ═══════════════════════════════════════════════════════════════
        function submitPdfExport() {
            const reportData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model, new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = null }));
            document.getElementById('reportJsonField').value = JSON.stringify(reportData);
            document.getElementById('decisionsJsonField').value = '{}';
            document.getElementById('pdfExportForm').submit();
        }

        // ═══════════════════════════════════════════════════════════════
        // Filtreleme & Görünüm
        // ═══════════════════════════════════════════════════════════════
        function filterResults(status, btn) {
            document.querySelectorAll('.card-body .btn-outline-secondary, .card-body .btn-outline-success, .card-body .btn-outline-warning, .card-body .btn-outline-danger').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            document.querySelectorAll('.match-card, .list-row').forEach(item => {
                item.style.display = (status === 'all' || item.dataset.status === status) ? '' : 'none';
            });
        }

        function switchView(view, btn) {
            document.querySelectorAll('.view-toggle .btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            document.getElementById('cardView').style.display = view === 'card' ? '' : 'none';
            document.getElementById('listView').style.display = view === 'list' ? '' : 'none';
        }

        // Collapse ikon güncellemesi
        document.querySelectorAll('.expand-btn').forEach(btn => {
            const target = document.querySelector(btn.dataset.bsTarget);
            if (target) {
                target.addEventListener('show.bs.collapse', () => {
                    btn.innerHTML = '<i class="fas fa-chevron-up"></i> Gizle';
                });
                target.addEventListener('hide.bs.collapse', () => {
                    btn.innerHTML = '<i class="fas fa-chevron-down"></i> Ham Veri';
                });
            }
        });

        // Sayfa yüklendiğinde karar sayısını getir
        (async function() {
            try {
                const res = await fetch(`@Url.Action("UserDecisions", "Comparison")?type=${comparisonType}`);
                const data = await res.json();
                savedDecisionCount = data ? data.length : 0;
                updateDecisionBadge();
            } catch(e) {}
        })();
    </script>
}
