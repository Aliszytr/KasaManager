@model KasaManager.Web.Models.FieldChooserViewModel
@using KasaManager.Domain.FormulaEngine

@*
    R17B: Field Chooser Panel - Kaynak Bazlı Merkezi Kontrol
    3 Ana Grup: Excel Ham Veri, Kullanıcı Girişleri, Hesaplanan Alanlar
*@

<div id="fieldChooserPanelContent">
    @* ═══════════ Arama ve Hızlı İşlemler ═══════════ *@
    <div class="p-3 bg-white border-bottom sticky-top">
        <div class="input-group input-group-sm mb-2">
            <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
            <input type="text" 
                   id="fcSearch" 
                   class="form-control" 
                   placeholder="Alan ara..." 
                   autocomplete="off" />
            <button type="button" class="btn btn-outline-secondary" id="fcClearSearch" title="Aramayı Temizle">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>
        <div class="d-flex gap-2 flex-wrap align-items-center">
            @if (!string.IsNullOrEmpty(Model.LoadedTemplateName))
            {
                <span class="badge bg-success" id="fcTemplateName" title="Yüklenen şablon">@Model.LoadedTemplateName</span>
            }
            <button type="button" class="btn btn-sm btn-outline-primary" id="fcSelectAll" title="Tüm alanları seç">
                <i class="bi bi-check-all"></i> Tümü
            </button>
            <button type="button" class="btn btn-sm btn-outline-secondary" id="fcClearAll" title="Tüm seçimleri kaldır">
                <i class="bi bi-x"></i> Temizle
            </button>
            <button type="button" class="btn btn-sm btn-outline-warning" id="fcResetDefaults" title="Varsayılan seçime dön">
                <i class="bi bi-arrow-counterclockwise"></i> Varsayılan
            </button>
            <span class="ms-auto text-muted small">
                <i class="bi bi-check2-square"></i>
                <span id="fcSelectedCount">@Model.SelectedCount</span> / @Model.TotalCount
            </span>
        </div>
    </div>

    @* ═══════════ Kaynak Bazlı Gruplar ═══════════ *@
    <div class="fc-categories" style="overflow-y: auto; max-height: calc(100vh - 300px);">
        <div class="accordion accordion-flush" id="fcAccordion">
            @{
                int groupIdx = 0;
            }
            @foreach (var sourceGroup in Model.SourceGroups)
            {
                var groupId = $"fc_source_{groupIdx}";
                var selInGroup = sourceGroup.Fields.Count(f => Model.IsSelected(f.Key));
                var showClass = groupIdx < 3 ? "show" : ""; // İlk 3 grup açık
                
                <div class="accordion-item">
                    <h2 class="accordion-header">
                        <button class="accordion-button py-2 @(string.IsNullOrEmpty(showClass) ? "collapsed" : "")" 
                                type="button" 
                                data-bs-toggle="collapse" 
                                data-bs-target="#@groupId">
                            <span class="d-flex align-items-center justify-content-between w-100 pe-2">
                                <span class="d-flex align-items-center gap-2">
                                    <i class="bi @sourceGroup.Icon @sourceGroup.ColorClass"></i>
                                    <span class="fw-semibold">@sourceGroup.DisplayName</span>
                                </span>
                                <span class="badge bg-primary bg-opacity-75" data-source-badge="@groupId">
                                    @selInGroup / @sourceGroup.Count
                                </span>
                            </span>
                        </button>
                    </h2>
                    <div id="@groupId" class="accordion-collapse collapse @showClass">
                        <div class="accordion-body py-2" style="max-height: 400px; overflow-y: auto;">
                            @* Grup içindeki alanları kategoriye göre alt-grupla *@
                            @{
                                var fieldsByCategory = sourceGroup.Fields
                                    .GroupBy(f => f.Category)
                                    .OrderBy(g => GetCategorySortOrder(g.Key));
                            }
                            @foreach (var catGroup in fieldsByCategory)
                            {
                                var catId = $"{groupId}_{catGroup.Key.Replace(" ", "_").Replace("/", "_")}";
                                <div class="fc-category-section mb-2">
                                    <div class="text-muted small fw-semibold px-2 py-1 bg-light rounded-top border-bottom">
                                        @catGroup.Key
                                        <span class="badge bg-secondary bg-opacity-50 ms-1">@catGroup.Count()</span>
                                    </div>
                                    <div class="fc-fields-list">
                                        @foreach (var field in catGroup.OrderBy(f => f.SortOrder))
                                        {
                                            var fid = $"fc_{field.Key.Replace("_", "-")}";
                                            var isSel = Model.IsSelected(field.Key);
                                            var hiddenCls = field.IsHidden ? "d-none" : "";
                                            
                                            <div class="form-check fc-field-item py-1 px-2 rounded @hiddenCls" 
                                                 data-fc-key="@field.Key"
                                                 data-fc-source="@((int)sourceGroup.Source)"
                                                 data-fc-cat="@catGroup.Key">
                                                <input class="form-check-input fc-checkbox" 
                                                       type="checkbox" 
                                                       value="@field.Key" 
                                                       id="@fid"
                                                       @(isSel ? "checked" : "") />
                                                <label class="form-check-label d-flex flex-column w-100" for="@fid">
                                                    <div class="d-flex align-items-center gap-2">
                                                        @if (!string.IsNullOrEmpty(field.Icon))
                                                        {
                                                            <i class="bi @field.Icon @field.ColorClass" style="width: 16px;"></i>
                                                        }
                                                        <span class="@(field.IsReadOnly ? "text-muted fst-italic" : "")">
                                                            @field.DisplayName
                                                        </span>
                                                        @if (field.IsReadOnly)
                                                        {
                                                            <span class="badge bg-light text-muted border ms-auto" style="font-size: 0.6rem;" title="Hesaplanan alan">
                                                                <i class="bi bi-calculator"></i>
                                                            </span>
                                                        }
                                                    </div>
                                                    @if (!string.IsNullOrEmpty(field.Description))
                                                    {
                                                        <small class="text-muted" style="font-size: 0.7rem; line-height: 1.2;">
                                                            @field.Description
                                                        </small>
                                                    }
                                                </label>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
                groupIdx++;
            }
        </div>
    </div>

    @* ═══════════ Footer ═══════════ *@
    <div class="p-3 border-top bg-white">
        <div class="d-flex gap-2 justify-content-end">
            <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="offcanvas">
                İptal
            </button>
            <button type="button" class="btn btn-primary btn-sm" id="fcApply">
                <i class="bi bi-check-lg"></i> Sol Menüye Uygula
            </button>
        </div>
    </div>
</div>

<style>
    .fc-categories .fc-field-item:hover {
        background-color: rgba(var(--bs-primary-rgb), 0.05);
    }
    .fc-categories .accordion-button {
        padding: 0.6rem 1rem;
        font-size: 0.9rem;
    }
    .fc-categories .accordion-button:focus {
        box-shadow: none;
    }
    .fc-categories .form-check-input:checked + .form-check-label {
        font-weight: 500;
    }
    .fc-category-section {
        border: 1px solid #e9ecef;
        border-radius: 0.375rem;
        margin-bottom: 0.5rem;
    }
    .fc-category-section .fc-fields-list {
        padding: 0.25rem;
    }
</style>

<script>
// R17B: Field Chooser - Kaynak Bazlı Merkezi Kontrol
// AJAX ile yüklendikten sonra çalışır
(function initFieldChooser() {
    'use strict';
    
    const panel = document.getElementById('fieldChooserPanelContent');
    if (!panel) {
        console.error('R17B: Panel bulunamadı');
        return;
    }
    
    const countSpan = document.getElementById('fcSelectedCount');
    const searchInput = document.getElementById('fcSearch');
    
    // Tüm checkbox'ları al
    function getAllCheckboxes() {
        return panel.querySelectorAll('.fc-checkbox');
    }
    
    // Sayaç güncelleme
    function updateCount() {
        const all = getAllCheckboxes();
        const checked = panel.querySelectorAll('.fc-checkbox:checked').length;
        
        if (countSpan) {
            countSpan.textContent = checked;
        }
        
        // Grup badge'lerini güncelle
        panel.querySelectorAll('.accordion-item').forEach(group => {
            const badge = group.querySelector('[data-source-badge]');
            if (badge) {
                const total = group.querySelectorAll('.fc-checkbox').length;
                const selected = group.querySelectorAll('.fc-checkbox:checked').length;
                badge.textContent = `${selected} / ${total}`;
            }
        });
        
        console.log('R17B: Count updated:', checked, '/', all.length);
    }
    
    // EVENT DELEGATION - Panel'e tek event listener
    panel.addEventListener('change', function(e) {
        if (e.target.classList.contains('fc-checkbox')) {
            console.log('R17B: Checkbox changed:', e.target.value, e.target.checked);
            updateCount();
        }
    });
    
    // Arama
    if (searchInput) {
        searchInput.addEventListener('input', function() {
            const search = this.value.toLowerCase().trim();
            panel.querySelectorAll('.fc-field-item').forEach(item => {
                if (item.classList.contains('d-none')) return;
                const text = item.textContent?.toLowerCase() || '';
                const key = item.dataset.fcKey?.toLowerCase() || '';
                item.style.display = (search === '' || text.includes(search) || key.includes(search)) ? '' : 'none';
            });
            // Kategori bölümlerini gizle/göster
            panel.querySelectorAll('.fc-category-section').forEach(section => {
                const vis = section.querySelectorAll('.fc-field-item:not([style*="display: none"])');
                section.style.display = vis.length > 0 ? '' : 'none';
            });
        });
    }
    
    document.getElementById('fcClearSearch')?.addEventListener('click', () => {
        if (searchInput) { searchInput.value = ''; searchInput.dispatchEvent(new Event('input')); }
    });
    
    // Tümü Seç
    document.getElementById('fcSelectAll')?.addEventListener('click', () => {
        getAllCheckboxes().forEach(cb => cb.checked = true);
        updateCount();
    });
    
    // Temizle
    document.getElementById('fcClearAll')?.addEventListener('click', () => {
        getAllCheckboxes().forEach(cb => cb.checked = false);
        updateCount();
    });
    
    // Varsayılana Dön
    document.getElementById('fcResetDefaults')?.addEventListener('click', async () => {
        const kasaType = document.getElementById('fcKasaType')?.textContent?.trim() || 'Aksam';
        try {
            const response = await fetch(`/FieldChooser/ResetToDefaults?kasaType=${kasaType}`, { method: 'POST' });
            if (response.ok) {
                const result = await response.json();
                if (result.defaultFields) {
                    getAllCheckboxes().forEach(cb => {
                        cb.checked = result.defaultFields.includes(cb.value);
                    });
                    updateCount();
                }
            }
        } catch (err) { console.error('R17B: Reset error:', err); }
    });
    
    // UYGULA - Sol Menü Senkronizasyonu (R18: Yeni alanları da ekler)
    document.getElementById('fcApply')?.addEventListener('click', function() {
        const selectedFields = Array.from(panel.querySelectorAll('.fc-checkbox:checked')).map(cb => ({
            key: cb.value,
            displayName: cb.closest('.fc-field-item')?.querySelector('.fc-field-name')?.textContent?.trim() || cb.value,
            source: cb.closest('.fc-field-item')?.dataset.fcSource || 'Excel'
        }));
        console.log('R18: Uygula clicked, seçili:', selectedFields.length, selectedFields);
        
        // Sol menüdeki mevcut checkbox'ları bul
        const solMenuCheckboxes = document.querySelectorAll('[data-ham-check]');
        const existingKeys = new Set();
        let updatedCount = 0;
        
        // 1. Mevcut checkbox'ları güncelle
        solMenuCheckboxes.forEach(cb => {
            const key = cb.dataset.key || cb.value;
            existingKeys.add(key.toLowerCase());
            const shouldBeChecked = selectedFields.some(f => f.key.toLowerCase() === key.toLowerCase());
            if (cb.checked !== shouldBeChecked) {
                cb.checked = shouldBeChecked;
                updatedCount++;
            }
        });
        
        // 2. Sol menüde olmayan yeni alanları ekle
        const scrollArea = document.querySelector('.ham-scroll-area');
        let addedCount = 0;
        
        if (scrollArea) {
            selectedFields.forEach(field => {
                if (!existingKeys.has(field.key.toLowerCase())) {
                    // Yeni satır oluştur
                    const newRow = document.createElement('div');
                    newRow.className = 'form-check ham-item d-flex align-items-start gap-2 mb-1';
                    newRow.setAttribute('data-ham-item', '');
                    newRow.setAttribute('data-key', field.key);
                    
                    const sourceClass = field.source === 'UserInput' ? 'bg-primary' 
                                       : field.source === 'Calculated' ? 'bg-warning text-dark' 
                                       : 'bg-info text-dark';
                    const sourceLabel = field.source === 'UserInput' ? 'UserInput' 
                                       : field.source === 'Calculated' ? 'Calculated' 
                                       : 'Catalog';
                    
                    newRow.innerHTML = `
                        <input class="form-check-input" type="checkbox" name="SelectedInputKeys" 
                               value="${field.key}" data-ham-check data-key="${field.key}" />
                        <label class="form-check-label w-100">
                            <div class="ham-line1">
                                <code class="ham-key">${field.key}</code>
                                <span class="badge ${sourceClass}">${sourceLabel}</span>
                            </div>
                            <div class="ham-line2">
                                <span class="ham-source">FieldCatalog • Alan Seçici'den eklendi</span>
                                <span class="ham-value">0.00</span>
                            </div>
                        </label>
                    `;
                    
                    scrollArea.insertBefore(newRow, scrollArea.firstChild);
                    existingKeys.add(field.key.toLowerCase());
                    addedCount++;
                }
            });
        }
        
        console.log('R18: Sol menu updated:', updatedCount, 'checkbox, yeni eklenen:', addedCount);
        
        // Ham veri sayılarını güncelle
        const countBadge = document.querySelector('.ham-panel .badge.bg-light');
        const visibleCount = document.getElementById('hamVisibleCount');
        if (countBadge && addedCount > 0) {
            const currentCount = parseInt(countBadge.textContent) || 0;
            countBadge.textContent = `${currentCount + addedCount} satır`;
        }
        if (visibleCount && addedCount > 0) {
            const currentVisible = parseInt(visibleCount.textContent) || 0;
            visibleCount.textContent = currentVisible + addedCount;
        }
        
        // Offcanvas kapat
        const offcanvasEl = document.getElementById('fieldChooserOffcanvas');
        if (offcanvasEl && typeof bootstrap !== 'undefined') {
            const offcanvas = bootstrap.Offcanvas.getInstance(offcanvasEl);
            offcanvas?.hide();
        }
        
        // Bildirim
        const alertDiv = document.createElement('div');
        alertDiv.className = 'alert alert-success alert-dismissible fade show position-fixed';
        alertDiv.style.cssText = 'top: 20px; right: 20px; z-index: 9999; max-width: 400px;';
        const msg = addedCount > 0 
            ? `<strong>${selectedFields.length}</strong> alan Sol Menüye uygulandı. <span class="badge bg-success">${addedCount} yeni alan eklendi!</span>`
            : `<strong>${selectedFields.length}</strong> alan Sol Menüye uygulandı.`;
        alertDiv.innerHTML = `<i class="bi bi-check-circle"></i> ${msg}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>`;
        document.body.appendChild(alertDiv);
        setTimeout(() => alertDiv.remove(), 4000);
    });
    
    // İlk sayaç güncelleme - DOM hazır olduğunda
    updateCount();
    console.log('R17B: Field Chooser initialized, checkboxes:', getAllCheckboxes().length);
})();
</script>

@functions {
    private static int GetCategorySortOrder(string category)
    {
        return category.ToLowerInvariant() switch
        {
            "tahsilat" => 1,
            "harç" => 2,
            "reddiyat" => 3,
            "stopaj" => 4,
            "eksik/fazla" => 5,
            "banka" => 6,
            "kasa" => 7,
            "banka yatırım" => 8,
            "vergi" => 9,
            "ortak kasa" => 10,
            "genel kasa hesap" => 11,
            "masraf" => 12,
            "meta" => 99,
            _ => 50
        };
    }
}
