@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    string ActiveClass(params string[] names) =>
        names.Any(n => n.Equals(currentController, StringComparison.OrdinalIgnoreCase)) ? "active" : "";

    // Server-side dark mode: cookie'den tema oku — JS'ten önce doğru tema garanti
    var themeCookie = Context.Request.Cookies["kasa-theme"];
    var serverTheme = themeCookie == "light" ? "light" : "dark"; // default: dark
}
<!DOCTYPE html>
<html lang="tr" data-theme="@serverTheme" data-bs-theme="@serverTheme">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>KasaManager</title>
    <meta name="description" content="Profesyonel Kasa Yönetim Sistemi" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    <!-- Bootstrap 5.3 -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <!-- KasaManager Design System -->
    <link rel="stylesheet" href="~/css/kasa-design-system.css" asp-append-version="true" />

    <!-- Scripts: head'de defer ile yüklenir — RenderBody crash'i durumunda bile çalışır -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script defer src="~/js/kasa-ui.js" asp-append-version="true"></script>
    <script defer src="~/js/alpine.min.js" asp-append-version="true"></script>

    @RenderSection("Styles", required: false)

    @* Tema IIFE: Alpine yüklenmeden önce doğru temayı anında uygular *@
    <script>
    (function(){
      var t=localStorage.getItem('kasa-theme')!=='light'?'dark':'light';
      document.documentElement.setAttribute('data-theme',t);
      document.documentElement.setAttribute('data-bs-theme',t);
      // Cookie'yi de senkronize et (server-side için)
      document.cookie='kasa-theme='+t+';path=/;max-age=31536000;SameSite=Lax';
    })();
    </script>
</head>
<body x-data :class="{ 'sidebar-collapsed': $store.sidebar.collapsed }">

    <!-- Sidebar -->
    <aside class="kasa-sidebar"
           :class="{ 'collapsed': $store.sidebar.collapsed, 'mobile-open': $store.sidebar.mobileOpen }">

        <!-- Brand -->
        <a class="kasa-sidebar-brand" asp-controller="Home" asp-action="Index">
            <div class="kasa-sidebar-brand-icon">
                <i class="fas fa-vault"></i>
            </div>
            <span class="kasa-sidebar-brand-text">KasaManager</span>
        </a>

        <!-- Navigation -->
        <ul class="kasa-sidebar-nav">

            <li class="kasa-sidebar-section">Ana Modüller</li>

            <li>
                <a class="kasa-sidebar-link @ActiveClass("Home")"
                   asp-controller="Home" asp-action="Index">
                    <i class="fas fa-th-large"></i>
                    <span class="link-text">Dashboard</span>
                </a>
            </li>
            <li>
                <a class="kasa-sidebar-link @ActiveClass("Import")"
                   asp-controller="Import" asp-action="Index">
                    <i class="fas fa-file-upload"></i>
                    <span class="link-text">Dosya Yükleme</span>
                </a>
            </li>

            <li class="kasa-sidebar-section">Kasa Hesaplama</li>

            <li>
                <a class="kasa-sidebar-link @ActiveClass("KasaPreview")"
                   asp-controller="KasaPreview" asp-action="Index" asp-route-kasaType="sabah">
                    <i class="fas fa-sun"></i>
                    <span class="link-text">Sabah Kasa</span>
                </a>
            </li>
            <li>
                <a class="kasa-sidebar-link @ActiveClass("KasaPreview")"
                   asp-controller="KasaPreview" asp-action="Index" asp-route-kasaType="aksam">
                    <i class="fas fa-moon"></i>
                    <span class="link-text">Akşam Kasa</span>
                </a>
            </li>
            <li>
                <a class="kasa-sidebar-link @ActiveClass("KasaPreview")"
                   asp-controller="KasaPreview" asp-action="Index" asp-route-kasaType="genel">
                    <i class="fas fa-chart-pie"></i>
                    <span class="link-text">Genel Kasa</span>
                </a>
            </li>
            <li>
                <a class="kasa-sidebar-link @ActiveClass("FormulaDesigner")"
                   asp-controller="FormulaDesigner" asp-action="Index">
                    <i class="fas fa-drafting-compass"></i>
                    <span class="link-text">Formül Designer</span>
                </a>
            </li>

            <li class="kasa-sidebar-section">Raporlar</li>

            <li>
                <a class="kasa-sidebar-link @ActiveClass("KasaUstRapor")"
                   asp-controller="KasaUstRapor" asp-action="Index">
                    <i class="fas fa-file-alt"></i>
                    <span class="link-text">KasaÜstRapor</span>
                </a>
            </li>
            @if (User.IsInRole("Admin"))
            {
            <li>
                <a class="kasa-sidebar-link @ActiveClass("GenelKasaRapor")"
                   asp-controller="GenelKasaRapor" asp-action="Index">
                    <i class="fas fa-chart-bar"></i>
                    <span class="link-text">Genel Kasa Rapor</span>
                </a>
            </li>
            }
            <li>
                <a class="kasa-sidebar-link @ActiveClass("KasaRaporlar")"
                   asp-controller="KasaRaporlar" asp-action="Index">
                    <i class="fas fa-folder-open"></i>
                    <span class="link-text">Kasa Raporları</span>
                </a>
            </li>
            <li>
                <a class="kasa-sidebar-link @ActiveClass("Comparison")"
                   asp-controller="Comparison" asp-action="Index">
                    <i class="fas fa-balance-scale"></i>
                    <span class="link-text">Karşılaştırma</span>
                </a>
            </li>
            <li>
                <a class="kasa-sidebar-link @ActiveClass("HesapKontrol")"
                   asp-controller="HesapKontrol" asp-action="Index">
                    <i class="fas fa-university"></i>
                    <span class="link-text">Hesap Kontrol</span>
                </a>
            </li>
            @inject Microsoft.Extensions.Configuration.IConfiguration _config
            @if (_config.GetValue<bool>("LegacyDatabase:Enabled"))
            {
            <li>
                <a class="kasa-sidebar-link @ActiveClass("LegacyKasa")"
                   asp-controller="LegacyKasa" asp-action="Index">
                    <i class="fas fa-archive"></i>
                    <span class="link-text">Eski Veriler</span>
                </a>
            </li>
            }

            <li class="kasa-sidebar-section">Yönetim</li>

            <li>
                <a class="kasa-sidebar-link @ActiveClass("KasaSettings")"
                   asp-controller="KasaSettings" asp-action="Index">
                    <i class="fas fa-cog"></i>
                    <span class="link-text">Ayarlar</span>
                </a>
            </li>
            @if (User.IsInRole("Admin"))
            {
            <li>
                <a class="kasa-sidebar-link @ActiveClass("UserManagement")"
                   asp-controller="UserManagement" asp-action="Index">
                    <i class="fas fa-users-cog"></i>
                    <span class="link-text">Kullanıcılar</span>
                </a>
            </li>
            <li>
                <a class="kasa-sidebar-link @ActiveClass("Backup")"
                   asp-controller="Backup" asp-action="Index">
                    <i class="fas fa-shield-alt"></i>
                    <span class="link-text">DB Yedek</span>
                </a>
            </li>
            }
            <li>
                <a class="kasa-sidebar-link @ActiveClass("Account")"
                   asp-controller="Account" asp-action="ChangePassword">
                    <i class="fas fa-key"></i>
                    <span class="link-text">Şifre Değiştir</span>
                </a>
            </li>
            <li>
                <a class="kasa-sidebar-link @ActiveClass("Diagnostics")"
                   asp-controller="Diagnostics" asp-action="Db">
                    <i class="fas fa-database"></i>
                    <span class="link-text">Diagnostics</span>
                </a>
            </li>
        </ul>

        <!-- Sidebar Footer -->
        <div class="kasa-sidebar-footer">
            <a class="kasa-sidebar-link" href="#" @@click.prevent="$store.sidebar.toggle()">
                <i class="fas" :class="$store.sidebar.collapsed ? 'fa-angles-right' : 'fa-angles-left'"></i>
                <span class="link-text">Daralt</span>
            </a>
        </div>
    </aside>

    <!-- Mobile overlay -->
    <div class="sidebar-overlay"
         :class="{ 'show': $store.sidebar.mobileOpen }"
         @@click="$store.sidebar.closeMobile()"></div>

    <!-- Header -->
    <header class="kasa-header">
        <div class="kasa-header-left">
            <!-- Mobile menu toggle -->
            <button class="sidebar-toggle d-lg-none"
                    @@click="$store.sidebar.openMobile()">
                <i class="fas fa-bars"></i>
            </button>
            <!-- Desktop collapse toggle -->
            <button class="sidebar-toggle d-none d-lg-flex"
                    @@click="$store.sidebar.toggle()">
                <i class="fas" :class="$store.sidebar.collapsed ? 'fa-angles-right' : 'fa-angles-left'"></i>
            </button>
            <div class="kasa-header-datetime">
                <i class="fas fa-calendar-day"></i>
                <span id="kasa-date"></span>
                <span class="mx-1 text-muted">|</span>
                <i class="fas fa-clock"></i>
                <span id="kasa-clock" class="font-mono"></span>
            </div>
        </div>
        <div class="kasa-header-right">
            <!-- Theme toggle -->
            <button class="theme-toggle"
                    @@click="$store.darkMode.toggle()"
                    :title="$store.darkMode.on ? 'Açık Mod' : 'Koyu Mod'">
                <i class="fas" :class="$store.darkMode.on ? 'fa-sun' : 'fa-moon'"></i>
            </button>

            @if (User.Identity?.IsAuthenticated == true)
            {
                <span class="kasa-user-badge" title="@User.FindFirst("UserId")?.Value">
                    <i class="fas fa-user-circle"></i>
                    <span class="d-none d-md-inline">@(User.FindFirst(System.Security.Claims.ClaimTypes.GivenName)?.Value ?? User.Identity.Name)</span>
                </span>
                <form method="post" asp-controller="Account" asp-action="Logout" style="display:inline;">
                    <button type="submit" class="theme-toggle" title="Çıkış Yap">
                        <i class="fas fa-sign-out-alt"></i>
                    </button>
                </form>
            }
        </div>
    </header>

    <!-- Toast container -->
    <div id="kasa-toast-container" class="kasa-toast-container"></div>

    <!-- Main content -->
    <main class="kasa-main kasa-fade-in">
        @if (TempData["Error"] != null)
        {
            <div class="kasa-alert kasa-alert-danger">
                <i class="fas fa-exclamation-circle"></i>
                <div>@TempData["Error"]</div>
            </div>
        }
        @if (TempData["Info"] != null)
        {
            <div class="kasa-alert kasa-alert-info">
                <i class="fas fa-info-circle"></i>
                <div>@TempData["Info"]</div>
            </div>
        }

        @RenderBody()
    </main>

    <!-- Scripts: head'e taşındı — burada sadece sayfa-özel scriptler -->
    @RenderSection("Scripts", required: false)
</body>
</html>