@{
    var title = ViewData["Title"]?.ToString() ?? "KasaManager";
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@title — KasaManager</title>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

    <style>
        :root {
            --login-bg: #0f172a;
            --login-card-bg: #1e293b;
            --login-card-border: rgba(255,255,255,0.06);
            --login-accent: #3b82f6;
            --login-accent-hover: #2563eb;
            --login-text: #f1f5f9;
            --login-text-muted: #94a3b8;
            --login-input-bg: #0f172a;
            --login-input-border: #334155;
            --login-input-focus: #3b82f6;
            --login-danger: #ef4444;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
            background: var(--login-bg);
            color: var(--login-text);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background-image:
                radial-gradient(ellipse at 20% 50%, rgba(59,130,246,0.08) 0%, transparent 50%),
                radial-gradient(ellipse at 80% 20%, rgba(139,92,246,0.06) 0%, transparent 50%);
        }

        .login-container {
            width: 100%;
            max-width: 420px;
            padding: 1.5rem;
            animation: fadeInUp 0.5s ease-out;
        }

        @@keyframes fadeInUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .login-card {
            background: var(--login-card-bg);
            border: 1px solid var(--login-card-border);
            border-radius: 16px;
            padding: 2.5rem 2rem;
            box-shadow: 0 25px 50px rgba(0,0,0,0.3);
            backdrop-filter: blur(20px);
        }

        .login-header {
            text-align: center;
            margin-bottom: 2rem;
        }

        .login-logo {
            width: 64px;
            height: 64px;
            border-radius: 16px;
            background: linear-gradient(135deg, var(--login-accent), #8b5cf6);
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1.25rem;
            font-size: 1.75rem;
            color: white;
            box-shadow: 0 8px 24px rgba(59,130,246,0.3);
        }

        .login-header h1 {
            font-size: 1.5rem;
            font-weight: 700;
            letter-spacing: -0.025em;
            margin-bottom: 0.25rem;
        }

        .login-subtitle {
            color: var(--login-text-muted);
            font-size: 0.875rem;
        }

        .login-alert {
            background: rgba(239,68,68,0.12);
            border: 1px solid rgba(239,68,68,0.25);
            border-radius: 10px;
            padding: 0.75rem 1rem;
            margin-bottom: 1.25rem;
            display: flex;
            align-items: center;
            gap: 0.625rem;
            font-size: 0.875rem;
            color: #fca5a5;
        }

        .login-alert i { color: var(--login-danger); flex-shrink: 0; }

        .login-form { display: flex; flex-direction: column; gap: 1.25rem; }

        .login-field label {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-size: 0.8125rem;
            font-weight: 500;
            color: var(--login-text-muted);
            margin-bottom: 0.5rem;
        }

        .login-field input {
            width: 100%;
            padding: 0.75rem 1rem;
            background: var(--login-input-bg);
            border: 1px solid var(--login-input-border);
            border-radius: 10px;
            color: var(--login-text);
            font-size: 0.9375rem;
            font-family: inherit;
            transition: border-color 0.2s, box-shadow 0.2s;
            outline: none;
        }

        .login-field input:focus {
            border-color: var(--login-input-focus);
            box-shadow: 0 0 0 3px rgba(59,130,246,0.15);
        }

        .login-field input::placeholder {
            color: #475569;
        }

        .password-wrapper {
            position: relative;
        }

        .password-wrapper input {
            padding-right: 3rem;
        }

        .password-toggle {
            position: absolute;
            right: 0.75rem;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            color: var(--login-text-muted);
            cursor: pointer;
            font-size: 1rem;
            padding: 0.25rem;
            transition: color 0.2s;
        }

        .password-toggle:hover { color: var(--login-text); }

        .login-btn {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            width: 100%;
            padding: 0.8rem 1.5rem;
            background: linear-gradient(135deg, var(--login-accent), #2563eb);
            color: white;
            border: none;
            border-radius: 10px;
            font-size: 0.9375rem;
            font-weight: 600;
            font-family: inherit;
            cursor: pointer;
            transition: all 0.2s;
            margin-top: 0.5rem;
        }

        .login-btn:hover {
            background: linear-gradient(135deg, var(--login-accent-hover), #1d4ed8);
            transform: translateY(-1px);
            box-shadow: 0 4px 16px rgba(59,130,246,0.35);
        }

        .login-btn:active {
            transform: translateY(0);
        }

        .login-footer {
            text-align: center;
            margin-top: 1.5rem;
            color: var(--login-text-muted);
            font-size: 0.75rem;
        }
    </style>
</head>
<body>
    @RenderBody()

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
