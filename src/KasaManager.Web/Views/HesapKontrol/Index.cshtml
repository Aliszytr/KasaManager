                                    <strong>@k.DosyaNo</strong>
                                }
                                @if (!string.IsNullOrEmpty(k.BirimAdi))
                                {
                                    <span class="text-muted"> — @k.BirimAdi</span>
                                }
                                @if (!string.IsNullOrEmpty(k.Aciklama))
                                {
                                    <div class="text-truncate" title="@k.Aciklama">@k.Aciklama</div>
                                }
                            </td>
                            <td>
                                <div class="btn-group btn-group-sm">
                                    <!-- Takibe Al -->
                                    <form method="post" asp-action="StartTracking" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@k.Id" />
                                        <input type="hidden" name="not" value="" />
                                        <button type="submit" class="btn btn-outline-info btn-sm" title="Takibe Al"
                                                onclick="return confirm('Bu kaydı takibe almak istediğinize emin misiniz?');">
                                            <i class="fas fa-binoculars me-1"></i>Takibe Al
                                        </button>
                                    </form>
                                    <!-- Yok Say -->
                                    <form method="post" asp-action="Cancel" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@k.Id" />
                                        <input type="hidden" name="sebep" value="" />
                                        <button type="submit" class="btn btn-outline-secondary btn-sm" title="Yok Say (yanlış tespit)"
                                                onclick="return confirm('Bu kaydı yok saymak istediğinize emin misiniz?');">
                                            <i class="fas fa-times me-1"></i>Yok Say
                                        </button>
                                    </form>
                                    <!-- Faz 2→3: İstisna Olarak Ekle (aynı sayfada POST) -->
                                    <form method="post" asp-action="CreateFinansalIstisnaFromHK" class="d-inline"
                                          onsubmit="return confirm('Bu farkı finansal istisna olarak kaydetmek istiyor musunuz?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="kayitId" value="@k.Id" />
                                        <input type="hidden" name="hesapTuru" value="@((int)k.HesapTuru)" />
                                        <input type="hidden" name="yon" value="@((int)k.Yon)" />
                                        <input type="hidden" name="tutar" value="@k.Tutar" />
                                        <input type="hidden" name="aciklama" value="@(k.Aciklama ?? k.TespitEdilenTip ?? "")" />
                                        <input type="hidden" name="analizTarihi" value="@k.AnalizTarihi.ToString("yyyy-MM-dd")" />
                                        <button type="submit" class="btn btn-outline-warning btn-sm"
                                                title="Bu farkı operasyonel istisna olarak kaydet">
                                            <i class="fas fa-exclamation-triangle me-1"></i>İstisna Ekle
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                        </tbody>
                    </table>
                </div>
        }
    }

    <script>
    document.addEventListener('DOMContentLoaded', function() {
        // BUG FIX: POST isteklerine analiz tarihi ekleme
        var isHistorical = @(isHistoricalTabs ? "true" : "false");
        var tarihStr = '@Model.AnalizTarihi.ToString("yyyy-MM-dd")';
        if (isHistorical) {
            document.querySelectorAll('form[method="post"]').forEach(function(f) {
                // "tarih" isminde gizli eleman ekle, ama RunAnalysis zaten bir tanesine sahip, çakışmayı önle
                if (!f.querySelector('input[name="tarih"]')) {
                    var inp = document.createElement('input');
                    inp.type = 'hidden';
                    inp.name = 'tarih';
                    inp.value = tarihStr;
                    f.appendChild(inp);
                }
            });
        }

        var selectAll = document.getElementById('selectAll');
        var btnBulk = document.getElementById('btnBulkCancel');
        if (!selectAll || !btnBulk) return;

        function updateBulk() {
            var checked = document.querySelectorAll('.row-select:checked').length;
            btnBulk.disabled = checked === 0;
            btnBulk.innerHTML = checked > 0
                ? '<i class="fas fa-times-circle me-1"></i>Seçilenleri Yok Say (' + checked + ')'
                : '<i class="fas fa-times-circle me-1"></i>Seçilenleri Yok Say';
        }

        btnBulk.addEventListener('click', function() {
            var checked = document.querySelectorAll('.row-select:checked');
            if (checked.length === 0) return;
            if (!confirm('Seçili ' + checked.length + ' kaydı yok saymak istiyor musunuz?')) return;

            var form = document.getElementById('bulkCancelForm');
            // Önceki dinamik input'ları temizle
            form.querySelectorAll('input[name="ids"]').forEach(function(el) { el.remove(); });
            // Seçili ID'leri hidden input olarak ekle
            checked.forEach(function(cb) {
                var input = document.createElement('input');
                input.type = 'hidden';
                input.name = 'ids';
                input.value = cb.getAttribute('data-id');
                form.appendChild(input);
            });
            form.submit();
        });

        selectAll.addEventListener('change', function() {
            document.querySelectorAll('.row-select').forEach(function(cb) {
                cb.checked = selectAll.checked;
            });
            updateBulk();
        });

        document.querySelectorAll('.row-select').forEach(function(cb) {
            cb.addEventListener('change', updateBulk);
        });
    });
    </script>

    <!-- ═══════ TAB: Takipte ═══════ -->
    @if (activeTab == "takipte")
    {
        @* ═══════ Bölüm 1: Bugün Çözülen Takip Kayıtları ═══════ *@
        @if (takipOzeti != null && takipOzeti.BugunCozulenler.Count > 0)
        {
            <div class="card mb-3" style="border-left: 5px solid #27ae60; background: linear-gradient(135deg, rgba(39,174,96,0.06) 0%, rgba(39,174,96,0.02) 100%);">
                <div class="card-body py-3">
                    <div class="d-flex align-items-center mb-2">
                        <span style="font-size: 24px; margin-right: 8px;">🎉</span>
                        <h6 class="mb-0 fw-bold" style="color: #27ae60;">
                            Bugün Gelen Takip Kayıtları
                            <span class="badge bg-success ms-1">@takipOzeti.BugunCozulenler.Count kayıt — @takipOzeti.BugunCozulenToplam.ToString("N2") ₺</span>
                        </h6>
                    </div>
                    <p class="small text-muted mb-2">Bu kayıtlar daha önce eksikti, bugün gelerek otomatik olarak <strong>Çözüldü</strong> (sistem eşleştirdi) olarak işaretlendi.</p>
