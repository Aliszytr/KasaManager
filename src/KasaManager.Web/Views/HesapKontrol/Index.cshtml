                            <th>Yön</th>
                            <th>Tutar</th>
                            <th>Sınıf</th>
                            <th>Takip Süresi</th>
                            <th>Tip</th>
                            <th>Açıklama / Dosya</th>
                            <th>İşlem</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var k in takipteKayitlar)
                    {
                        var takipGun = k.TakipteGunSayisi ?? 0;
                        var takipClass = takipGun >= 5 ? "text-danger fw-bold" : takipGun >= 2 ? "text-warning fw-bold" : "text-muted";
                        var takipIcon = takipGun >= 5 ? "🔴" : takipGun >= 2 ? "⚠️" : "📌";
                        <tr>
                            <td>@k.AnalizTarihi.ToString("dd.MM.yyyy")</td>
                            <td>
                                <span class="badge @(k.HesapTuru == BankaHesapTuru.Tahsilat ? "bg-success" : k.HesapTuru == BankaHesapTuru.Harc ? "bg-primary" : "bg-warning text-dark")">
                                    @k.HesapTuru
                                </span>
                            </td>
                            <td>
                                @if (k.Yon == KayitYonu.Eksik)
                                {
                                    <span class="text-danger fw-bold"><i class="fas fa-arrow-down me-1"></i>Eksik</span>
                                }
                                else
                                {
                                    <span class="text-success fw-bold"><i class="fas fa-arrow-up me-1"></i>Fazla</span>
                                }
                            </td>
                            <td class="fw-bold font-monospace">@k.Tutar.ToString("N2")₺</td>
                            <td>
                                <span class="badge @(k.Sinif == FarkSinifi.Beklenen ? "bg-info" : k.Sinif == FarkSinifi.Askida ? "bg-warning text-dark" : "bg-danger")" style="font-size: 10px;">
                                    @(k.Sinif == FarkSinifi.Beklenen ? "Olağan" : k.Sinif == FarkSinifi.Askida ? "Askıda" : "Olağan Dışı")
                                </span>
                            </td>
                            <td>
                                <span class="@takipClass" title="Takip başlangıç: @(k.TakipBaslangicTarihi?.ToString("dd.MM.yyyy") ?? "-")">
                                    @takipIcon @(takipGun > 0 ? $"{takipGun} gün" : "Bugün")
                                </span>
                            </td>
                            <td class="small">@(k.TespitEdilenTip ?? "-")</td>
                            <td class="small" style="max-width: 250px;">
                                @if (!string.IsNullOrEmpty(k.DosyaNo))
                                {
                                    <strong>@k.DosyaNo</strong>
                                }
                                @if (!string.IsNullOrEmpty(k.BirimAdi))
                                {
                                    <span class="text-muted"> — @k.BirimAdi</span>
                                }
                                @if (!string.IsNullOrEmpty(k.Aciklama))
                                {
                                    <div class="text-truncate" title="@k.Aciklama">@k.Aciklama</div>
                                }
                            </td>
                            <td>
                                <div class="btn-group btn-group-sm">
                                    <form method="post" asp-action="Resolve" class="d-inline">
                                        <input type="hidden" name="id" value="@k.Id" />
                                        <input type="hidden" name="not" value="" />
                                        <button type="submit" class="btn btn-outline-success btn-sm" title="Çözüldü olarak işaretle (Onaylandı — kullanıcı kapattı)">
                                            <i class="fas fa-check me-1"></i>Çözüldü
                                        </button>
                                    </form>
                                    <form method="post" asp-action="Revert" class="d-inline">
                                        <input type="hidden" name="id" value="@k.Id" />
                                        <input type="hidden" name="returnTab" value="takipte" />
                                        <button type="submit" class="btn btn-outline-warning btn-sm" title="Geri al"
                                                onclick="return confirm('Takibi bırakıp Açık Kayıtlara geri almak istiyor musunuz?');">
                                            <i class="fas fa-undo me-1"></i>Geri Al
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
            <div class="text-muted small mt-2">
                Toplam <strong>@takipteKayitlar.Count</strong> aktif takipte kayıt.
            </div>
        }

        @* ═══════ Bölüm 4: Gelişmiş Takip Sorgu Motoru ═══════ *@
        <hr class="my-4" />
        <div class="card mb-3" style="border-left: 5px solid #8e44ad;">
            <div class="card-body py-2">
                <h6 class="mb-2 fw-bold"><i class="fas fa-search me-1" style="color: #8e44ad;"></i>Gelişmiş Takip Sorgu Motoru</h6>
                <p class="small text-muted mb-2">
                    İki tarih arasında takibe alınmış tüm kayıtları sorgulayın. Durum filtresiyle sadece bekleyenleri, çözülenleri veya tümünü görebilirsiniz.
                </p>
                <div class="small mb-3 p-2 rounded" style="background: rgba(142,68,173,0.06);">
                    <i class="fas fa-info-circle me-1" style="color: #8e44ad;"></i>
                    <strong>Durum açıklaması:</strong>
                    <span class="badge" style="background: #8e44ad;">Takipte</span> Hâlâ bekleniyor ·
                    <span class="badge bg-success">Çözüldü</span> Sistem otomatik kapattı (CrossDay geldi) ·
                    <span class="badge bg-info">Onaylandı</span> Kullanıcı el ile kapattı
                </div>
                <form method="get" class="row g-2 align-items-end">
                    <input type="hidden" name="tab" value="takipte" />
                    <div class="col-auto">
                        <label class="form-label small mb-0">Başlangıç</label>
                        <input type="date" name="baslangic" class="form-control form-control-sm"
                               value="@filterBaslangic.ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="col-auto">
                        <label class="form-label small mb-0">Bitiş</label>
                        <input type="date" name="bitis" class="form-control form-control-sm"
                               value="@filterBitis.ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="col-auto">
                        <label class="form-label small mb-0">Durum</label>
                        <select name="takipDurum" class="form-select form-select-sm">
                            <option value="">Hepsi</option>
                            <option value="Takipte" selected="@(ViewContext.HttpContext.Request.Query["takipDurum"] == "Takipte")">Bekleyen</option>
                            <option value="Cozuldu" selected="@(ViewContext.HttpContext.Request.Query["takipDurum"] == "Cozuldu")">Çözülen (otomatik)</option>
                            <option value="Onaylandi" selected="@(ViewContext.HttpContext.Request.Query["takipDurum"] == "Onaylandi")">Onaylanan (el ile)</option>
                        </select>
                    </div>
                    <div class="col-auto">
                        <label class="form-label small mb-0">Hesap Türü</label>
                        <select name="hesapTuru" class="form-select form-select-sm">
                            <option value="">Tümü</option>
                            <option value="Tahsilat" selected="@(filterHesapTuru == BankaHesapTuru.Tahsilat)">Tahsilat</option>
                            <option value="Harc" selected="@(filterHesapTuru == BankaHesapTuru.Harc)">Harç</option>
                            <option value="Stopaj" selected="@(filterHesapTuru == BankaHesapTuru.Stopaj)">Stopaj</option>
                        </select>
                    </div>
                    <div class="col-auto">
                        <label class="form-label small mb-0">Arama</label>
                        <input type="text" name="arama" class="form-control form-control-sm" placeholder="Dosya, birim, açıklama..." value="@arama" />
                    </div>
                    <div class="col-auto">
                        <button type="submit" class="btn btn-sm" style="background: #8e44ad; color: white;"><i class="fas fa-search me-1"></i>Sorgula</button>
                    </div>
                </form>
            </div>
        </div>

        @* Takip geçmişi: Servis katmanından gelen özel takip yaşam döngüsü verisi *@
        @if (takipGecmisiModel.Count > 0)
        {
            var tgTakipte = takipGecmisiModel.Count(x => x.Durum == KayitDurumu.Takipte);
            var tgCozuldu = takipGecmisiModel.Count(x => x.Durum == KayitDurumu.Cozuldu);
            var tgOnaylandi = takipGecmisiModel.Count(x => x.Durum == KayitDurumu.Onaylandi);
            var tgEksik = takipGecmisiModel.Where(x => x.Yon == KayitYonu.Eksik).Sum(x => x.Tutar);
            var tgFazla = takipGecmisiModel.Where(x => x.Yon == KayitYonu.Fazla).Sum(x => x.Tutar);

            <div class="card mb-3" style="background: rgba(142,68,173,0.04); border: 1px solid rgba(142,68,173,0.15);">
                <div class="card-body py-3">
                    <div class="d-flex align-items-center mb-2">
                        <i class="fas fa-chart-pie me-2" style="color: #8e44ad;"></i>
                        <strong>@filterBaslangic.ToString("dd.MM.yyyy") — @filterBitis.ToString("dd.MM.yyyy") Arası Takip Özeti</strong>
                        <span class="badge ms-2" style="background: #8e44ad;">@takipGecmisiModel.Count kayıt</span>
                    </div>
                    <div class="d-flex flex-wrap gap-2 mb-2">
                        @if (tgTakipte > 0) { <span class="badge" style="background: #8e44ad; font-size: 12px; padding: 6px 12px;"><i class="fas fa-binoculars me-1"></i>Hâlâ Bekleyen: @tgTakipte</span> }
                        @if (tgCozuldu > 0) { <span class="badge" style="background: #27ae60; font-size: 12px; padding: 6px 12px;"><i class="fas fa-check-circle me-1"></i>Çözüldü (otomatik): @tgCozuldu</span> }
                        @if (tgOnaylandi > 0) { <span class="badge" style="background: #2980b9; font-size: 12px; padding: 6px 12px;"><i class="fas fa-user-check me-1"></i>Onaylandı (el ile): @tgOnaylandi</span> }
                    </div>
                    <div class="d-flex flex-wrap gap-3 small">
                        <span><i class="fas fa-arrow-down text-danger me-1"></i>Eksik: <strong>@tgEksik.ToString("N2") ₺</strong></span>
                        <span><i class="fas fa-arrow-up text-success me-1"></i>Fazla: <strong>@tgFazla.ToString("N2") ₺</strong></span>
                    </div>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table table-hover table-striped table-sm">
                    <thead style="background: #2c2c3e; color: white;">
                        <tr>
                            <th>Analiz Tarihi</th>
                            <th>Hesap</th>
                            <th>Yön</th>
                            <th>Tutar</th>
                            <th>Sınıf</th>
                            <th>Durum</th>
                            <th>Takip Bilgisi</th>
                            <th>Tip</th>
                            <th>Açıklama</th>
                            <th>Notlar</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var k in takipGecmisiModel)
                    {
                        var durumClass2 = k.Durum switch
                        {
                            KayitDurumu.Takipte => "bg-purple",
                            KayitDurumu.Cozuldu => "bg-success",
                            KayitDurumu.Onaylandi => "bg-info",
                            _ => "bg-secondary"
                        };
                        var durumLabel2 = k.Durum switch
                        {
                            KayitDurumu.Takipte => "📌 Bekleyen",
                            KayitDurumu.Cozuldu => "✅ Çözüldü (otomatik)",
                            KayitDurumu.Onaylandi => "✅ Onaylandı (el ile)",
                            _ => k.Durum.ToString()
                        };
                        var takipInfo = "";
                        if (k.TakipBaslangicTarihi.HasValue)
                        {
                            var tGun = k.TakipteGunSayisi;
                            if (tGun.HasValue && tGun > 0) { takipInfo = $"{tGun} gün"; }
                            else if (k.Durum == KayitDurumu.Cozuldu) { takipInfo = "Çözüldü (sistem)"; }
                            else if (k.Durum == KayitDurumu.Onaylandi) { takipInfo = "Çözüldü (el ile)"; }
                            else { takipInfo = "Bugün"; }
                        }
                        <tr class="@(k.Durum == KayitDurumu.Takipte ? "table-warning" : "")">
                            <td>@k.AnalizTarihi.ToString("dd.MM.yyyy")</td>
                            <td>
                                <span class="badge @(k.HesapTuru == BankaHesapTuru.Tahsilat ? "bg-success" : k.HesapTuru == BankaHesapTuru.Harc ? "bg-primary" : "bg-warning text-dark")">
                                    @k.HesapTuru
                                </span>
                            </td>
                            <td>
                                @if (k.Yon == KayitYonu.Eksik)
                                { <span class="text-danger"><i class="fas fa-arrow-down"></i></span> }
                                else
                                { <span class="text-success"><i class="fas fa-arrow-up"></i></span> }
                            </td>
                            <td class="font-monospace fw-bold">@k.Tutar.ToString("N2")₺</td>
                            <td>
                                <span class="badge @(k.Sinif == FarkSinifi.Beklenen ? "bg-info" : k.Sinif == FarkSinifi.Askida ? "bg-warning text-dark" : "bg-danger")" style="font-size: 10px;">
                                    @(k.Sinif == FarkSinifi.Beklenen ? "Olağan" : k.Sinif == FarkSinifi.Askida ? "Askıda" : "Olağan Dışı")
                                </span>
                            </td>
                            <td><span class="badge @durumClass2">@durumLabel2</span></td>
                            <td class="small">
                                @if (!string.IsNullOrEmpty(takipInfo))
                                { <span title="Takip başlangıç: @(k.TakipBaslangicTarihi?.ToString("dd.MM.yyyy") ?? "-")">@takipInfo</span> }
                                else
                                { <span class="text-muted">-</span> }
                            </td>
                            <td class="small">@(k.TespitEdilenTip ?? "-")</td>
                            <td class="small text-truncate" style="max-width: 180px;" title="@k.Aciklama">
                                @(k.Aciklama ?? k.DosyaNo ?? "-")
                            </td>
                            <td class="small text-truncate" style="max-width: 150px;" title="@k.Notlar">
                                @(k.Notlar ?? "-")
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
            <div class="text-muted small mt-2">
                Toplam <strong>@takipGecmisiModel.Count</strong> takip kaydı — <strong>@filterBaslangic.ToString("dd.MM.yyyy")</strong> ile <strong>@filterBitis.ToString("dd.MM.yyyy")</strong> arası.
            </div>
        }
        else
        {
            <div class="text-center py-3 text-muted">
                <i class="fas fa-search fa-2x mb-2"></i>
                <p class="small">Seçili tarih aralığında takip kaydı bulunamadı. Tarih aralığını genişletin veya durum filtresini değiştirin.</p>
            </div>
        }
    }

    <!-- ═══════ TAB: Geçmiş ═══════ -->
    @if (activeTab == "gecmis")
    {
        <!-- Filtre Paneli -->
        <div class="card mb-3" style="border-left: 5px solid #3498db;">
            <div class="card-body py-2">
                <h6 class="mb-2 fw-bold"><i class="fas fa-search me-1 text-primary"></i>Gelişmiş Sorgu Motoru</h6>
                <form method="get" class="row g-2 align-items-end">
                    <input type="hidden" name="tab" value="gecmis" />
                    <div class="col-auto">
                        <label class="form-label small mb-0">Başlangıç</label>
                        <input type="date" name="baslangic" class="form-control form-control-sm"
                               value="@filterBaslangic.ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="col-auto">
                        <label class="form-label small mb-0">Bitiş</label>
                        <input type="date" name="bitis" class="form-control form-control-sm"
                               value="@filterBitis.ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="col-auto">
                        <label class="form-label small mb-0">Hesap Türü</label>
                        <select name="hesapTuru" class="form-select form-select-sm">
                            <option value="">Tümü</option>
                            <option value="Tahsilat" selected="@(filterHesapTuru == BankaHesapTuru.Tahsilat)">Tahsilat</option>
                            <option value="Harc" selected="@(filterHesapTuru == BankaHesapTuru.Harc)">Harç</option>
                            <option value="Stopaj" selected="@(filterHesapTuru == BankaHesapTuru.Stopaj)">Stopaj</option>
                        </select>
                    </div>
                    <div class="col-auto">
                        <label class="form-label small mb-0">Durum</label>
                        <select name="durum" class="form-select form-select-sm">
                            <option value="">Tümü</option>
                            <option value="Acik" selected="@(filterDurum == KayitDurumu.Acik)">Açık</option>
                            <option value="Takipte" selected="@(filterDurum == KayitDurumu.Takipte)">Takipte</option>
                            <option value="Cozuldu" selected="@(filterDurum == KayitDurumu.Cozuldu)">Çözüldü</option>
                            <option value="Onaylandi" selected="@(filterDurum == KayitDurumu.Onaylandi)">Onaylandı</option>
                            <option value="Iptal" selected="@(filterDurum == KayitDurumu.Iptal)">İptal</option>
                        </select>
                    </div>
                    <div class="col-auto">
                        <label class="form-label small mb-0">Arama</label>
                        <input type="text" name="arama" class="form-control form-control-sm" placeholder="Dosya, birim, açıklama..." value="@arama" />
                    </div>
                    <div class="col-auto">
                        <button type="submit" class="btn btn-primary btn-sm"><i class="fas fa-search me-1"></i>Sorgula</button>
                    </div>
                    <div class="col-auto">
                        <a asp-action="ExportPdf"
                           asp-route-baslangic="@filterBaslangic.ToString("yyyy-MM-dd")"
                           asp-route-bitis="@filterBitis.ToString("yyyy-MM-dd")"
                           asp-route-hesapTuru="@filterHesapTuru"
                           asp-route-durum="@filterDurum"
                           class="btn btn-outline-danger btn-sm">
                            <i class="fas fa-file-pdf me-1"></i>PDF
                        </a>
                    </div>
                    <div class="col-auto">
                        <a asp-action="ExportCsv"
                           asp-route-baslangic="@filterBaslangic.ToString("yyyy-MM-dd")"
                           asp-route-bitis="@filterBitis.ToString("yyyy-MM-dd")"
                           asp-route-hesapTuru="@filterHesapTuru"
                           asp-route-durum="@filterDurum"
                           class="btn btn-outline-secondary btn-sm">
                            <i class="fas fa-file-csv me-1"></i>CSV
                        </a>
                    </div>
                </form>
            </div>
        </div>

        @if (gecmisKayitlar.Count == 0)
        {
            <div class="text-center py-5 text-muted">
                <i class="fas fa-inbox fa-3x mb-3"></i>
                <h5>Kayıt bulunamadı</h5>
                <p>Seçili tarih aralığında hesap kontrol kaydı yok. Tarih aralığını genişletin veya filtreleri kaldırın.</p>
            </div>
        }
        else
        {
            @* ═══════ Durum Özeti Mini-Kartları ═══════ *@
            var gAcik = gecmisKayitlar.Count(x => x.Durum == KayitDurumu.Acik);
                var gTakipte = gecmisKayitlar.Count(x => x.Durum == KayitDurumu.Takipte);
                var gCozuldu = gecmisKayitlar.Count(x => x.Durum == KayitDurumu.Cozuldu);
                var gOnaylandi = gecmisKayitlar.Count(x => x.Durum == KayitDurumu.Onaylandi);
                var gIptal = gecmisKayitlar.Count(x => x.Durum == KayitDurumu.Iptal);
                var gBeklenen = gecmisKayitlar.Count(x => x.Sinif == FarkSinifi.Beklenen);
                var gBilinmeyen = gecmisKayitlar.Count(x => x.Sinif == FarkSinifi.Bilinmeyen);
                var gEksikTutar = gecmisKayitlar.Where(x => x.Yon == KayitYonu.Eksik).Sum(x => x.Tutar);
                var gFazlaTutar = gecmisKayitlar.Where(x => x.Yon == KayitYonu.Fazla).Sum(x => x.Tutar);

            <div class="card mb-3" style="background: rgba(52,152,219,0.04); border: 1px solid rgba(52,152,219,0.15);">
                <div class="card-body py-3">
                    <div class="d-flex align-items-center mb-2">
                        <i class="fas fa-chart-pie me-2 text-primary"></i>
                        <strong>@filterBaslangic.ToString("dd.MM.yyyy") — @filterBitis.ToString("dd.MM.yyyy") Arası Dönem Özeti</strong>
                        <span class="badge bg-primary ms-2">@gecmisKayitlar.Count kayıt</span>
                    </div>
                    <div class="d-flex flex-wrap gap-2 mb-2">
                        @if (gAcik > 0) { <span class="badge" style="background: #e74c3c; font-size: 12px; padding: 6px 12px;"><i class="fas fa-exclamation-circle me-1"></i>Açık: @gAcik</span> }
                        @if (gTakipte > 0) { <span class="badge" style="background: #8e44ad; font-size: 12px; padding: 6px 12px;"><i class="fas fa-binoculars me-1"></i>Takipte: @gTakipte</span> }
                        @if (gCozuldu > 0) { <span class="badge" style="background: #27ae60; font-size: 12px; padding: 6px 12px;"><i class="fas fa-check-circle me-1"></i>Çözüldü: @gCozuldu</span> }
                        @if (gOnaylandi > 0) { <span class="badge" style="background: #2980b9; font-size: 12px; padding: 6px 12px;"><i class="fas fa-user-check me-1"></i>Onaylandı: @gOnaylandi</span> }
                        @if (gIptal > 0) { <span class="badge" style="background: #95a5a6; font-size: 12px; padding: 6px 12px;"><i class="fas fa-ban me-1"></i>İptal: @gIptal</span> }
                    </div>
                    <div class="d-flex flex-wrap gap-3 small">
                        <span><i class="fas fa-arrow-down text-danger me-1"></i>Eksik: <strong>@gEksikTutar.ToString("N2") ₺</strong></span>
                        <span><i class="fas fa-arrow-up text-success me-1"></i>Fazla: <strong>@gFazlaTutar.ToString("N2") ₺</strong></span>
                        <span class="text-muted">|</span>
                        <span><i class="fas fa-clock text-info me-1"></i>Olağan: <strong>@gBeklenen</strong></span>
                        <span><i class="fas fa-question-circle text-warning me-1"></i>Olağan Dışı: <strong>@gBilinmeyen</strong></span>
                    </div>
                </div>
            </div>

            @* ═══════ Sonuç Tablosu ═══════ *@
            <div class="table-responsive">
                <table class="table table-hover table-striped table-sm">
                    <thead class="table-dark">
                        <tr>
                            <th>Tarih</th>
                            <th>Hesap</th>
                            <th>Yön</th>
                            <th>Tutar</th>
                            <th>Sınıf</th>
                            <th>Durum</th>
                            <th>Takip</th>
                            <th>Tip</th>
                            <th>Açıklama</th>
                            <th>Notlar</th>
                            <th>İşlem</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var k in gecmisKayitlar)
                    {
                        var durumClass = k.Durum switch
                        {
                            KayitDurumu.Acik => "bg-danger",
                            KayitDurumu.Takipte => "bg-purple",
                            KayitDurumu.Cozuldu => "bg-success",
                            KayitDurumu.Onaylandi => "bg-info",
                            KayitDurumu.Iptal => "bg-secondary",
                            _ => "bg-light text-dark"
                        };
                        var durumLabel = k.Durum switch
                        {
                            KayitDurumu.Acik => "Açık",
                            KayitDurumu.Takipte => "Takipte",
                            KayitDurumu.Cozuldu => "Çözüldü",
                            KayitDurumu.Onaylandi => "Onaylandı",
                            KayitDurumu.Iptal => "İptal",
                            _ => k.Durum.ToString()
                        };
                        var sinifLabel = k.Sinif switch
                        {
                            FarkSinifi.Beklenen => "Olağan",
                            FarkSinifi.Askida => "Askıda",
                            FarkSinifi.Bilinmeyen => "Olağan Dışı",
                            _ => k.Sinif.ToString()
                        };
                        var sinifClass = k.Sinif switch
                        {
                            FarkSinifi.Beklenen => "bg-info",
                            FarkSinifi.Askida => "bg-warning text-dark",
                            FarkSinifi.Bilinmeyen => "bg-danger",
                            _ => "bg-secondary"
                        };
                        // Takip bilgisi
                        var takipBilgi = "";
                        if (k.TakipBaslangicTarihi.HasValue)
                        {
                            var takipGun = k.TakipteGunSayisi;
                            if (takipGun.HasValue && takipGun > 0)
                            {
                                takipBilgi = $"{takipGun} gün";
                            }
                            else if (k.Durum == KayitDurumu.Cozuldu || k.Durum == KayitDurumu.Onaylandi)
                            {
                                takipBilgi = "✅ Çözüldü";
                            }
                            else
                            {
                                takipBilgi = "📌 Takipte";
                            }
                        }
                        <tr>
                            <td>@k.AnalizTarihi.ToString("dd.MM.yyyy")</td>
                            <td>
                                <span class="badge @(k.HesapTuru == BankaHesapTuru.Tahsilat ? "bg-success" : k.HesapTuru == BankaHesapTuru.Harc ? "bg-primary" : "bg-warning text-dark")">
                                    @k.HesapTuru
                                </span>
                            </td>
                            <td>
                                @if (k.Yon == KayitYonu.Eksik)
                                {
                                    <span class="text-danger"><i class="fas fa-arrow-down"></i></span>
                                }
                                else
                                {
                                    <span class="text-success"><i class="fas fa-arrow-up"></i></span>
                                }
                            </td>
                            <td class="font-monospace fw-bold">@k.Tutar.ToString("N2")₺</td>
                            <td><span class="badge @sinifClass" style="font-size: 10px;">@sinifLabel</span></td>
                            <td><span class="badge @durumClass">@durumLabel</span></td>
                            <td class="small">
                                @if (!string.IsNullOrEmpty(takipBilgi))
                                {
                                    <span title="Takip başlangıç: @(k.TakipBaslangicTarihi?.ToString("dd.MM.yyyy") ?? "-")">@takipBilgi</span>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td class="small">@(k.TespitEdilenTip ?? "-")</td>
                            <td class="small text-truncate" style="max-width: 200px;" title="@k.Aciklama">
                                @(k.Aciklama ?? k.DosyaNo ?? "-")
                            </td>
                            <td class="small text-truncate" style="max-width: 150px;" title="@k.Notlar">
                                @(k.Notlar ?? "-")
                            </td>
                            <td class="text-nowrap">
                                @if (k.Durum == KayitDurumu.Acik)
                                {
                                    @* Açık kayıtlar: Takibe Al, Yok Say, Çözüldü *@
                                    <div class="btn-group btn-group-sm">
                                        <form method="post" asp-action="Confirm" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@k.Id" />
                                            <button type="submit" class="btn btn-outline-success btn-sm" title="Onayla">
                                                <i class="fas fa-check"></i>
                                            </button>
                                        </form>
                                        <form method="post" asp-action="StartTracking" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@k.Id" />
                                            <button type="submit" class="btn btn-outline-info btn-sm" title="Takibe Al">
                                                <i class="fas fa-thumbtack"></i>
                                            </button>
                                        </form>
                                        <form method="post" asp-action="Cancel" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@k.Id" />
                                            <input type="hidden" name="sebep" value="Geçmiş kayıtlardan yok sayıldı" />
                                            <button type="submit" class="btn btn-outline-secondary btn-sm" title="Yok Say"
                                                    onclick="return confirm('Bu kaydı yok saymak istiyor musunuz?');">
                                                <i class="fas fa-times"></i>
                                            </button>
                                        </form>
                                    </div>
                                }
                                else if (k.Durum == KayitDurumu.Takipte)
                                {
                                    @* Takipte kayıtlar: Çözüldü, Geri Al *@
                                    <div class="btn-group btn-group-sm">
                                        <form method="post" asp-action="Resolve" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@k.Id" />
                                            <button type="submit" class="btn btn-outline-success btn-sm" title="Çözüldü">
                                                <i class="fas fa-check"></i>
                                            </button>
                                        </form>
                                        <form method="post" asp-action="Revert" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@k.Id" />
                                            <input type="hidden" name="returnTab" value="gecmis" />
                                            <button type="submit" class="btn btn-outline-warning btn-sm" title="Geri Al"
                                                    onclick="return confirm('Takibi bırakıp Açık Kayıtlara geri almak istiyor musunuz?');">
                                                <i class="fas fa-undo"></i>
                                            </button>
                                        </form>
                                    </div>
                                }
                                else if (k.Durum != KayitDurumu.Acik)
                                {
                                    @* Çözüldü/Onaylandı/İptal kayıtlar: Geri Al *@
                                    <form method="post" asp-action="Revert" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@k.Id" />
                                        <input type="hidden" name="returnTab" value="gecmis" />
                                        <button type="submit" class="btn btn-outline-warning btn-sm" title="Geri Al"
                                                onclick="return confirm('İşlemi geri almak istiyor musunuz?');">
                                            <i class="fas fa-undo"></i>
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
            <div class="text-muted small mt-2">
                Toplam <strong>@gecmisKayitlar.Count</strong> kayıt — <strong>@filterBaslangic.ToString("dd.MM.yyyy")</strong> ile <strong>@filterBitis.ToString("dd.MM.yyyy")</strong> arası.
            </div>
        }
    }
</div>
