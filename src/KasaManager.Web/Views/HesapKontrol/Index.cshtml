                                <td>@k.AnalizTarihi.ToString("dd.MM.yyyy")</td>
                                <td>
                                    <span class="badge @(k.HesapTuru == BankaHesapTuru.Tahsilat ? "bg-success" : k.HesapTuru == BankaHesapTuru.Harc ? "bg-primary" : "bg-warning text-dark")">
                                        @k.HesapTuru
