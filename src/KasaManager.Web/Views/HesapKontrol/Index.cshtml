                                    <td>@c.AnalizTarihi.ToString("dd.MM.yyyy")</td>
                                    <td>
                                        <span class="badge @(c.HesapTuru == BankaHesapTuru.Tahsilat ? "bg-success" : c.HesapTuru == BankaHesapTuru.Harc ? "bg-primary" : "bg-warning text-dark")">
                                            @c.HesapTuru
                                        </span>
                                    </td>
                                    <td class="fw-bold font-monospace">@c.Tutar.ToString("N2")₺</td>
                                    <td class="small">@(c.TespitEdilenTip ?? "-")</td>
                                    <td><span class="text-success">✅ @(takipSure > 0 ? $"{takipSure} gün sonra geldi" : "Aynı gün geldi")</span></td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }

        @* ═══════ Bölüm 2: Kümülatif Takip Toplam Kartı ═══════ *@
        @if (takipOzeti != null && takipOzeti.AktifTakipSayisi > 0)
        {
            <div class="card mb-3" style="border: 2px solid #8e44ad; background: linear-gradient(135deg, rgba(142,68,173,0.08) 0%, rgba(142,68,173,0.02) 100%);">
                <div class="card-body py-3">
                    <div class="row align-items-center">
                        <div class="col-md-4">
                            <div class="text-center">
                                <div style="font-size: 14px; color: #8e44ad; text-transform: uppercase; letter-spacing: 1px; font-weight: 600;">Toplam Takip Açığı</div>
                                <div style="font-size: 32px; font-weight: 800; color: #e74c3c; font-family: 'JetBrains Mono', monospace;">
                                    @takipOzeti.ToplamEksik.ToString("N2") ₺
                                </div>
                                <div class="small text-muted">
                                    @takipOzeti.AktifTakipSayisi kayıt · Ort. @takipOzeti.OrtalamaGun.ToString("N1") gün
                                </div>
                                @if (takipOzeti.ToplamFazla > 0)
                                {
                                    <div class="small mt-1">
                                        <span class="text-success">
                                            <i class="fas fa-arrow-up me-1"></i>Fazla Toplam: <strong>@takipOzeti.ToplamFazla.ToString("N2") ₺</strong>
                                        </span>
                                    </div>
                                }
                            </div>
                        </div>
                        <div class="col-md-8">
                            <div class="small fw-bold mb-2" style="color: #8e44ad;">
                                <i class="fas fa-layer-group me-1"></i>Gün Bazlı Kırılım
                            </div>
                            <div class="d-flex flex-wrap gap-2">
                                @foreach (var g in takipOzeti.GunBazliKirilim)
                                {
                                    var bgColor = g.Seviye switch
                                    {
                                        "kritik" => "background: #e74c3c; color: white;",
                                        "uyari" => "background: #f39c12; color: white;",
                                        _ => "background: rgba(142,68,173,0.15); color: #8e44ad;"
                                    };
                                    var icon = g.Seviye switch
                                    {
                                        "kritik" => "🔴",
                                        "uyari" => "⚠️",
                                        _ => "📌"
                                    };
                                    <div style="padding: 8px 14px; border-radius: 10px; @bgColor font-size: 13px;">
                                        <strong>@icon @(g.GunSayisi == 0 ? "Bugün" : $"{g.GunSayisi} gün")</strong>
                                        <span class="ms-1">@g.KayitSayisi kayıt</span>
                                        <span class="ms-1" style="font-family: 'JetBrains Mono', monospace; font-weight: 700;">@g.ToplamTutar.ToString("N2")₺</span>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }

        @* ═══════ Bölüm 2.5: Kısmi Eşleşme Onay Paneli ═══════ *@
        @if (Model.PotansiyelEslesmeler.Count > 0)
        {
            <div class="card mb-3" style="border-left: 5px solid #f39c12; background: linear-gradient(135deg, rgba(243,156,18,0.08) 0%, rgba(243,156,18,0.02) 100%);">
                <div class="card-body py-3">
                    <div class="d-flex align-items-center mb-2">
                        <span style="font-size: 24px; margin-right: 8px;">⚠️</span>
                        <h6 class="mb-0 fw-bold" style="color: #f39c12;">
                            Kısmi Eşleşmeler — Onayınızı Bekliyor
                            <span class="badge" style="background: #f39c12;">@Model.PotansiyelEslesmeler.Count kayıt</span>
                        </h6>
                    </div>
                    <p class="small text-muted mb-3">
                        Aşağıdaki kayıtlarda <strong>tutar eşleşiyor</strong> ancak <strong>DosyaNo doğrulanamadı</strong>.
                        Tesadüfi eşleşme riski olduğu için otomatik çözülmedi. Lütfen kontrol edin:
                    </p>
                    @foreach (var pot in Model.PotansiyelEslesmeler)
                    {
                        <div class="card mb-2" style="border: 1px solid rgba(243,156,18,0.3); background: rgba(243,156,18,0.04);">
                            <div class="card-body py-2 px-3">
                                <div class="row align-items-center">
                                    <div class="col-md-8">
                                        <div class="d-flex flex-wrap align-items-center gap-2 mb-1">
                                            <span class="badge @(pot.HesapTuru == BankaHesapTuru.Tahsilat ? "bg-success" : pot.HesapTuru == BankaHesapTuru.Harc ? "bg-primary" : "bg-warning text-dark")">
                                                @pot.HesapTuru
                                            </span>
                                            <span class="fw-bold font-monospace" style="font-size: 16px; color: #e74c3c;">@pot.Tutar.ToString("N2") ₺</span>
                                            <span class="text-muted small">Tarih: @pot.EksikTarihi.ToString("dd.MM.yyyy") → @pot.FazlaTarihi.ToString("dd.MM.yyyy")</span>
                                        </div>
                                        <div class="small">
                                            @if (!string.IsNullOrEmpty(pot.EksikDosyaNo))
                                            {
                                                <strong class="text-primary">📋 Eksik DosyaNo:</strong> <span>@pot.EksikDosyaNo</span>
                                                @if (!string.IsNullOrEmpty(pot.EksikBirimAdi))
                                                {
                                                    <span class="text-muted">— @pot.EksikBirimAdi</span>
                                                }
                                            }
                                            else
                                            {
                                                <span class="text-muted"><i class="fas fa-info-circle me-1"></i>DosyaNo bilgisi mevcut değil</span>
                                            }
                                        </div>
                                        @if (!string.IsNullOrEmpty(pot.FazlaAciklama))
                                        {
                                            <div class="small text-truncate mt-1" style="max-width: 500px;" title="@pot.FazlaAciklama">
                                                <strong class="text-success">🏦 Fazla Açıklama:</strong> @pot.FazlaAciklama
                                            </div>
                                        }
                                    </div>
                                    <div class="col-md-4 text-end">
                                        <div class="btn-group btn-group-sm">
                                            <form method="post" asp-action="ApprovePotentialMatch" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="eksikId" value="@pot.EksikKayitId" />
                                                <input type="hidden" name="fazlaId" value="@pot.FazlaKayitId" />
                                                <button type="submit" class="btn btn-success btn-sm"
                                                        onclick="return confirm('Bu eşleşmeyi onaylıyor musunuz? Kayıtlar Çözüldü olarak işaretlenecek.');">
