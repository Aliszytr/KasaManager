                                                <input type="hidden" name="fazlaId" value="@pot.FazlaKayitId" />
                                                <button type="submit" class="btn btn-outline-danger btn-sm"
                                                        onclick="return confirm('Bu eşleşmeyi reddetmek istediğinize emin misiniz?');">
                                                    <i class="fas fa-times me-1"></i>Reddet
                                                </button>
