@using KasaManager.Application.Abstractions
@using KasaManager.Domain.Reports.HesapKontrol
@model KasaManager.Web.Models.HesapKontrolViewModel
@{
    ViewData["Title"] = "Hesap Kontrol";

    var dashboard = Model.Dashboard;
    var acikKayitlar = Model.AcikKayitlar;
    var takipteKayitlar = Model.TakipteKayitlar;
    var gecmisKayitlar = Model.GecmisKayitlar;
    var takipGecmisiModel = Model.TakipGecmisi;
    var activeTab = Model.ActiveTab;
    var filterHesapTuru = Model.FilterHesapTuru;
    var filterDurum = Model.FilterDurum;
    var filterBaslangic = Model.FilterBaslangic;
    var filterBitis = Model.FilterBitis;
    var arama = Model.Arama;
    var takipOzeti = Model.TakipOzeti;

    // P4.3: Snapshot UI baglantisi ve LastSnapshotDate sokuldu.
    // Tarihsel inceleme (Bugünden farklı bir gün ise) kontrolü eklendi.
    bool isHistoricalTabs = Model.AnalizTarihi < DateOnly.FromDateTime(DateTime.Now);
    string tarihStrTabs = Model.AnalizTarihi.ToString("yyyy-MM-dd");
}


<div class="container-fluid">

    <!-- Header -->
    <div class="row mb-4">
        <div class="col-12 d-flex align-items-start justify-content-between flex-wrap gap-3">
            <div>
                <h2 class="text-primary">
                    <i class="fas fa-university me-2"></i>
                    Banka Hesap Kontrol
                </h2>
                <p class="text-muted mb-0">
                    Banka karşılaştırma raporlarından tespit edilen eksik/fazla kayıtların yönetimi ve takibi.
                </p>
            </div>

            <!-- ═══════ Tarih Seçici (Geriye Dönük Analiz) ═══════ -->
            <div class="d-flex align-items-center gap-2 p-2 rounded-3"
                 style="background: var(--kasa-surface); border: 1px solid var(--kasa-border);">
                <i class="fas fa-calendar-alt text-kasa-primary"></i>
                <label class="small fw-semibold text-muted mb-0">Analiz Tarihi:</label>
                <input type="date" id="analizTarihiSelect" class="form-control form-control-sm"
                       style="width: auto; min-width: 140px; font-weight: 600;"
                       value="@Model.AnalizTarihi.ToString("yyyy-MM-dd")"
                       onchange="window.location.href='@Url.Action("Index", "HesapKontrol")?analizTarihiStr=' + this.value" />
                @if (isHistoricalTabs)
                {
                    <span class="badge bg-warning text-dark ms-1">
                        <i class="fas fa-history me-1"></i>Geriye Dönük
                    </span>
                }
            </div>
        </div>
    </div>

    <!-- ═══════ UX Context Banner (Kasa Raporu Entry Point) ═══════ -->
    @if (ViewData["QueryDate"] != null)
    {
        <div class="alert alert-info border-0 shadow-sm mb-4" style="background: rgba(14, 165, 233, 0.08); border-left: 5px solid #0ea5e9 !important;">
            <div class="d-flex align-items-center">
                <i class="fas fa-info-circle fa-2x me-3" style="color: #0ea5e9;"></i>
                <div>
                    <h6 class="mb-1" style="color: #0369a1; font-weight: 700;">Tarihsel Bağlam (Historical Context) Aktif</h6>
                    <div class="small">
                        Şu anda <strong>@(((DateOnly)ViewData["QueryDate"]!).ToString("dd.MM.yyyy"))</strong> tarihli banka hesap kontrol raporunu görüntülüyorsunuz. Yapacağınız işlemler ve sekme geçişleri bu tarihe sadık kalacaktır.
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- ═══════ CrossDay Bildirim Banner'ı ═══════ -->
    @if (TempData["CrossDay"] is string crossDayMsg)
    {
        <div class="alert alert-success border-0 shadow-sm mb-4" style="background: linear-gradient(135deg, #d4edda 0%, #c3f0c8 100%); border-left: 5px solid #28a745 !important;">
            <div class="d-flex align-items-center">
                <div style="font-size: 28px; margin-right: 12px;">🎉</div>
                <div>
                    <strong>Takip Motoru Bildirimi</strong>
                    <div class="small mt-1">@crossDayMsg</div>
                </div>
            </div>
        </div>
    }

    <!-- ═══════ Dashboard Kartları ═══════ -->
    @if (dashboard != null)
    {
        <div class="row g-3 mb-4">
            <!-- Açık Kayıt -->
            <div class="col-md-4 col-lg-2">
                <div class="card text-center h-100" style="border-left: 4px solid #e74c3c;">
                    <div class="card-body py-3">
                        <div class="text-muted small mb-1"><i class="fas fa-exclamation-circle me-1"></i>Açık Kayıt</div>
                        <h3 class="mb-0 fw-bold" style="color: #e74c3c;">@dashboard.AcikKayitSayisi</h3>
                    </div>
                </div>
            </div>
            <!-- Beklenen -->
            <div class="col-md-4 col-lg-2">
                <div class="card text-center h-100" style="border-left: 4px solid #f39c12;">
                    <div class="card-body py-3">
                        <div class="text-muted small mb-1"><i class="fas fa-clock me-1"></i>Beklenen</div>
                        <h3 class="mb-0 fw-bold" style="color: #f39c12;">@dashboard.BeklenenSayisi</h3>
                    </div>
                </div>
            </div>
            <!-- Bilinmeyen -->
            <div class="col-md-4 col-lg-2">
                <div class="card text-center h-100" style="border-left: 4px solid #9b59b6;">
                    <div class="card-body py-3">
                        <div class="text-muted small mb-1"><i class="fas fa-question-circle me-1"></i>Bilinmeyen</div>
                        <h3 class="mb-0 fw-bold" style="color: #9b59b6;">@dashboard.BilinmeyenSayisi</h3>
                    </div>
                </div>
            </div>
            <!-- Eksik Toplam -->
            <div class="col-md-4 col-lg-2">
                <div class="card text-center h-100" style="border-left: 4px solid #e67e22;">
                    <div class="card-body py-3">
                        <div class="text-muted small mb-1"><i class="fas fa-arrow-down me-1"></i>Eksik Toplam</div>
                        <h4 class="mb-0 fw-bold" style="color: #e67e22;">@dashboard.AcikEksikToplam.ToString("N2")₺</h4>
                    </div>
                </div>
            </div>
            <!-- Fazla Toplam -->
            <div class="col-md-4 col-lg-2">
                <div class="card text-center h-100" style="border-left: 4px solid #27ae60;">
                    <div class="card-body py-3">
                        <div class="text-muted small mb-1"><i class="fas fa-arrow-up me-1"></i>Fazla Toplam</div>
                        <h4 class="mb-0 fw-bold" style="color: #27ae60;">@dashboard.AcikFazlaToplam.ToString("N2")₺</h4>
                    </div>
                </div>
            </div>
            <!-- Bugün Çözülen -->
            <div class="col-md-4 col-lg-2">
                <div class="card text-center h-100" style="border-left: 4px solid #2ecc71;">
                    <div class="card-body py-3">
                        <div class="text-muted small mb-1"><i class="fas fa-check-circle me-1"></i>Bugün Çözülen</div>
                        <h3 class="mb-0 fw-bold" style="color: #2ecc71;">@dashboard.BugunCozulenSayisi</h3>
                    </div>
                </div>
            </div>
        </div>

        @* ═══════ Takipte Özet Kartı ═══════ *@
        @if (dashboard.TakipteSayisi > 0)
        {
            <div class="row mb-4">
                <div class="col-12">
                    <div class="card" style="border-left: 5px solid #8e44ad; background: rgba(142,68,173,0.06);">
                        <div class="card-body py-3">
                            <div class="d-flex align-items-center justify-content-between">
                                <div>
                                    <h6 class="mb-1 fw-bold">
                                        <i class="fas fa-binoculars me-1" style="color: #8e44ad;"></i>
                                        📌 Takipteki Kayıtlar
                                        <span class="badge bg-secondary ms-1">@dashboard.TakipteSayisi</span>
                                    </h6>
                                    <div class="d-flex flex-wrap gap-3 mt-2">
                                        @if (dashboard.TakipteEksikToplam > 0)
                                        {
                                            <span class="text-danger">
                                                <i class="fas fa-arrow-down me-1"></i>Eksik: <strong>@dashboard.TakipteEksikToplam.ToString("N2")₺</strong>
                                            </span>
                                        }
                                        @if (dashboard.TakipteFazlaToplam > 0)
                                        {
                                            <span class="text-success">
                                                <i class="fas fa-arrow-up me-1"></i>Fazla: <strong>@dashboard.TakipteFazlaToplam.ToString("N2")₺</strong>
                                            </span>
                                        }
                                    </div>
                                </div>
                                <a asp-action="Index" asp-route-tab="takipte" asp-route-analizTarihiStr="@tarihStrTabs" class="btn btn-outline-secondary btn-sm">
                                    <i class="fas fa-external-link-alt me-1"></i>Detay
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }

        @* ═══════ Stopaj/Virman Durumu (Commit 4: 4 durumlu renk mapping) ═══════ *@
        @if (dashboard.LastStopajDurum != null)
        {
            var s = dashboard.LastStopajDurum;
            var cardBorder = s.Status switch
            {
                KasaManager.Domain.Reports.HesapKontrol.StopajStatus.Ok => "#2ecc71",
                KasaManager.Domain.Reports.HesapKontrol.StopajStatus.OkWithNote => "#3498db",
                KasaManager.Domain.Reports.HesapKontrol.StopajStatus.WarningPending => "#f39c12",
                KasaManager.Domain.Reports.HesapKontrol.StopajStatus.Error => "#e74c3c",
                _ => "#7f8c8d"
            };
            var cardBg = s.Status switch
            {
                KasaManager.Domain.Reports.HesapKontrol.StopajStatus.Ok => "rgba(46,204,113,0.08)",
                KasaManager.Domain.Reports.HesapKontrol.StopajStatus.OkWithNote => "rgba(52,152,219,0.08)",
                KasaManager.Domain.Reports.HesapKontrol.StopajStatus.WarningPending => "rgba(243,156,18,0.08)",
                KasaManager.Domain.Reports.HesapKontrol.StopajStatus.Error => "rgba(231,76,60,0.08)",
                _ => "rgba(127,140,141,0.08)"
            };
            var icon = s.Status switch
            {
                KasaManager.Domain.Reports.HesapKontrol.StopajStatus.Ok => "fa-check-circle text-success",
                KasaManager.Domain.Reports.HesapKontrol.StopajStatus.OkWithNote => "fa-info-circle text-info",
                KasaManager.Domain.Reports.HesapKontrol.StopajStatus.WarningPending => "fa-exclamation-triangle text-warning",
                KasaManager.Domain.Reports.HesapKontrol.StopajStatus.Error => "fa-times-circle text-danger",
                _ => "fa-question-circle text-secondary"
            };
            var textClass = s.Status switch
            {
                KasaManager.Domain.Reports.HesapKontrol.StopajStatus.Ok => "text-success",
                KasaManager.Domain.Reports.HesapKontrol.StopajStatus.OkWithNote => "text-info",
                KasaManager.Domain.Reports.HesapKontrol.StopajStatus.WarningPending => "text-warning",
                KasaManager.Domain.Reports.HesapKontrol.StopajStatus.Error => "text-danger",
                _ => "text-secondary"
            };
            <div class="row mb-4">
                <div class="col-12">
                    <div class="card" style="border-left: 5px solid @cardBorder; background: @cardBg;">
                        <div class="card-body py-3 d-flex align-items-center gap-3">
                            <i class="fas @icon fa-2x"></i>
                            <div>
                                <h6 class="mb-1 fw-bold">
                                    <i class="fas fa-exchange-alt me-1"></i>Stopaj Virman Durumu
                                </h6>
                                <span class="@textClass">
                                    @s.Mesaj
                                </span>
                                @if (s.BeklenenTutar > 0)
                                {
                                    <span class="ms-3 text-muted small">
                                        Beklenen: <strong>@s.BeklenenTutar.ToString("N2")₺</strong>
                                        @if (s.BulunanVirmanTutar.HasValue)
                                        {
                                            <span> · Bulunan: <strong>@s.BulunanVirmanTutar.Value.ToString("N2")₺</strong></span>
                                        }
                                    </span>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    }

    @* ═══════ İşlem Tipi Gruplu Toplam ═══════ *@
    @{
        var tipGruplari = acikKayitlar
            .Where(k => !string.IsNullOrEmpty(k.TespitEdilenTip))
            .GroupBy(k => k.TespitEdilenTip!)
            .Select(g => new { Tip = g.Key, Adet = g.Count(), Toplam = g.Sum(x => x.Tutar) })
            .OrderByDescending(g => g.Toplam)
            .ToList();
    }
    @if (tipGruplari.Count > 0)
    {
        <div class="row mb-4">
            <div class="col-12">
                <div class="card" style="border-left: 5px solid #3498db; background: rgba(52,152,219,0.04);">
                    <div class="card-body py-3">
                        <h6 class="mb-2 fw-bold">
                            <i class="fas fa-layer-group me-1 text-primary"></i>İşlem Tipine Göre Açık Kayıt Toplamları
                        </h6>
                        <div class="d-flex flex-wrap gap-2">
                            @foreach (var g in tipGruplari)
                            {
                                var tipLabel = g.Tip switch
                                {
                                    "EFT_OTOMATIK_IADE" => "EFT Otomatik İade",
                                    "GELEN_HAVALE" => "Gelen Havale",
                                    "MEVDUAT_YATIRMA" => "Mevduata Para Yatırma",
                                    "VIRMAN" => "Virman",
                                    "MASRAF" => "Masraf",
                                    "REDDIYAT" => "Reddiyat",
                                    "IADE" => "İade",
                                    _ => g.Tip
                                };
                                var tipColor = g.Tip switch
                                {
                                    "EFT_OTOMATIK_IADE" => "#3498db",
                                    "GELEN_HAVALE" => "#2ecc71",
                                    "MEVDUAT_YATIRMA" => "#e67e22",
                                    "VIRMAN" => "#9b59b6",
                                    "MASRAF" => "#e74c3c",
                                    "REDDIYAT" => "#f39c12",
                                    "IADE" => "#1abc9c",
                                    _ => "#7f8c8d"
                                };
                                <div style="display: inline-flex; align-items: center; gap: 8px; padding: 6px 14px; border-radius: 8px; background: rgba(0,0,0,0.15); border: 1px solid @(tipColor)33;">
                                    <span style="width: 8px; height: 8px; border-radius: 50%; background: @tipColor; display: inline-block;"></span>
                                    <span style="font-size: 12px; font-weight: 600; color: @tipColor;">@tipLabel</span>
                                    <span class="badge bg-secondary" style="font-size: 10px;">@g.Adet adet</span>
                                    <span style="font-size: 12px; font-weight: 700; font-family: 'JetBrains Mono', monospace;">@g.Toplam.ToString("N2") ₺</span>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- ═══════ Tab Navigation ═══════ -->
    <ul class="nav nav-tabs mb-4">
        <li class="nav-item">
            @if (isHistoricalTabs)
            {
                <a class="nav-link @(activeTab == "ozet" ? "active" : "")"
                   href="@Url.Action("QueryDate", "HesapKontrol", new { tarih = tarihStrTabs, tab = "ozet" })">
                    <i class="fas fa-th-large me-1"></i> Özet
                </a>
            }
            else
            {
                <a class="nav-link @(activeTab == "ozet" ? "active" : "")"
                   asp-action="Index" asp-route-tab="ozet" asp-route-analizTarihiStr="@tarihStrTabs">
                    <i class="fas fa-th-large me-1"></i> Özet
                </a>
            }
        </li>
        <li class="nav-item">
            @if (isHistoricalTabs)
            {
                <a class="nav-link @(activeTab == "acik" ? "active" : "")"
                   href="@Url.Action("QueryDate", "HesapKontrol", new { tarih = tarihStrTabs, tab = "acik" })">
                    <i class="fas fa-exclamation-circle me-1"></i> Açık Kayıtlar
                    @if (acikKayitlar.Count > 0)
                    {
                        <span class="badge bg-danger ms-1">@acikKayitlar.Count</span>
                    }
                </a>
            }
            else
            {
                <a class="nav-link @(activeTab == "acik" ? "active" : "")"
                   asp-action="Index" asp-route-tab="acik" asp-route-analizTarihiStr="@tarihStrTabs">
                    <i class="fas fa-exclamation-circle me-1"></i> Açık Kayıtlar
                    @if (acikKayitlar.Count > 0)
                    {
                        <span class="badge bg-danger ms-1">@acikKayitlar.Count</span>
                    }
                </a>
            }
        </li>
        <li class="nav-item">
            @if (isHistoricalTabs)
            {
                <a class="nav-link @(activeTab == "takipte" ? "active" : "")"
                   href="@Url.Action("QueryDate", "HesapKontrol", new { tarih = tarihStrTabs, tab = "takipte" })">
                    <i class="fas fa-binoculars me-1"></i> Takipte
                    @if (takipteKayitlar.Count > 0)
                    {
                        <span class="badge ms-1" style="background: #8e44ad;">@takipteKayitlar.Count</span>
                    }
                </a>
            }
            else
            {
                <a class="nav-link @(activeTab == "takipte" ? "active" : "")"
                   asp-action="Index" asp-route-tab="takipte" asp-route-analizTarihiStr="@tarihStrTabs">
                    <i class="fas fa-binoculars me-1"></i> Takipte
                    @if (takipteKayitlar.Count > 0)
                    {
                        <span class="badge ms-1" style="background: #8e44ad;">@takipteKayitlar.Count</span>
                    }
                </a>
            }
        </li>
        <li class="nav-item">
            @if (isHistoricalTabs)
            {
                <a class="nav-link @(activeTab == "gecmis" ? "active" : "")"
                   href="@Url.Action("QueryDate", "HesapKontrol", new { tarih = tarihStrTabs, tab = "gecmis" })">
                    <i class="fas fa-history me-1"></i> Geçmiş
                </a>
            }
            else
            {
                <a class="nav-link @(activeTab == "gecmis" ? "active" : "")"
                   asp-action="Index" asp-route-tab="gecmis" asp-route-analizTarihiStr="@tarihStrTabs">
                    <i class="fas fa-history me-1"></i> Geçmiş
                </a>
            }
        </li>
    </ul>

    <!-- ═══════ TAB: Özet ═══════ -->
    @if (activeTab == "ozet")
    {
        <div class="row g-4">
            <div class="col-md-8">
                <div class="card">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0"><i class="fas fa-list me-2"></i>Son Açık Kayıtlar (İlk 10)</h5>
                    </div>
                    <div class="card-body p-0">
                        @if (acikKayitlar.Count == 0)
                        {
                            <div class="text-center py-4 text-muted">
                                <i class="fas fa-check-circle fa-3x mb-3" style="color: #2ecc71;"></i>
                                <h5>Tüm kayıtlar temiz!</h5>
                                <p>Açık eksik/fazla kaydı bulunmamaktadır.</p>
                            </div>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-hover table-sm mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Tarih</th>
                                            <th>Hesap</th>
                                            <th>Yön</th>
                                            <th>Tutar</th>
                                            <th>Sınıf</th>
                                            <th>Açıklama</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                    @foreach (var k in acikKayitlar.Take(10))
                                    {
                                        <tr>
                                            <td class="small">@k.AnalizTarihi.ToString("dd.MM")</td>
                                            <td>
                                                <span class="badge @(k.HesapTuru == BankaHesapTuru.Tahsilat ? "bg-success" : k.HesapTuru == BankaHesapTuru.Harc ? "bg-primary" : "bg-warning text-dark")">
                                                    @k.HesapTuru
                                                </span>
                                            </td>
                                            <td>
                                                @if (k.Yon == KayitYonu.Eksik)
                                                {
                                                    <span class="text-danger"><i class="fas fa-arrow-down"></i> Eksik</span>
                                                }
                                                else
                                                {
                                                    <span class="text-success"><i class="fas fa-arrow-up"></i> Fazla</span>
                                                }
                                            </td>
                                            <td class="fw-bold">@k.Tutar.ToString("N2")₺</td>
                                            <td>
                                                <span class="badge @(k.Sinif == FarkSinifi.Beklenen ? "bg-info" : k.Sinif == FarkSinifi.Askida ? "bg-warning text-dark" : "bg-secondary")">
                                                    @k.Sinif
                                                </span>
                                            </td>
                                            <td class="small text-truncate" style="max-width: 200px;" title="@k.Aciklama">
                                                @(k.Aciklama ?? k.DosyaNo ?? "-")
                                            </td>
                                        </tr>
                                    }
                                    </tbody>
                                </table>
                            </div>
                            @if (acikKayitlar.Count > 10)
                            {
                                <div class="text-center py-2">
                                    <a asp-action="Index" asp-route-tab="acik" asp-route-analizTarihiStr="@tarihStrTabs" class="btn btn-outline-primary btn-sm">
                                        Tümünü Gör (@acikKayitlar.Count kayıt)
                                    </a>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <!-- Info Card -->
                <div class="card mb-3">
                    <div class="card-body">
                        <h6 class="card-title"><i class="fas fa-info-circle text-primary me-2"></i>Hesap Kontrol Nedir?</h6>
                        <p class="small text-muted mb-0">
                            Karşılaştırma modülünde tespit edilen eşleşmeyen kayıtları (Eksik/Fazla) takip eder.
                            Sabah Kasa hesaplamasında bu veriler otomatik olarak doldurulur. Gün arası eşleşen
                            kayıtlar çapraz kontrol ile otomatik kapatılır.
                        </p>
                    </div>
                </div>
                <!-- Hızlı Aksiyon -->
                <div class="card">
                    <div class="card-body">
                        <h6 class="card-title"><i class="fas fa-bolt text-warning me-2"></i>Hızlı İşlemler</h6>
                        <form asp-action="RunAnalysis" method="post" class="mb-2">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="tarih" value="@Model.AnalizTarihi.ToString("yyyy-MM-dd")" />
                            <button type="submit" class="btn btn-success btn-sm w-100"
                                    onclick="this.disabled=true; this.innerHTML='<i class=\'fas fa-spinner fa-spin me-1\'></i> Analiz çalışıyor...'; this.form.submit();">
                                <i class="fas fa-sync-alt me-1"></i> Yeniden Analiz Et
                            </button>
                        </form>
                        <a asp-action="Index" asp-route-tab="acik" asp-route-analizTarihiStr="@tarihStrTabs" class="btn btn-outline-danger btn-sm w-100 mb-2">
                            <i class="fas fa-exclamation-circle me-1"></i> Açık Kayıtları Yönet
                        </a>
                        <a asp-action="ExportPdf"
