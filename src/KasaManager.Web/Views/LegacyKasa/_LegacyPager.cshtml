@{
    var (totalCount, currentPage, pageSize, totalPages, tab, startDate, endDate) =
        ((int, int, int, int, string, DateTime?, DateTime?))Model;
}

@if (totalPages > 1)
{
    <div class="card-footer d-flex justify-content-between align-items-center bg-white">
        <small class="text-muted">Toplam @totalCount kayıt — Sayfa @currentPage / @totalPages</small>
        <nav>
            <div class="d-flex gap-1">
                @if (currentPage > 1)
                {
                    <a asp-action="Index" asp-route-tab="@tab" asp-route-page="@(currentPage - 1)"
                       asp-route-startDate="@startDate?.ToString("yyyy-MM-dd")" asp-route-endDate="@endDate?.ToString("yyyy-MM-dd")"
                       class="page-link-custom"><i class="fas fa-chevron-left"></i></a>
                }

                @for (var p = Math.Max(1, currentPage - 2); p <= Math.Min(totalPages, currentPage + 2); p++)
                {
                    <a asp-action="Index" asp-route-tab="@tab" asp-route-page="@p"
                       asp-route-startDate="@startDate?.ToString("yyyy-MM-dd")" asp-route-endDate="@endDate?.ToString("yyyy-MM-dd")"
                       class="page-link-custom @(p == currentPage ? "active" : "")">@p</a>
                }

                @if (currentPage < totalPages)
                {
                    <a asp-action="Index" asp-route-tab="@tab" asp-route-page="@(currentPage + 1)"
                       asp-route-startDate="@startDate?.ToString("yyyy-MM-dd")" asp-route-endDate="@endDate?.ToString("yyyy-MM-dd")"
                       class="page-link-custom"><i class="fas fa-chevron-right"></i></a>
                }
            </div>
        </nav>
    </div>
}
else if (totalCount > 0)
{
    <div class="card-footer bg-white">
        <small class="text-muted">Toplam @totalCount kayıt</small>
    </div>
}
