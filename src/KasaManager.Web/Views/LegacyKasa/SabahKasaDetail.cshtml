<!-- ═══════ Bankaya Yatırılacak ═══════ -->
<div class="row g-3 mb-3">
    <div class="col-12">
        <div class="kasa-card" style="border: 2px solid var(--kasa-success); border-radius: var(--radius-md); overflow: hidden;">
            <div class="kasa-card-header" style="background: rgba(16,185,129,0.06); padding: 12px 20px;">
                <h6 class="mb-0" style="color: var(--kasa-success); font-weight: 700;">
                    <i class="fas fa-university me-2"></i>Bankaya Yatırılacak
                </h6>
            </div>
            <div class="kasa-card-body" style="padding: 0;">
                <div style="display: flex; justify-content: space-between; align-items: center; padding: 14px 20px; border-bottom: 1px solid var(--border-light);">
                    <span style="font-size: 13px; color: var(--text-muted); font-weight: 600;">Nakit</span>
                    <span class="money-value" style="font-size: 16px; font-weight: 700;">@Model.BankayaYatirilacakNakitSabahK.ToString("N2") <span class="money-currency">₺</span></span>
                </div>
                <div style="display: flex; justify-content: space-between; align-items: center; padding: 14px 20px; border-bottom: 1px solid var(--border-light);">
                    <span style="font-size: 13px; color: var(--text-muted); font-weight: 600;">Stopaj</span>
                    <span class="money-value" style="font-size: 16px; font-weight: 700;">@Model.BankayaYatirilacakStopajSabahK.ToString("N2") <span class="money-currency">₺</span></span>
                </div>
                <div style="display: flex; justify-content: space-between; align-items: center; padding: 14px 20px; border-bottom: 1px solid var(--border-light);">
                    <span style="font-size: 13px; color: var(--text-muted); font-weight: 600;">Harç</span>
                    <span class="money-value" style="font-size: 16px; font-weight: 700;">@Model.BankayaYatirilacakHarcSabahK.ToString("N2") <span class="money-currency">₺</span></span>
                </div>
                <!-- B.Toplam Yatan — vurgulu -->
                <div style="padding: 16px 20px; background: linear-gradient(135deg, rgba(16,185,129,0.08) 0%, rgba(16,185,129,0.03) 100%); border-top: 2px solid var(--kasa-success); display: flex; align-items: center; justify-content: space-between;">
                    <span style="font-size: 13px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.8px; color: var(--kasa-success);">
                        <i class="fas fa-arrow-right me-2"></i>B.Toplam Yatan
                    </span>
                    <span class="money-value" style="font-size: 22px; font-weight: 800; color: var(--kasa-success);">@Model.BToplamYATANSabahK.ToString("N2") <span class="money-currency">₺</span></span>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ═══════ Gizli Bölüm: Diğer Detaylar ═══════ -->
<div class="mb-3">
    <button class="kasa-btn kasa-btn-secondary w-100" type="button"
            onclick="let el=document.getElementById('legacyBankayaYat'); el.style.display=el.style.display==='none'?'':'none'; this.querySelector('.fa-chevron-down, .fa-chevron-up').classList.toggle('fa-chevron-down'); this.querySelector('.fa-chevron-down, .fa-chevron-up').classList.toggle('fa-chevron-up');"
            style="justify-content: space-between; padding: 12px 20px; border-radius: var(--radius-md);">
        <span><i class="fas fa-ellipsis-h me-2"></i>Diğer Detaylar (EFT, Değiştir, CN)</span>
        <i class="fas fa-chevron-down"></i>
