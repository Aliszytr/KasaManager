        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- MUHASEBE DEFTERİ: Banka Giriş Mutabakatı Accordion             -->
        <!-- ═══════════════════════════════════════════════════════════════ -->

        <div class="kasa-card mb-3" x-data="{ open: false }">
            <button type="button" class="kasa-accordion-toggle"
                    @@click="open = !open"
                    :aria-expanded="open.toString()">
                <span><i class="fas fa-book me-2"></i>Muhasebe Detayları — Banka Giriş Mutabakatı</span>
                <i class="fas fa-chevron-down"></i>
            </button>
            <div x-show="open" x-transition>
                <div class="kasa-card-body p-0">

                    <!-- ─── TAHSİLAT RECONCİLİASYON ─── -->
                    <div style="padding: 16px 20px 8px; border-bottom: 2px solid var(--border-light);">
                        <h6 style="font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; color: var(--kasa-primary); margin-bottom: 12px;">
                            <i class="fas fa-arrow-down text-success me-1"></i> Tahsilat Mutabakatı
                        </h6>
                        <table class="kasa-table" style="margin-bottom: 0;">
                            <thead>
                                <tr>
                                    <th style="width: 55%;">Kalem</th>
                                    <th class="text-end" style="width: 25%;">Tutar</th>
                                    <th style="width: 20%;"></th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr style="background: rgba(16,185,129,0.04);">
                                    <td><strong><i class="fas fa-arrow-circle-down text-success me-1"></i> Bankaya Giren Tahsilat</strong></td>
                                    <td class="text-end money-value" style="font-weight: 700; font-size: 14px;">@MuhFmt(muh_banka_giren_t) ₺</td>
                                    <td></td>
                                </tr>
                                <tr>
                                    <td style="padding-left: 28px;"><i class="fas fa-minus text-muted me-1" style="font-size: 10px;"></i> Bankaya Yatırılacak Tahsilat</td>
                                    <td class="text-end money-value">−@MuhFmt(muh_bankaya_yat_t) ₺</td>
                                    <td></td>
                                </tr>
                                <tr>
                                    <td style="padding-left: 28px;"><i class="fas fa-minus text-muted me-1" style="font-size: 10px;"></i> Online Tahsilat</td>
                                    <td class="text-end money-value">−@MuhFmt(muh_online_t) ₺</td>
                                    <td></td>
                                </tr>
                                @if (muh_eft_iade != 0)
                                {
                                <tr style="background: rgba(59,130,246,0.04);">
                                    <td style="padding-left: 28px;"><i class="fas fa-minus text-info me-1" style="font-size: 10px;"></i> EFT Otomatik İade</td>
                                    <td class="text-end money-value">−@MuhFmt(muh_eft_iade) ₺</td>
                                    <td><span style="font-size: 10px; color: var(--kasa-info);" title="Kasaya gelen EFT iadesidir. Çıktığı birime UYAP girişi yapılmalıdır."><i class="fas fa-info-circle"></i> UYAP girişi gerekli</span></td>
                                </tr>
                                }
                                @if (muh_gelen_havale != 0)
                                {
                                <tr style="background: rgba(59,130,246,0.04);">
                                    <td style="padding-left: 28px;"><i class="fas fa-minus text-info me-1" style="font-size: 10px;"></i> Gelen Havale</td>
                                    <td class="text-end money-value">−@MuhFmt(muh_gelen_havale) ₺</td>
                                    <td><span style="font-size: 10px; color: var(--kasa-info);" title="Gelen havale tutarıdır. İlgili birime UYAP girişi yapılmalıdır."><i class="fas fa-info-circle"></i> UYAP girişi gerekli</span></td>
                                </tr>
                                }
                                @if (muh_iade_kelimesi != 0)
                                {
                                <tr style="background: rgba(59,130,246,0.04);">
                                    <td style="padding-left: 28px;"><i class="fas fa-minus text-info me-1" style="font-size: 10px;"></i> İade Kelimesi Giriş</td>
                                    <td class="text-end money-value">−@MuhFmt(muh_iade_kelimesi) ₺</td>
                                    <td><span style="font-size: 10px; color: var(--kasa-info);" title="Açıklamasında 'iade' geçen giriştir. UYAP sistemine girişi yapılmalıdır."><i class="fas fa-info-circle"></i> UYAP girişi gerekli</span></td>
                                </tr>
                                }
                                @if (muh_dunden_gelen_t != 0)
                                {
                                <tr style="background: rgba(245,158,11,0.04);">
                                    <td style="padding-left: 28px;"><i class="fas fa-minus text-warning me-1" style="font-size: 10px;"></i> Dünden Gelen Eksik/Fazla</td>
                                    <td class="text-end money-value">−@MuhFmt(muh_dunden_gelen_t) ₺</td>
                                    <td><span style="font-size: 10px; color: var(--text-muted);"><i class="fas fa-history"></i> Önceki günden</span></td>
                                </tr>
                                }
                                <tr style="border-top: 2px solid var(--border-light); background: @(Math.Abs(muh_fark_t) < 0.01m ? "rgba(16,185,129,0.06)" : "rgba(239,68,68,0.06)");">
                                    <td><strong><i class="@MuhFarkIcon(muh_fark_t) me-1" style="@MuhFarkClass(muh_fark_t)"></i> Toplam Fark</strong></td>
                                    <td class="text-end money-value" style="font-weight: 700; font-size: 14px; @MuhFarkClass(muh_fark_t)">@MuhFmt(muh_fark_t) ₺</td>
                                    <td>
                                        @if (Math.Abs(muh_fark_t) < 0.01m)
                                        {
                                            <span style="font-size: 10px; color: var(--kasa-success);"><i class="fas fa-check"></i> Sorun yok</span>
                                        }
                                        else
                                        {
                                            <span style="font-size: 10px; color: var(--kasa-danger);"><i class="fas fa-exclamation-triangle"></i> Kontrol edin</span>
                                        }
                                    </td>
                                </tr>
                                @if (Math.Abs(muh_fark_t) >= 0.01m && muh_beklenen_t > 0)
                                {
                                <tr style="background: rgba(59,130,246,0.04);">
                                    <td style="padding-left: 28px; font-size: 12px;"><i class="fas fa-check-circle text-info me-1"></i> Beklenen (EFT İade + Havale + Diğer)</td>
                                    <td class="text-end money-value" style="font-size: 12px; color: var(--kasa-info);">@MuhFmt(muh_beklenen_t) ₺</td>
                                    <td><span style="font-size: 10px; color: var(--kasa-info);">Normal akış</span></td>
                                </tr>
                                <tr style="background: @(Math.Abs(muh_olagan_disi_t) < 0.01m ? "rgba(16,185,129,0.04)" : "rgba(239,68,68,0.06)");">
                                    <td style="padding-left: 28px; font-size: 12px; font-weight: 600;">
                                        <i class="fas fa-exclamation-triangle me-1" style="color: @(Math.Abs(muh_olagan_disi_t) < 0.01m ? "var(--kasa-success)" : "var(--kasa-danger)")"></i>
                                        ⚠️ Olağan Dışı (Beklenmeyen) Fark
                                    </td>
                                    <td class="text-end money-value" style="font-size: 13px; font-weight: 700; @MuhFarkClass(muh_olagan_disi_t)">@MuhFmt(muh_olagan_disi_t) ₺</td>
                                    <td>
                                        @if (Math.Abs(muh_olagan_disi_t) >= 0.01m)
                                        {
                                            <span class="badge" style="font-size: 9px; background: @(muh_olagan_disi_t < 0 ? "var(--kasa-danger)" : "var(--kasa-success)"); color: white;">@(muh_olagan_disi_t < 0 ? "Eksik" : "Fazla")</span>
                                            <span style="font-size: 9px; color: var(--kasa-danger); margin-left: 4px;">Takibe alın</span>
                                        }
                                        else
                                        {
                                            <span style="font-size: 10px; color: var(--kasa-success);"><i class="fas fa-check"></i></span>
                                        }
                                    </td>
                                </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <!-- ─── HARÇ RECONCİLİASYON ─── -->
                    <div style="padding: 16px 20px 8px; border-bottom: 2px solid var(--border-light);">
                        <h6 style="font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; color: var(--kasa-primary); margin-bottom: 12px;">
                            <i class="fas fa-receipt text-danger me-1"></i> Harç Mutabakatı
                        </h6>
                        <table class="kasa-table" style="margin-bottom: 0;">
                            <thead>
