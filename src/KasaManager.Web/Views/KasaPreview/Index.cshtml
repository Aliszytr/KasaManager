        <!-- TÜM SONUÇLAR ACCORDION                                         -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        @if (resultFields.Count > 0)
        {
            <div class="kasa-card mb-3" x-data="{ open: false }">
                <button type="button" class="kasa-accordion-toggle"
                        @@click="open = !open"
                        :aria-expanded="open.toString()">
                    <span><i class="fas fa-list-ul me-2"></i>Tüm Formül Çıktıları (@resultFields.Count adet)</span>
                    <i class="fas fa-chevron-down"></i>
                </button>
                <div x-show="open" x-transition>
                    <div class="kasa-card-body p-0">
                        <table class="kasa-table">
                            <thead>
                                <tr>
                                    <th>Alan</th>
                                    <th class="text-end">Değer</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var kv in resultFields)
                                {
                                    <tr>
                                        <td>@kv.Key.Replace("_", " ")</td>
                                        <td class="text-end money-value">@kv.Value ₺</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }

