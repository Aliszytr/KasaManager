<!-- ═══════════════════════════════════════════════════════════════════ -->
<!-- ADIM 3: Sonuçlar (Progressive Disclosure — Hesaplama sonrası)      -->
<!-- ═══════════════════════════════════════════════════════════════════ -->
@if (Model.HasResults)
{
<div class="mb-4 kasa-fade-in">
    <div class="kasa-step-header">
        <div class="kasa-step-number active">3</div>
        <div>
            <div class="kasa-step-title">Sonuçlar</div>
            <div class="kasa-step-subtitle">Hesaplama sonuçları ve özet</div>
        </div>
    </div>

    @* ── Validation Uyarı Paneli (Genel Kasa'da bankaya yatırılacak yoktur, panel gösterilmez) ── *@
    @if (!string.Equals(Model.KasaType, "genel", StringComparison.OrdinalIgnoreCase))
    {
        @await Html.PartialAsync("_ValidationPanel", Model)
    }

    @* ── TempData Alerts moved to above CRUD buttons ── *@

    @if (string.IsNullOrEmpty(Model.DbFormulaSetId) && !Model.LoadedSnapshotId.HasValue)
    {
        <div class="kasa-alert kasa-alert-warning mb-3" style="border-left: 4px solid var(--kasa-warning); background: rgba(245,158,11,0.08); padding: 12px 16px; border-radius: var(--radius-sm); display: flex; align-items: flex-start; gap: 10px;">
            <i class="fas fa-exclamation-triangle" style="color: var(--kasa-warning); margin-top: 2px; flex-shrink: 0;"></i>
            <div style="font-size: 13px;">
                <strong>Gömülü varsayılan formüller kullanılıyor.</strong>
                Aktif bir DB şablonu bulunamadığı için sınırlı embedded fallback formüller kullanıldı — bazı sonuç kartları eksik değer gösterebilir.
                <a href="@Url.Action("Index", "FormulaDesigner")" style="color: var(--kasa-info); font-weight: 600;">FormulaDesigner'a gidin →</a>
            </div>
        </div>
    }

    @{
        // FormulaRun.Outputs (Intent-First) veya Drafts.Fields (legacy) kaynağını birleştir
        var resultFields = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);

        if (Model.FormulaRun?.Outputs?.Count > 0)
        {
            foreach (var kv in Model.FormulaRun.Outputs)
            {
                resultFields[kv.Key] = kv.Value.ToString("N2", System.Globalization.CultureInfo.GetCultureInfo("tr-TR"));
            }
        }
        else if (Model.Drafts != null)
        {
            var draft = Model.KasaType?.ToLowerInvariant() switch
            {
                "sabah" => Model.Drafts.Sabah,
                "aksam" => Model.Drafts.Aksam,
                "genel" => Model.Drafts.Genel,
                _ => Model.Drafts.Genel
            };
            if (draft?.Fields != null)
            {
                foreach (var kv in draft.Fields)
                {
                    resultFields[kv.Key] = kv.Value;
                }
            }
        }

        // Key aliasing: DB şablonları ve V1 şablonları farklı key adları kullanabilir.
        // Bu sözlük, UI'nin doğru değeri bulmasını sağlar.
        var keyAliases = new Dictionary<string, string[]>(StringComparer.OrdinalIgnoreCase)
        {
            // Aksam Kasa aliases
            ["bankaya_yatirilacak_toplam"] = new[] { "bankaya_yatirilacak_toplam_miktar", "bankaya_goturulecek_toplam" },
            ["normal_stopaj"]              = new[] { "bankaya_yatirilacak_stopaj", "toplam_stopaj_net" },
            ["bankaya_yatirilacak_harc"]   = new[] { "bankaya_yatirilacak_harç", "banka_goturulecek_harc" },
            ["bankaya_yatirilacak_tahsilat"] = new[] { "banka_goturulecek_tahsilat" },

            // Genel Kasa aliases (FormulaSet key → canonical key fallback)
            ["devreden"]             = new[] { "genel_kasa_devreden_seed", "Devreden" },
            ["toplam_tahsilat"]      = new[] { "masraf", "toplamTahsilat", "Toplam_Tahsilat" },
            ["toplam_reddiyat"]      = new[] { "masraf_reddiyat", "toplamReddiyat", "Toplam_Reddiyat" },
            ["tah_red_fark"]         = new[] { "Tah_Red_Fark", "tahRedFark", "Tah_red_fark" },
            ["banka_bakiye"]         = new[] { "bankaBakiye", "Banka_Bakiye", "banka_yarina_devredecek_tahsilat" },
            ["sonraya_devredecek"]   = new[] { "banka_yarina_devredecek_tahsilat", "sonrayaDevredecek", "Sonraya_Devredecek" },
            ["kasa_nakit"]           = new[] { "nakit_para", "kasaNakit", "Kasa_Nakit" },
            ["eksik_fazla"]          = new[] { "kasa_eksik_fazla", "eksikFazla", "Eksik_Fazla" },
            ["genel_kasa"]           = new[] { "GenelKasa", "Genel_Kasa", "genelKasa" },
            ["mutabakat_farki"]      = new[] { "MutabakatFarki", "Mutabakat_Farki", "mutabakatFarki" },
            ["kayden_tahsilat"]      = new[] { "kaydenTahsilat", "Kayden_Tahsilat" },
            ["gelmeyen_d"]           = new[] { "gelmeyenD", "Gelmeyen_D" },
        };

        // Pool'dan ham değerleri oku (FormulaRun çıktısında olmayanlar için)
        string PoolVal(string key) {
            var p = Model.PoolEntries?.FirstOrDefault(x =>
                x.CanonicalKey.Equals(key, StringComparison.OrdinalIgnoreCase));
            if (p != null) return p.Value; // Value zaten string formatlı
            // FormulaRun çıktısından bak
            if (resultFields.TryGetValue(key, out var v)) return v;
            // Alias'larda ara
            if (keyAliases.TryGetValue(key, out var aliases))
            {
                foreach (var alt in aliases)
                {
                    var ap = Model.PoolEntries?.FirstOrDefault(x =>
                        x.CanonicalKey.Equals(alt, StringComparison.OrdinalIgnoreCase));
                    if (ap != null) return ap.Value;
                    if (resultFields.TryGetValue(alt, out var av)) return av;
                }
            }
            return "—";
        }

        // ResultVal: Formül çıktıları > Pool
        // Önce formül sonuçlarında (direkt + alias) ara, sonra pool'da ara
        string ResultVal(string key) {
            // 1. Direkt formül çıktısı
            if (resultFields.TryGetValue(key, out var v)) return v;
            // 2. Alias üzerinden formül çıktısı (ÖNCELİKLİ — formül sonuçları pool'dan üstün)
            if (keyAliases.TryGetValue(key, out var aliases))
            {
                foreach (var alt in aliases)
                {
                    if (resultFields.TryGetValue(alt, out var av)) return av;
                }
            }
            // 3. Direkt pool araması
            var p = Model.PoolEntries?.FirstOrDefault(x =>
                x.CanonicalKey.Equals(key, StringComparison.OrdinalIgnoreCase));
            if (p != null) return p.Value;
            // 4. Alias üzerinden pool araması
            if (keyAliases.TryGetValue(key, out var aliases2))
            {
                foreach (var alt in aliases2)
                {
                    var ap = Model.PoolEntries?.FirstOrDefault(x =>
                        x.CanonicalKey.Equals(alt, StringComparison.OrdinalIgnoreCase));
                    if (ap != null) return ap.Value;
                }
            }
            return "—";
        }

        // ResultValRaw: ham decimal değer — Banka Fişi hidden input'ları için
        decimal ResultValRaw(string key) {
            if (Model.FormulaRun?.Outputs != null && Model.FormulaRun.Outputs.TryGetValue(key, out var v)) return v;
            if (keyAliases.TryGetValue(key, out var aliases))
            {
                foreach (var alt in aliases)
                {
                    if (Model.FormulaRun?.Outputs != null && Model.FormulaRun.Outputs.TryGetValue(alt, out var av)) return av;
                }
            }
            var p = Model.PoolEntries?.FirstOrDefault(x => x.CanonicalKey.Equals(key, StringComparison.OrdinalIgnoreCase));
            if (p != null && decimal.TryParse(p.Value, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var pv)) return pv;
            return 0m;
        }

        // ════════════════════════════════════════════════════════════════
        // STOPAJ KONTROL İŞ MANTIĞI
        // ════════════════════════════════════════════════════════════════
        // Fark = OnlineReddiyat − BankadanÇıkan
        // 
        // SABAH / AKŞAM TAM GÜN (gün bitmiş):
        //   Fark ≈ 0        → ✅ OK
        //   Fark ≈ Stopaj   → ❌ Stopaj Virman Yapılmamış
        //   Fark ≠ 0/Stopaj → ❌ Bilinmeyen Uyuşmazlık
        //
        // AKŞAM MESAİ SONU (gün devam ediyor):
        //   Fark ≈ 0        → ✅ OK
        //   Fark ≈ Stopaj   → ✅ OK + bilgi notu (virman yapılacak)
        //   Fark ≠ Stopaj   → ❌ Stopaj dışı uyuşmazlık
        // ════════════════════════════════════════════════════════════════
        var sk_reddiyat = ResultValRaw("online_reddiyat");
        var sk_bankaCikan = ResultValRaw("bankadan_cikan_tahsilat");
        var sk_toplamStopaj = ResultValRaw("toplam_stopaj");
        decimal sk_fark = sk_reddiyat - sk_bankaCikan;          // ham fark
        bool sk_farkSifir = Math.Abs(sk_fark) < 0.01m;          // fark ≈ 0
        bool sk_farkStopajaDenk = !sk_farkSifir                 // fark ≈ stopaj
                                  && sk_toplamStopaj > 0.01m
                                  && Math.Abs(sk_fark - sk_toplamStopaj) < 0.01m;

        // Eski uyumluluk — "stopajKontrolRaw" ve "stopajKontrolOk" hâlâ
        // Sonuçlar bölümündeki tablo tarafından kullanılıyor
        decimal stopajKontrolRaw = sk_fark;
        var stopajKontrolOk = sk_farkSifir;

        // Muhasebe reconciliation hesaplamaları
        var muh_banka_giren_t = ResultValRaw("bankaya_giren_tahsilat");
        var muh_bankaya_yat_t = ResultValRaw("bankaya_yatirilacak_tahsilat");
        var muh_online_t = ResultValRaw("online_tahsilat");
        var muh_eft_iade = ResultValRaw("eft_otomatik_iade");
        var muh_gelen_havale = ResultValRaw("gelen_havale");
        var muh_iade_kelimesi = ResultValRaw("iade_kelimesi_giris");
        var muh_dunden_gelen_t = ResultValRaw("dunden_eksik_fazla_gelen_tahsilat");
        var muh_fark_t = muh_banka_giren_t - muh_bankaya_yat_t - muh_online_t
                        - muh_eft_iade - muh_gelen_havale - muh_iade_kelimesi - muh_dunden_gelen_t;
        var muh_beklenen_t = muh_eft_iade + muh_gelen_havale + muh_iade_kelimesi + muh_dunden_gelen_t;
        var muh_olagan_disi_t = muh_banka_giren_t - muh_bankaya_yat_t - muh_online_t; // ham fark (beklenen hariç)

        var muh_banka_giren_h = ResultValRaw("bankaya_giren_harc");
        var muh_bankaya_yat_h = ResultValRaw("bankaya_yatirilacak_harc");
        var muh_online_h = ResultValRaw("online_harc");
        var muh_dunden_gelen_h = ResultValRaw("dunden_eksik_fazla_gelen_harc");
        var muh_fark_h = muh_banka_giren_h - muh_bankaya_yat_h - muh_online_h - muh_dunden_gelen_h;
        var muh_olagan_disi_h = muh_banka_giren_h - muh_bankaya_yat_h - muh_online_h; // ham fark (beklenen hariç)

        var muhTrFmt = System.Globalization.CultureInfo.GetCultureInfo("tr-TR");

        string MuhFmt(decimal v) => v.ToString("N2", muhTrFmt);
        string MuhFarkClass(decimal v) => Math.Abs(v) < 0.01m ? "color: var(--kasa-success)" : "color: var(--kasa-danger); font-weight: 700";
        string MuhFarkIcon(decimal v) => Math.Abs(v) < 0.01m ? "fas fa-check-circle" : "fas fa-exclamation-triangle";
    }

    @if (resultFields.Count > 0 || Model.PoolEntries?.Count > 0)
    {
        @if (kasaTypeClass == "genel")
        {
            // ═══════════════════════════════════════════════════════════════
            // GENEL KASA — Özel Sonuç Şablonu
            // ═══════════════════════════════════════════════════════════════

            var trC = System.Globalization.CultureInfo.GetCultureInfo("tr-TR");

            // Sayısal değer ayrıştırma yardımcısı
            decimal ParseGkDecimal(string s) {
                if (string.IsNullOrEmpty(s) || s == "—") return 0m;
                // TR formatı: 1.234.567,89 → temizle
                var clean = s.Replace(".", "").Replace(",", ".").Replace("₺", "").Trim();
                if (decimal.TryParse(clean, System.Globalization.NumberStyles.Any,
                    System.Globalization.CultureInfo.InvariantCulture, out var d)) return d;
                return 0m;
            }

            string GkMoney(string key) {
                var v = ResultVal(key);
                if (v == "—") v = PoolVal(key);
                if (v != "—") return v;

                // Computed fallback: türetilmiş değerler
                if (key.Equals("tah_red_fark", StringComparison.OrdinalIgnoreCase))
                {
                    var tah = GkMoney("toplam_tahsilat");
                    var red = GkMoney("toplam_reddiyat");
                    if (tah != "—" && red != "—")
                    {
                        var result = ParseGkDecimal(tah) - ParseGkDecimal(red);
                        return result.ToString("N2", trC);
                    }
                }
                else if (key.Equals("mutabakat_farki", StringComparison.OrdinalIgnoreCase))
                {
                    var banka = GkMoney("banka_bakiye");
                    var devredecek = GkMoney("sonraya_devredecek");
                    var eksik = GkMoney("eksik_fazla");
                    if (banka != "—" && devredecek != "—")
                    {
                        var beklenen = ParseGkDecimal(devredecek) + ParseGkDecimal(eksik);
                        var result = ParseGkDecimal(banka) - beklenen;
                        return result.ToString("N2", trC);
                    }
                }

                return v;
            }

            <!-- ═══════ KASA KİMLİK BANDI (Genel Kasa) ═══════ -->
            <div class="kasa-identity-banner kasa-identity-banner-genel">
                <div class="kasa-identity-banner-icon">
                    <i class="fas fa-chart-pie"></i>
                </div>
                <div class="kasa-identity-banner-body">
                    <div class="kasa-identity-banner-type">Genel Kasa Raporu</div>
                    <div class="kasa-identity-banner-date">
                        @(Model.GenelKasaStartDate?.ToString("dd MMMM yyyy", new System.Globalization.CultureInfo("tr-TR")) ?? "—")
                        <span style="font-size:14px; font-weight:600; color:var(--text-muted); margin:0 6px;">—</span>
                        @(Model.GenelKasaEndDate?.ToString("dd MMMM yyyy", new System.Globalization.CultureInfo("tr-TR")) ?? Model.SelectedDate?.ToString("dd MMMM yyyy", new System.Globalization.CultureInfo("tr-TR")) ?? "—")
                    </div>
                    <div class="kasa-identity-banner-meta">
                        @if (Model.LoadedSnapshotId.HasValue)
                        {
                            <span class="kasa-identity-banner-source kasa-identity-banner-source-db">
                                <i class="fas fa-database"></i> Veritabanından yüklendi
                            </span>
                        }
                        else
                        {
                            <span class="kasa-identity-banner-source kasa-identity-banner-source-excel">
                                <i class="fas fa-file-excel"></i> Excel'den hesaplandı
                            </span>
                        }
                        @if (!string.IsNullOrEmpty(Model.KasayiYapan))
                        {
                            <span class="kasa-identity-banner-period">
                                <i class="fas fa-user-check me-1"></i>@Model.KasayiYapan
                            </span>
                        }
                    </div>
                </div>
            </div>

            <!-- TARİH BİLGİLERİ -->
            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <div class="result-card" style="border-left: 5px solid var(--kasa-primary); height: 100%;">
                        <div class="result-card-label">
                            <i class="fas fa-calendar-day" style="color: var(--kasa-primary);"></i> Dönem Başlangıcı
                        </div>
                        <div class="result-card-value" style="font-size: 22px;">
                            @(Model.GenelKasaStartDate?.ToString("dd.MM.yyyy") ?? Model.SelectedDate?.ToString("dd.MM.yyyy") ?? "—")
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="result-card result-card-primary" style="border-left: 5px solid var(--kasa-primary); height: 100%;">
                        <div class="result-card-label">
                            <i class="fas fa-calendar-check"></i> Dönem Bitişi
                        </div>
                        <div class="result-card-value" style="font-size: 22px;">
                            @(Model.GenelKasaEndDate?.ToString("dd.MM.yyyy") ?? Model.SelectedDate?.ToString("dd.MM.yyyy") ?? "—")
                        </div>
                    </div>
                </div>
            </div>


            <!-- ANA METRİKLER — 4'lü Kart Satırı -->
            <div class="row g-3 mb-3">
                <div class="col-md-3">
                    <div class="result-card" style="border-left: 4px solid var(--kasa-success); height: 100%;">
                        <div class="result-card-label">
                            <i class="fas fa-arrow-right" style="color: var(--kasa-success);"></i> Devreden
                        </div>
                        <div class="result-card-value" style="font-size: 20px; color: var(--kasa-success);">
                            @GkMoney("devreden") <span class="money-currency">₺</span>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="result-card" style="border-left: 4px solid var(--kasa-info); height: 100%;">
                        <div class="result-card-label">
                            <i class="fas fa-coins" style="color: var(--kasa-info);"></i> Toplam Tahsilat
                        </div>
                        <div class="result-card-value" style="font-size: 20px;">
                            @GkMoney("toplam_tahsilat") <span class="money-currency">₺</span>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="result-card" style="border-left: 4px solid var(--kasa-warning); height: 100%;">
                        <div class="result-card-label">
                            <i class="fas fa-undo" style="color: var(--kasa-warning);"></i> Toplam Reddiyat
                        </div>
                        <div class="result-card-value" style="font-size: 20px;">
                            @GkMoney("toplam_reddiyat") <span class="money-currency">₺</span>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="result-card" style="border-left: 4px solid var(--kasa-secondary); height: 100%;">
                        <div class="result-card-label">
                            <i class="fas fa-balance-scale" style="color: var(--kasa-secondary);"></i> Tahsilat − Reddiyat Fark
                        </div>
                        <div class="result-card-value" style="font-size: 20px;">
                            @GkMoney("tah_red_fark") <span class="money-currency">₺</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- DETAY KARTLARI — 2'li Panel -->
            <div class="row g-3 mb-3">
                <!-- Sol: Banka & Devir -->
                <div class="col-lg-6">
                    <div class="kasa-card" style="border-radius: var(--radius-md); height: 100%;">
                        <div class="kasa-card-header" style="padding: 12px 20px; background: rgba(8,145,178,0.06);">
                            <h6 class="mb-0" style="font-weight: 700; color: var(--kasa-info);">
                                <i class="fas fa-university me-2"></i>Banka & Devir Bilgileri
                            </h6>
                        </div>
                        <div class="kasa-card-body" style="padding: 0;">
                            <div style="display: flex; justify-content: space-between; align-items: center; padding: 12px 20px; border-bottom: 1px solid var(--border-light);">
                                <span style="font-size: 13px; color: var(--text-muted); font-weight: 600;">
                                    <i class="fas fa-piggy-bank me-2" style="color: var(--kasa-info); width: 16px;"></i>Banka Bakiye
                                </span>
                                <span style="font-size: 16px; font-weight: 700;">@GkMoney("banka_bakiye") ₺</span>
                            </div>
                            <div style="display: flex; justify-content: space-between; align-items: center; padding: 12px 20px; border-bottom: 1px solid var(--border-light);">
                                <span style="font-size: 13px; color: var(--text-muted); font-weight: 600;">
                                    <i class="fas fa-file-invoice-dollar me-2" style="color: var(--kasa-info); width: 16px;"></i>Kayden Tahsilat
                                </span>
                                <span style="font-size: 16px; font-weight: 700;">@GkMoney("kayden_tahsilat") ₺</span>
                            </div>
                            <div style="display: flex; justify-content: space-between; align-items: center; padding: 12px 20px;">
                                <span style="font-size: 13px; color: var(--text-muted); font-weight: 600;">
                                    <i class="fas fa-forward me-2" style="color: var(--kasa-info); width: 16px;"></i>Sonraya Devredecek
                                </span>
                                <span style="font-size: 16px; font-weight: 700;">@GkMoney("sonraya_devredecek") ₺</span>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- Sağ: Kasa Detayları -->
                <div class="col-lg-6">
                    <div class="kasa-card" style="border-radius: var(--radius-md); height: 100%;">
                        <div class="kasa-card-header" style="padding: 12px 20px; background: rgba(245,158,11,0.06);">
                            <h6 class="mb-0" style="font-weight: 700; color: var(--kasa-warning);">
                                <i class="fas fa-cash-register me-2"></i>Kasa Detayları
                            </h6>
                        </div>
                        <div class="kasa-card-body" style="padding: 0;">
                            <div style="display: flex; justify-content: space-between; align-items: center; padding: 12px 20px; border-bottom: 1px solid var(--border-light);">
                                <span style="font-size: 13px; color: var(--text-muted); font-weight: 600;">
                                    <i class="fas fa-money-bill-wave me-2" style="color: var(--kasa-warning); width: 16px;"></i>Kasa Nakit
                                </span>
                                <span style="font-size: 16px; font-weight: 700;">@GkMoney("kasa_nakit") ₺</span>
                            </div>
                            <div style="display: flex; justify-content: space-between; align-items: center; padding: 12px 20px; border-bottom: 1px solid var(--border-light);">
                                <span style="font-size: 13px; color: var(--text-muted); font-weight: 600;">
                                    <i class="fas fa-plus-minus me-2" style="color: var(--kasa-warning); width: 16px;"></i>Eksik/Fazla Makbuz
                                </span>
                                <span style="font-size: 16px; font-weight: 700;">@GkMoney("eksik_fazla") ₺</span>
                            </div>
                            <div style="display: flex; justify-content: space-between; align-items: center; padding: 12px 20px;">
                                <span style="font-size: 13px; color: var(--text-muted); font-weight: 600;">
                                    <i class="fas fa-ban me-2" style="color: var(--kasa-warning); width: 16px;"></i>Gelmeyen D.
                                </span>
                                <span style="font-size: 16px; font-weight: 700;">@GkMoney("gelmeyen_d") ₺</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- SONUÇ HERO KARTLARI — Genel Kasa + Mutabakat Farkı -->
            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <div class="kasa-card" style="border: 2px solid var(--kasa-primary); border-radius: var(--radius-md); overflow: hidden; height: 100%;">
                        <div style="padding: 20px 24px; background: linear-gradient(135deg, rgba(8,145,178,0.06) 0%, rgba(8,145,178,0.02) 100%);">
                            <div style="font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.8px; color: var(--text-muted); margin-bottom: 8px;">
                                <i class="fas fa-landmark me-2"></i>Genel Kasa
                            </div>
                            <div style="font-size: 34px; font-weight: 800; color: var(--kasa-primary); line-height: 1.1;">
                                @GkMoney("genel_kasa") <span style="font-size: 18px; font-weight: 600;">₺</span>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    @{
                        var mkVal = GkMoney("mutabakat_farki");
                        decimal mkDec = 0;
                        decimal.TryParse(mkVal?.Replace(".", "").Replace(",", "."), System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out mkDec);
                        var mkColor = Math.Abs(mkDec) < 0.01m ? "var(--kasa-success)" : "var(--kasa-danger)";
                    }
                    <div class="kasa-card" style="border: 2px solid @mkColor; border-radius: var(--radius-md); overflow: hidden; height: 100%;">
                        <div style="padding: 20px 24px; background: linear-gradient(135deg, rgba(16,185,129,0.06) 0%, rgba(16,185,129,0.02) 100%);">
                            <div style="font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.8px; color: var(--text-muted); margin-bottom: 8px;">
                                <i class="fas fa-balance-scale-right me-2"></i>Mutabakat Farkı
                                <span style="font-size: 10px; font-weight: 500; letter-spacing: 0;">(Banka − Beklenen)</span>
                            </div>
                            <div style="font-size: 34px; font-weight: 800; color: @mkColor; line-height: 1.1;">
                                @mkVal <span style="font-size: 18px; font-weight: 600;">₺</span>
                            </div>
                            @if (Math.Abs(mkDec) < 0.01m)
                            {
                                <div style="margin-top: 8px; font-size: 12px; color: var(--kasa-success);">
                                    <i class="fas fa-check-circle me-1"></i> Mutabakat tamam — fark yok
                                </div>
                            }
                            else
                            {
                                <div style="margin-top: 8px; font-size: 12px; color: var(--kasa-danger);">
                                    <i class="fas fa-exclamation-triangle me-1"></i> Mutabakat farkı mevcut — kontrol gerekli
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <!-- Kasayı Yapan + Günlük Not -->
            <div class="row g-3 mb-3">
                <div class="col-md-4">
                    <div class="kasa-card" style="border-radius: var(--radius-md); height: 100%;">
                        <div class="kasa-card-body d-flex align-items-center gap-3" style="padding: 16px 20px;">
                            <div style="width: 44px; height: 44px; border-radius: 50%; background: rgba(8,145,178,0.1); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                                <i class="fas fa-user" style="color: var(--kasa-primary); font-size: 18px;"></i>
                            </div>
                            <div>
                                <div style="font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; color: var(--text-muted);">Kasayı Yapan</div>
                                <div style="font-size: 16px; font-weight: 700;">@(string.IsNullOrEmpty(Model.KasayiYapan) ? "—" : Model.KasayiYapan)</div>
                                <div style="font-size: 11px; color: var(--text-muted);">@(Model.SelectedDate?.ToString("dd.MM.yyyy") ?? "—")</div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-8">
                    <div class="kasa-card" style="border-radius: var(--radius-md); border-left: 4px solid #f59e0b; height: 100%;">
                        <div class="kasa-card-body" style="padding: 12px 20px;">
                            <div class="d-flex align-items-center gap-2 mb-2">
                                <div style="width: 32px; height: 32px; border-radius: 50%; background: rgba(245,158,11,0.1); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                                    <i class="fas fa-sticky-note" style="color: #f59e0b; font-size: 14px;"></i>
                                </div>
                                <div style="font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; color: var(--text-muted);">Günlük Kasa Notu</div>
                                <span style="font-size: 10px; color: var(--text-muted); margin-left: auto;">Özel durumları, uyarıları ve notları buraya yazın</span>
                            </div>
                            <textarea id="kasaGunlukNot" name="KasaGunlukNot" rows="3"
                                      class="form-control" 
                                      style="font-size: 13px; border: 1.5px dashed var(--border-light); border-radius: var(--radius-sm); background: rgba(245,158,11,0.02); resize: vertical; transition: border-color 0.2s;"
                                      placeholder="Örn: @eftIadePlaceholder • Olağandışı fazla tahsilat kontrol edilecek • Banka kaydına yansımayan değerler mevcut..."
                                      onfocus="this.style.borderColor='#f59e0b'; this.style.borderStyle='solid';" 
                                      onblur="this.style.borderColor='var(--border-light)'; this.style.borderStyle='dashed';">@Model.GunlukKasaNotu</textarea>
                        </div>
                    </div>
                </div>
            </div>
        }
        else
        {
        <!-- ═══════ KASA KİMLİK BANDI (Sabah / Akşam) ═══════ -->
        <div class="kasa-identity-banner kasa-identity-banner-@kasaTypeClass">
            <div class="kasa-identity-banner-icon">
                <i class="fas @kasaIcon"></i>
            </div>
            <div class="kasa-identity-banner-body">
                <div class="kasa-identity-banner-type">@kasaDisplayName</div>
                <div class="kasa-identity-banner-date">@(Model.SelectedDate?.ToString("dd MMMM yyyy, dddd", new System.Globalization.CultureInfo("tr-TR")) ?? "—")</div>
                <div class="kasa-identity-banner-meta">
                    @if (Model.LoadedSnapshotId.HasValue)
                    {
                        <span class="kasa-identity-banner-source kasa-identity-banner-source-db">
                            <i class="fas fa-database"></i> Veritabanından yüklendi
                            @if (!string.IsNullOrEmpty(Model.LoadedSnapshotName))
                            {
                                <text> — @Model.LoadedSnapshotName</text>
                            }
                        </span>
                    }
                    else
                    {
                        <span class="kasa-identity-banner-source kasa-identity-banner-source-excel">
                            <i class="fas fa-file-excel"></i> Excel'den hesaplandı
                        </span>
                    }
                    @if (!string.IsNullOrEmpty(Model.KasayiYapan))
                    {
                        <span class="kasa-identity-banner-period">
                            <i class="fas fa-user-check me-1"></i>@Model.KasayiYapan
                        </span>
                    }
                </div>
            </div>
        </div>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- ROW 1: Dünden Devreden Kasa + Güne Ait Genel Kasa              -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <div class="row g-3 mb-3">
            <div class="col-md-6">
                <div class="result-card" style="border-left: 5px solid var(--kasa-primary);">
                    <div class="result-card-label">
                        <i class="fas fa-history" style="color: var(--kasa-primary);"></i> Dünden Devreden Kasa
                    </div>
                    <div class="result-card-value" style="font-size: 28px;">
                        @PoolVal("dunden_devreden_kasa_nakit") <span class="money-currency">₺</span>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="result-card result-card-primary" style="border-left: 5px solid var(--kasa-primary);">
                    <div class="result-card-label">
                        <i class="fas fa-landmark"></i> Güne Ait Genel Kasa
                    </div>
                    <div class="result-card-value" style="font-size: 28px;">
                        @ResultVal("genel_kasa") <span class="money-currency">₺</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- ROW 2: Online Reddiyat + Bankadan Çıkan + Stopaj Kontrolü     -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <div class="row g-3 mb-3">
            <div class="col-md-4">
                <div class="result-card" style="border-left: 4px solid var(--kasa-secondary);">
                    <div class="result-card-label">
                        <i class="fas fa-arrow-circle-up" style="color: var(--kasa-secondary);"></i> Online Reddiyat
                    </div>
                    <div class="result-card-value" style="color: var(--kasa-secondary); font-size: 20px;">
                        @PoolVal("online_reddiyat") <span class="money-currency">₺</span>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="result-card" style="border-left: 4px solid var(--kasa-secondary);">
                    <div class="result-card-label">
                        <i class="fas fa-arrow-circle-down" style="color: var(--kasa-secondary);"></i> Bankadan Çıkan
                    </div>
                    <div class="result-card-value" style="color: var(--kasa-secondary); font-size: 20px;">
                        @PoolVal("bankadan_cikan_tahsilat") <span class="money-currency">₺</span>
                    </div>
                </div>
            </div>
            <!-- Stopaj Kontrol Kartı -->
            <div class="col-md-4">
                @{
                    var cesitliNedenlerle = Model.CesitliNedenlerleBankadanCikamayanTahsilat ?? 0m;
                    var isMesaiSonu = Model.AksamMesaiSonuModu;
                    var isSabahKasa = Model.KasaType?.Equals("Sabah", StringComparison.OrdinalIgnoreCase) == true;
                    // Gün bitmiş mi: Sabah kasa VEYA Akşam Tam Gün
                    var gunBitmis = isSabahKasa || !isMesaiSonu;
                    var trCulture = System.Globalization.CultureInfo.GetCultureInfo("tr-TR");
                }
                @if (sk_farkSifir)
                {
                    <!-- DURUM 1: Fark = 0 → Her senaryoda OK -->
                    <div class="kasa-alert kasa-alert-success" style="border-radius: var(--radius-md); margin: 0; height: 100%; display: flex; align-items: center;">
                        <i class="fas fa-check-circle" style="font-size: 22px;"></i>
                        <div>
                            <strong>Stopaj Kontrolü ✓</strong>
                            <div style="font-size: 11px;">Reddiyat − Banka Çıkış = 0</div>
                        </div>
                    </div>
                }
                else if (sk_farkStopajaDenk && !gunBitmis)
                {
                    <!-- DURUM 2: Fark = Stopaj + Mesai Sonu → OK, virman yapılacak -->
                    <div class="kasa-alert kasa-alert-success" style="border-radius: var(--radius-md); margin: 0; height: 100%; display: flex; align-items: center;">
                        <i class="fas fa-check-circle" style="font-size: 22px;"></i>
                        <div>
                            <strong>Stopaj Kontrolü ✓</strong>
                            <div style="font-size: 11px;">Reddiyat − Banka Çıkış = Stopaj</div>
                            <div style="font-size: 10px; color: #f59e0b; margin-top: 3px;">
                                <i class="fas fa-info-circle me-1"></i>Fark @sk_fark.ToString("N2", trCulture) ₺ (Stopaj kadar) — virman kasa sonrası yapılacak
                            </div>
                        </div>
                    </div>
                }
                else if (sk_farkStopajaDenk && gunBitmis)
                {
                    <!-- DURUM 3: Fark = Stopaj + Sabah/TamGün → Stopaj Virman Yapılmamış -->
                    <div class="kasa-alert kasa-alert-danger" style="border-radius: var(--radius-md); margin: 0; height: 100%; display: flex; flex-direction: column; justify-content: center;">
                        <div style="display: flex; align-items: center; gap: 10px;">
                            <i class="fas fa-exclamation-triangle" style="font-size: 22px;"></i>
                            <div>
                                <strong>Stopaj Virman Yapılmamış</strong>
                                <div style="font-size: 11px;">
                                    @(isSabahKasa ? "Bir önceki gün" : "Tam gün kasası: Gün") bitmiş, stopaj virmanı hâlâ bekliyor.
                                </div>
                            </div>
                        </div>
                        <div style="font-size: 12px; margin-top: 6px; padding: 4px 8px; background: rgba(239,68,68,0.08); border-radius: 4px;">
                            <i class="fas fa-coins me-1"></i> Virman Bekleyen: <strong>@sk_fark.ToString("N2", trCulture) ₺</strong>
                        </div>
                    </div>
                }
                else
                {
                    <!-- DURUM 4: Fark ≠ 0 ve ≠ Stopaj → Bilinmeyen uyuşmazlık -->
                    <div class="kasa-alert kasa-alert-danger" style="border-radius: var(--radius-md); margin: 0; height: 100%; display: flex; flex-direction: column; justify-content: center;">
                        <div style="display: flex; align-items: center; gap: 10px;">
                            <i class="fas fa-exclamation-triangle" style="font-size: 22px;"></i>
                            <div>
                                <strong>Stopaj Uyuşmazlığı</strong>
                                <div style="font-size: 11px;">Reddiyat ile Banka Çıkışı arasında stopaj dışında fark var.</div>
                            </div>
                        </div>
                        <div style="font-size: 12px; margin-top: 6px; padding: 4px 8px; background: rgba(239,68,68,0.08); border-radius: 4px;">
                            Fark: <strong>@sk_fark.ToString("N2", trCulture) ₺</strong>
                            <span style="font-size: 10px; color: var(--text-muted); margin-left: 8px;">(Stopaj: @sk_toplamStopaj.ToString("N2", trCulture) ₺)</span>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- ROW 2.5: Çeşitli Nedenlerle Bankadan Çıkamayan Tahsilat       -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        @if (cesitliNedenlerle > 0.01m)
        {
            <div class="row g-3 mb-3">
                <div class="col-12">
                    <div class="kasa-alert" style="border-radius: var(--radius-md); margin: 0; border: 2px solid #f59e0b; background: rgba(245,158,11,0.04); display: flex; align-items: center; gap: 14px; padding: 14px 20px;">
                        <i class="fas fa-hourglass-half" style="font-size: 24px; color: #f59e0b;"></i>
                        <div style="flex: 1;">
                            <strong style="color: #f59e0b;">Ç.N. Bankadan Çıkamayan Tahsilat</strong>
                            <div style="font-size: 11px; color: var(--text-muted); margin-top: 2px;">
                                Bankaya çıkması için talimat verilmiş ancak henüz çıkamamış tutar. Sonraki günlerde çıkacaktır.
                                Bu değer <strong>Genel Kasa</strong> hesaplamasına dahil edilmiştir.
                            </div>
                        </div>
                        <div style="text-align: right;">
                            <div style="font-size: 22px; font-weight: 700; color: #f59e0b;">
                                @cesitliNedenlerle.ToString("N2", System.Globalization.CultureInfo.GetCultureInfo("tr-TR")) <span style="font-size: 14px;">₺</span>
                            </div>
                            <div style="font-size: 10px; color: var(--text-muted);">Kullanıcı girişi</div>
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- ROW 3: BANKAYA GÖTÜRÜLECEK (Grup Kart)                         -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <div class="row g-3 mb-3">
            <div class="col-12">
                <div class="kasa-card" style="border: 2px solid var(--kasa-success); border-radius: var(--radius-md); overflow: hidden;">
                    <div class="kasa-card-header" style="background: rgba(16,185,129,0.06); padding: 14px 20px;">
                        <h6 class="mb-0" style="color: var(--kasa-success); font-weight: 700; font-size: 16px;">
                            <i class="fas fa-university me-2"></i>Bankaya Götürülecek
                        </h6>
                    </div>
                    <div class="kasa-card-body" style="padding: 0;">

                        @* ── STOPAJ ── *@
                        <div style="padding: 14px 20px; border-bottom: 1px solid var(--border-light); background: rgba(249,115,22,0.03);">
                            <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 6px;">
                                <div style="font-size: 13px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.6px; color: var(--text-muted);">
                                    <i class="fas fa-receipt me-1" style="color: var(--kasa-secondary);"></i> Stopaj
                                </div>
                                <div class="money-value" style="font-size: 24px; font-weight: 800;">
                                    @ResultVal("toplam_stopaj") <span class="money-currency">₺</span>
                                </div>
                            </div>
                            @{
                                var virmanTahsilat = ResultValRaw("banka_virman_tahsilat");
                                var stopajVal = ResultValRaw("toplam_stopaj");
                            }
                            @if (stopajVal != 0)
                            {
                                var virmanFark = stopajVal - virmanTahsilat;
                                var virmanOk = Math.Abs(virmanFark) < 0.50m;
                                <div style="padding: 3px 10px; font-size: 12px; display: flex; align-items: center; gap: 6px;">
                                    <i class="fas @(virmanOk ? "fa-check-circle text-success" : "fa-exclamation-triangle text-danger")" style="font-size: 13px;"></i>
                                    <span style="color: var(--text-muted);">
                                        @if (virmanOk)
                                        {
                                            <text>Virman doğru yatırılmıştır ✅</text>
                                        }
                                        else if (virmanTahsilat == 0)
                                        {
                                            <span class="text-danger">Bankada Virman kaydı bulunamadı</span>
                                        }
                                        else
                                        {
                                            <text>Bankada Virman: <strong>@MuhFmt(virmanTahsilat) ₺</strong></text>
                                            <span class="text-danger ms-1">(Fark: @MuhFmt(virmanFark) ₺)</span>
                                        }
                                    </span>
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(Model.IbanStopaj))
                            {
                                <div onclick="KasaIBAN.copy('@Model.IbanStopaj')" title="Kopyalamak için tıklayın"
                                     style="cursor: pointer; display: flex; align-items: center; gap: 10px; padding: 6px 10px; border-radius: 6px; background: rgba(249,115,22,0.06); transition: background 0.15s;">
                                    <i class="fas fa-university" style="color: var(--kasa-secondary); font-size: 13px;"></i>
                                    <span style="font-size: 13px; font-weight: 600; color: var(--text-secondary);">@(Model.HesapAdiStopaj ?? "Stopaj Hesabı")</span>
                                    <span style="font-family: 'JetBrains Mono', monospace; font-size: 13px; font-weight: 600; letter-spacing: 1px; color: var(--kasa-primary);">@FormatIban(Model.IbanStopaj)</span>
                                    <i class="fas fa-copy" style="font-size: 12px; color: var(--text-muted); margin-left: auto;"></i>
                                </div>
                            }
                        </div>

                        @* ── TAHSİLAT ── *@
                        <div style="padding: 14px 20px; border-bottom: 1px solid var(--border-light); background: rgba(16,185,129,0.03);">
                            <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 6px;">
                                <div style="font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.6px; color: var(--text-muted);">
                                    <i class="fas fa-hand-holding-usd me-1" style="color: var(--kasa-success);"></i> Bankaya Yatırılacak Tahsilat
                                </div>
                                <div class="money-value" style="font-size: 20px; font-weight: 800;">
                                    @ResultVal("bankaya_yatirilacak_tahsilat") <span class="money-currency">₺</span>
                                </div>
                            </div>
                            @{
                                var mevduatTahsilat = ResultValRaw("banka_mevduat_tahsilat");
                                var bankayaTahsilatVal = ResultValRaw("bankaya_yatirilacak_tahsilat");
                            }
                            @if (bankayaTahsilatVal != 0)
                            {
                                var tahsilatFark = bankayaTahsilatVal - mevduatTahsilat;
                                var tahsilatOk = Math.Abs(tahsilatFark) < 0.50m;
                                <div style="padding: 3px 10px; font-size: 10px; display: flex; align-items: center; gap: 6px;">
                                    <i class="fas @(tahsilatOk ? "fa-check-circle text-success" : "fa-exclamation-triangle text-danger")" style="font-size: 11px;"></i>
                                    <span style="color: var(--text-muted);">
                                        @if (tahsilatOk)
                                        {
                                            <text>Mevduata Para Yatırma doğru yatırılmıştır ✅</text>
                                        }
                                        else if (mevduatTahsilat == 0)
                                        {
                                            <span class="text-danger">Bankada Mevduata Para Yatırma kaydı bulunamadı</span>
                                        }
                                        else
                                        {
                                            <text>Bankada Mevduat: <strong>@MuhFmt(mevduatTahsilat) ₺</strong></text>
                                            <span class="text-danger ms-1">(Fark: @MuhFmt(tahsilatFark) ₺)</span>
                                        }
                                    </span>
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(Model.IbanMasraf))
                            {
                                <div onclick="KasaIBAN.copy('@Model.IbanMasraf')" title="Kopyalamak için tıklayın"
                                     style="cursor: pointer; display: flex; align-items: center; gap: 10px; padding: 6px 10px; border-radius: 6px; background: rgba(16,185,129,0.06); transition: background 0.15s;">
                                    <i class="fas fa-university" style="color: var(--kasa-success); font-size: 13px;"></i>
                                    <span style="font-size: 13px; font-weight: 600; color: var(--text-secondary);">@(Model.HesapAdiMasraf ?? "Tahsilat Hesabı")</span>
                                    <span style="font-family: 'JetBrains Mono', monospace; font-size: 13px; font-weight: 600; letter-spacing: 1px; color: var(--kasa-primary);">@FormatIban(Model.IbanMasraf)</span>
                                    <i class="fas fa-copy" style="font-size: 12px; color: var(--text-muted); margin-left: auto;"></i>
                                </div>
                            }
                        </div>

                        @* ── HARÇ ── *@
                        <div style="padding: 14px 20px; border-bottom: 1px solid var(--border-light); background: rgba(245,158,11,0.03);">
                            <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 6px;">
                                <div style="font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.6px; color: var(--text-muted);">
                                    <i class="fas fa-gavel me-1" style="color: var(--kasa-warning);"></i> Bankaya Yatırılacak Harç
                                </div>
                                <div class="money-value" style="font-size: 20px; font-weight: 800;">
                                    @ResultVal("bankaya_yatirilacak_harc") <span class="money-currency">₺</span>
                                </div>
                            </div>
                            @{
                                var mevduatHarc = ResultValRaw("banka_mevduat_harc");
                                var bankayaHarcVal = ResultValRaw("bankaya_yatirilacak_harc");
                            }
                            @if (bankayaHarcVal != 0)
                            {
                                var harcFark = bankayaHarcVal - mevduatHarc;
                                var harcOk = Math.Abs(harcFark) < 0.50m;
                                <div style="padding: 3px 10px; font-size: 10px; display: flex; align-items: center; gap: 6px;">
                                    <i class="fas @(harcOk ? "fa-check-circle text-success" : "fa-exclamation-triangle text-danger")" style="font-size: 11px;"></i>
                                    <span style="color: var(--text-muted);">
                                        @if (harcOk)
                                        {
                                            <text>Mevduata Para Yatırma doğru yatırılmıştır ✅</text>
                                        }
                                        else if (mevduatHarc == 0)
                                        {
                                            <span class="text-danger">Bankada Mevduata Para Yatırma kaydı bulunamadı</span>
                                        }
                                        else
                                        {
                                            <text>Bankada Mevduat: <strong>@MuhFmt(mevduatHarc) ₺</strong></text>
                                            <span class="text-danger ms-1">(Fark: @MuhFmt(harcFark) ₺)</span>
                                        }
                                    </span>
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(Model.IbanHarc))
                            {
                                <div onclick="KasaIBAN.copy('@Model.IbanHarc')" title="Kopyalamak için tıklayın"
                                     style="cursor: pointer; display: flex; align-items: center; gap: 10px; padding: 6px 10px; border-radius: 6px; background: rgba(245,158,11,0.06); transition: background 0.15s;">
                                    <i class="fas fa-university" style="color: var(--kasa-warning); font-size: 13px;"></i>
                                    <span style="font-size: 13px; font-weight: 600; color: var(--text-secondary);">@(Model.HesapAdiHarc ?? "Harç Hesabı")</span>
                                    <span style="font-family: 'JetBrains Mono', monospace; font-size: 13px; font-weight: 600; letter-spacing: 1px; color: var(--kasa-primary);">@FormatIban(Model.IbanHarc)</span>
                                    <i class="fas fa-copy" style="font-size: 12px; color: var(--text-muted); margin-left: auto;"></i>
                                </div>
                            }
                        </div>

                        <!-- TOPLAM — vurgulu -->
                        <div style="padding: 16px 20px; background: linear-gradient(135deg, rgba(16,185,129,0.08) 0%, rgba(16,185,129,0.03) 100%); border-top: 2px solid var(--kasa-success); display: flex; align-items: center; justify-content: space-between;">
                            <div style="font-size: 15px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.8px; color: var(--kasa-success);">
                                <i class="fas fa-arrow-right me-2"></i>Bankaya Götürülecek Toplam
                            </div>
                            <div class="money-value" style="font-size: 30px; font-weight: 800; color: var(--kasa-success);">
                                @ResultVal("bankaya_yatirilacak_toplam") <span class="money-currency">₺</span>
                            </div>
                        </div>

                        <!-- Kasa & Banka Detay Kartları — 4-grid vurgulu -->
                        @{
                            var kasadakiNakit = ResultValRaw("genel_kasa");
                            var bankadanCekilenVal = ResultValRaw("bankadan_cekilen");
                            var dundenDevredenBanka = ResultValRaw("banka_devreden_tahsilat");
                            var yarinaDevredecekBanka = ResultValRaw("banka_yarina_devredecek_tahsilat");
                            var bankayaTahsilatNegatif = ResultValRaw("bankaya_yatirilacak_tahsilat") < 0;
                        }
                        <div style="border-top: 1px solid var(--border-light); padding: 16px 20px; background: rgba(8,145,178,0.02);">
                            <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px;">
                                <!-- Kasadaki Nakit -->
                                <div style="padding: 14px 16px; background: rgba(16,185,129,0.06); border-radius: 8px; border-left: 4px solid var(--kasa-success);">
                                    <div style="font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; color: var(--text-muted); margin-bottom: 6px;">
                                        <i class="fas fa-coins" style="color: var(--kasa-success); margin-right: 4px;"></i>Kasadaki Nakit
                                    </div>
                                    <div style="font-size: 20px; font-weight: 800; color: var(--kasa-success);">
                                        @kasadakiNakit.ToString("N2", System.Globalization.CultureInfo.GetCultureInfo("tr-TR")) <span class="money-currency" style="font-size: 14px;">₺</span>
                                    </div>
                                </div>
                                <!-- Bankadan Çekilen — her zaman görünür, amber vurgu -->
                                <div style="padding: 14px 16px; background: @(bankadanCekilenVal > 0 ? "rgba(245,158,11,0.12)" : "rgba(245,158,11,0.04)"); border-radius: 8px; border-left: 4px solid var(--kasa-warning);">
                                    <div style="font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; color: var(--text-muted); margin-bottom: 6px;">
                                        <i class="fas fa-university" style="color: var(--kasa-warning); margin-right: 4px;"></i>Bankadan Çekilen
                                    </div>
                                    <div style="font-size: 20px; font-weight: 800; color: @(bankadanCekilenVal > 0 ? "var(--kasa-warning)" : "var(--text-muted)");">
                                        @if (bankadanCekilenVal > 0)
                                        {
                                            @bankadanCekilenVal.ToString("N2", System.Globalization.CultureInfo.GetCultureInfo("tr-TR")) <span class="money-currency" style="font-size: 14px;">₺</span>
                                        }
                                        else
                                        {
                                            <span style="font-size: 14px; opacity: 0.5;">Çekim yok</span>
                                        }
                                    </div>
                                </div>
                                <!-- Dünden Devreden Banka -->
                                <div style="padding: 14px 16px; background: rgba(8,145,178,0.06); border-radius: 8px; border-left: 4px solid var(--kasa-info);">
                                    <div style="font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; color: var(--text-muted); margin-bottom: 6px;">
                                        <i class="fas fa-arrow-left" style="color: var(--kasa-info); margin-right: 4px;"></i>Dünden Devreden
                                    </div>
                                    <div style="font-size: 20px; font-weight: 800; color: var(--kasa-info);">
                                        @dundenDevredenBanka.ToString("N2", System.Globalization.CultureInfo.GetCultureInfo("tr-TR")) <span class="money-currency" style="font-size: 14px;">₺</span>
                                    </div>
                                </div>
                                <!-- Yarına Devredecek Banka -->
                                <div style="padding: 14px 16px; background: rgba(99,102,241,0.06); border-radius: 8px; border-left: 4px solid var(--kasa-primary);">
                                    <div style="font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; color: var(--text-muted); margin-bottom: 6px;">
                                        <i class="fas fa-arrow-right" style="color: var(--kasa-primary); margin-right: 4px;"></i>Yarına Devredecek
                                    </div>
                                    <div style="font-size: 20px; font-weight: 800; color: var(--kasa-primary);">
                                        @yarinaDevredecekBanka.ToString("N2", System.Globalization.CultureInfo.GetCultureInfo("tr-TR")) <span class="money-currency" style="font-size: 14px;">₺</span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- ═══════ Banka Yazıları — Collapsible 4 Butonlu Grid ═══════ -->
                        <div style="border-top: 1px solid var(--border-light);" x-data="{ bankaOpen: false }">
                            <button type="button" @@click="bankaOpen = !bankaOpen"
                                    style="width: 100%; padding: 10px 20px; background: rgba(8,145,178,0.02); border: none; cursor: pointer; display: flex; align-items: center; justify-content: space-between; transition: background 0.15s;"
                                    onmouseover="this.style.background='rgba(8,145,178,0.06)'" onmouseout="this.style.background='rgba(8,145,178,0.02)'">
                                <div style="font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; color: var(--text-muted);">
                                    <i class="fas fa-file-pdf me-1" style="color: var(--kasa-info);"></i>Banka Belgeleri İndir
                                    <span style="font-size: 11px; font-weight: 500; opacity: 0.6; margin-left: 4px;">(4 belge)</span>
                                </div>
                                <i class="fas fa-chevron-down" style="font-size: 9px; color: var(--text-muted); transition: transform 0.2s;"
                                   :style="bankaOpen ? 'transform: rotate(180deg)' : ''"></i>
                            </button>
                            <div x-show="bankaOpen" x-transition.duration.200ms style="padding: 0 20px 14px 20px;">
                            <!-- Muhabere No giriş alanı -->
                            <div style="margin-bottom: 10px; margin-top: 6px; padding: 10px 14px; background: rgba(99,102,241,0.04); border: 1px dashed rgba(99,102,241,0.2); border-radius: 8px; display: flex; align-items: center; gap: 10px;">
                                <div style="display: flex; align-items: center; gap: 6px; flex-shrink: 0;">
                                    <i class="fas fa-hashtag" style="color: var(--kasa-primary); font-size: 12px;"></i>
                                    <label for="muhabereNoInput" style="font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.4px; color: var(--text-muted); white-space: nowrap; margin: 0;">Muhabere No</label>
                                </div>
                                <input type="text" id="muhabereNoInput"
                                       style="flex: 1; padding: 6px 10px; font-size: 12px; font-weight: 600; border: 1px solid rgba(99,102,241,0.2); border-radius: 6px; background: var(--card-bg); color: var(--text-primary); outline: none; transition: border-color 0.2s; font-family: 'JetBrains Mono', monospace; letter-spacing: 0.5px;"
                                       placeholder="Ör: 2026/0001"
                                       onfocus="this.style.borderColor='var(--kasa-primary)'"
                                       onblur="this.style.borderColor='rgba(99,102,241,0.2)'"
                                       oninput="document.querySelectorAll('.muhabereNoHidden').forEach(el => el.value = this.value)" />
                                <span style="font-size: 9px; color: var(--text-muted); white-space: nowrap; opacity: 0.7;">opsiyonel</span>
                            </div>
                            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 8px;">
                                <!-- 1. Banka Fişi -->
                                <form asp-controller="KasaPreview" asp-action="DownloadBankaFisi" method="post" style="margin: 0;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" asp-for="SelectedDate" />
                                    <input type="hidden" asp-for="KasaType" />
                                    <input type="hidden" asp-for="KasayiYapan" />
                                    <input type="hidden" name="PdfStopaj" value="@ResultValRaw("toplam_stopaj").ToString(System.Globalization.CultureInfo.InvariantCulture)" />
                                    <input type="hidden" name="PdfTahsilat" value="@ResultValRaw("bankaya_yatirilacak_tahsilat").ToString(System.Globalization.CultureInfo.InvariantCulture)" />
                                    <input type="hidden" name="PdfHarc" value="@ResultValRaw("bankaya_yatirilacak_harc").ToString(System.Globalization.CultureInfo.InvariantCulture)" />
                                    <input type="hidden" name="PdfToplam" value="@ResultValRaw("bankaya_yatirilacak_toplam").ToString(System.Globalization.CultureInfo.InvariantCulture)" />
                                    <input type="hidden" name="PdfKasadakiNakit" value="@ResultValRaw("genel_kasa").ToString(System.Globalization.CultureInfo.InvariantCulture)" />
                                    <input type="hidden" name="PdfDevredenBanka" value="@ResultValRaw("banka_devreden_tahsilat").ToString(System.Globalization.CultureInfo.InvariantCulture)" />
                                    <input type="hidden" name="PdfDevredecekBanka" value="@ResultValRaw("banka_yarina_devredecek_tahsilat").ToString(System.Globalization.CultureInfo.InvariantCulture)" />
                                    <button type="submit"
                                            style="width: 100%; padding: 10px 12px; border: 1px solid rgba(8,145,178,0.2); background: rgba(8,145,178,0.05); border-radius: 8px; cursor: pointer; display: flex; align-items: center; gap: 8px; transition: all 0.15s;"
                                            onmouseover="this.style.background='rgba(8,145,178,0.12)'; this.style.borderColor='rgba(8,145,178,0.35)'"
