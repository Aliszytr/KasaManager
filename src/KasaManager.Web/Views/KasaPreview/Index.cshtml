                                            <span style="font-size: 10px; color: var(--kasa-danger);"><i class="fas fa-exclamation-triangle"></i> Çıkışı onaylanmayan kayıt var</span>
                                        }
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                </div>
            </div>
        </div>

