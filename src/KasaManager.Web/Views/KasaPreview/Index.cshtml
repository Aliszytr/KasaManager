                <input type="hidden" name="RptGunlukNot" class="rpt-gunluk-not" value="" />
                @* ROW 1 *@
                <input type="hidden" name="RptDundenDevreden" value="@Inv(ResultValRaw("dunden_devreden_kasa_nakit"))" />
                <input type="hidden" name="RptGenelKasa" value="@Inv(ResultValRaw("genel_kasa"))" />
                @* ROW 2 *@
                <input type="hidden" name="RptOnlineReddiyat" value="@Inv(ResultValRaw("online_reddiyat"))" />
                <input type="hidden" name="RptBankadanCikan" value="@Inv(ResultValRaw("bankadan_cikan_tahsilat"))" />
                <input type="hidden" name="RptToplamStopaj" value="@Inv(ResultValRaw("toplam_stopaj"))" />
                <input type="hidden" name="RptStopajOk" value="@(stopajKontrolOk ? "true" : "false")" />
                <input type="hidden" name="RptStopajFark" value="@Inv(stopajKontrolRaw)" />
                @* ROW 3 — Bankaya Götürülecek *@
                <input type="hidden" name="RptBankayaStopaj" value="@Inv(ResultValRaw("toplam_stopaj"))" />
                <input type="hidden" name="RptBankayaTahsilat" value="@Inv(ResultValRaw("bankaya_yatirilacak_tahsilat"))" />
                <input type="hidden" name="RptBankayaHarc" value="@Inv(ResultValRaw("bankaya_yatirilacak_harc"))" />
                <input type="hidden" name="RptBankayaToplam" value="@Inv(ResultValRaw("bankaya_yatirilacak_toplam"))" />
                @* Devir *@
                <input type="hidden" name="RptKasadakiNakit" value="@Inv(ResultValRaw("genel_kasa"))" />
                <input type="hidden" name="RptDevredenBanka" value="@Inv(ResultValRaw("banka_devreden_tahsilat"))" />
                <input type="hidden" name="RptDevredecekBanka" value="@Inv(ResultValRaw("banka_yarina_devredecek_tahsilat"))" />
                @* Vergi *@
                <input type="hidden" name="RptVergidenGelen" value="@Inv(ResultValRaw("vergiden_gelen"))" />
                <input type="hidden" name="RptVergiKasa" value="@Inv(Model.VergiKasaBakiyeToplam)" />
                <input type="hidden" name="RptVergideBiriken" value="@Inv(Model.VergideBirikenKasa ?? 0m)" />
                <input type="hidden" name="RptVergiCalisanlari" value="@(string.Join(",", Model.VergiKasaVeznedarlar ?? new()))" />
                @* Beklenen Girişler *@
                <input type="hidden" name="RptEftIade" value="@Inv(ResultValRaw("eft_otomatik_iade"))" />
                <input type="hidden" name="RptGelenHavale" value="@Inv(ResultValRaw("gelen_havale"))" />
                <input type="hidden" name="RptIadeKelimesi" value="@Inv(ResultValRaw("iade_kelimesi_giris"))" />
                @* Eksik/Fazla *@
                <input type="hidden" name="RptEfGuneT" value="@Inv(Model.ToplamFarkTahsilat != 0 ? Model.ToplamFarkTahsilat : (Model.GuneAitEksikFazlaTahsilat ?? 0m))" />
                <input type="hidden" name="RptEfDundenT" value="@Inv(Model.DundenEksikFazlaTahsilat ?? 0m)" />
                <input type="hidden" name="RptEfGelenT" value="@Inv(Model.DundenEksikFazlaGelenTahsilat ?? 0m)" />
                <input type="hidden" name="RptEfGuneH" value="@Inv(Model.ToplamFarkHarc != 0 ? Model.ToplamFarkHarc : (Model.GuneAitEksikFazlaHarc ?? 0m))" />
                <input type="hidden" name="RptEfDundenH" value="@Inv(Model.DundenEksikFazlaHarc ?? 0m)" />
                <input type="hidden" name="RptEfGelenH" value="@Inv(Model.DundenEksikFazlaGelenHarc ?? 0m)" />
                <button type="submit" class="kasa-btn" style="background: linear-gradient(135deg, #1e88e5, #1565c0); color: white; border: none;">
                    <i class="fas fa-file-pdf me-1"></i> Genel Rapor İndir
                </button>
            </form>

            @* ── Özet Rapor İndir ── *@
            <form asp-controller="KasaPreview" asp-action="DownloadOzetRapor" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="SelectedDate" />
                <input type="hidden" asp-for="KasaType" />
                <input type="hidden" asp-for="KasayiYapan" />
                <input type="hidden" name="RptGunlukNot" class="rpt-gunluk-not" value="" />
                @* ROW 1 *@
                <input type="hidden" name="RptDundenDevreden" value="@Inv(ResultValRaw("dunden_devreden_kasa_nakit"))" />
                <input type="hidden" name="RptGenelKasa" value="@Inv(ResultValRaw("genel_kasa"))" />
                @* ROW 3 — Bankaya Götürülecek *@
                <input type="hidden" name="RptBankayaStopaj" value="@Inv(ResultValRaw("toplam_stopaj"))" />
                <input type="hidden" name="RptBankayaTahsilat" value="@Inv(ResultValRaw("bankaya_yatirilacak_tahsilat"))" />
                <input type="hidden" name="RptBankayaHarc" value="@Inv(ResultValRaw("bankaya_yatirilacak_harc"))" />
                <input type="hidden" name="RptBankayaToplam" value="@Inv(ResultValRaw("bankaya_yatirilacak_toplam"))" />
                @* Devir *@
                <input type="hidden" name="RptDevredenBanka" value="@Inv(ResultValRaw("banka_devreden_tahsilat"))" />
                <input type="hidden" name="RptDevredecekBanka" value="@Inv(ResultValRaw("banka_yarina_devredecek_tahsilat"))" />
                @* Vergi *@
                <input type="hidden" name="RptVergidenGelen" value="@Inv(ResultValRaw("vergiden_gelen"))" />
                <input type="hidden" name="RptVergiKasa" value="@Inv(Model.VergiKasaBakiyeToplam)" />
                <input type="hidden" name="RptVergideBiriken" value="@Inv(Model.VergideBirikenKasa ?? 0m)" />
                @* Eksik/Fazla *@
                <input type="hidden" name="RptEfGuneT" value="@Inv(Model.ToplamFarkTahsilat != 0 ? Model.ToplamFarkTahsilat : (Model.GuneAitEksikFazlaTahsilat ?? 0m))" />
                <input type="hidden" name="RptEfDundenT" value="@Inv(Model.DundenEksikFazlaTahsilat ?? 0m)" />
                <input type="hidden" name="RptEfGelenT" value="@Inv(Model.DundenEksikFazlaGelenTahsilat ?? 0m)" />
                <input type="hidden" name="RptEfGuneH" value="@Inv(Model.ToplamFarkHarc != 0 ? Model.ToplamFarkHarc : (Model.GuneAitEksikFazlaHarc ?? 0m))" />
                <input type="hidden" name="RptEfDundenH" value="@Inv(Model.DundenEksikFazlaHarc ?? 0m)" />
                <input type="hidden" name="RptEfGelenH" value="@Inv(Model.DundenEksikFazlaGelenHarc ?? 0m)" />
                <button type="submit" class="kasa-btn" style="background: linear-gradient(135deg, #43a047, #2e7d32); color: white; border: none;">
                    <i class="fas fa-file-pdf me-1"></i> Özet Rapor İndir
                </button>
            </form>

            @* ══════════════════════════════════════════════════════════════ *@
            @* ──  RAPOR YÖNETİMİ: In-Context CRUD Button Group               *@
            @* ══════════════════════════════════════════════════════════════ *@
            <div style="width: 2px; height: 32px; background: var(--border-light); margin: 0 4px;"></div>



            @* ── Kaydet ── *@
            <button type="button" id="btnOpenSaveModal" class="kasa-btn" style="background: linear-gradient(135deg, #f59e0b, #d97706); color: white; border: none; font-weight: 600; padding: 8px 16px; font-size: 12px; box-shadow: 0 2px 8px rgba(245,158,11,0.3);" title="Bu raporu veritabanına kaydet">
                <i class="fas fa-save me-1"></i> Kaydet
            </button>

            @* ── Raporları Aç/Kapat ── *@
            <button type="button" id="btnToggleReports" class="kasa-btn" style="background: linear-gradient(135deg, #6366f1, #4f46e5); color: white; border: none; font-weight: 600; padding: 8px 16px; font-size: 12px;" title="Kaydedilmiş raporları listele">
                <i class="fas fa-folder-open me-1"></i> Raporlar
                <i class="fas fa-chevron-down ms-1" id="reportsChevron" style="font-size:10px; transition: transform 0.3s;"></i>
            </button>

            @* ── Güncelle (sadece yüklü rapor varsa aktif) ── *@
            <button type="button" id="btnUpdateSnapshot" class="kasa-btn" style="background: linear-gradient(135deg, #10b981, #059669); color: white; border: none; font-weight: 600; padding: 8px 16px; font-size: 12px; opacity: @(Model.LoadedSnapshotId.HasValue ? "1" : "0.4"); pointer-events: @(Model.LoadedSnapshotId.HasValue ? "auto" : "none");" title="@(Model.LoadedSnapshotId.HasValue ? "Yüklü raporu güncelle" : "Önce rapor yüklemelisiniz")" @(Model.LoadedSnapshotId.HasValue ? "" : "disabled")>
                <i class="fas fa-sync-alt me-1"></i> Güncelle
            </button>

            @* ── Sil (sadece yüklü rapor varsa aktif) ── *@
            <button type="button" id="btnDeleteSnapshot" class="kasa-btn" style="background: linear-gradient(135deg, #ef4444, #dc2626); color: white; border: none; font-weight: 600; padding: 8px 16px; font-size: 12px; opacity: @(Model.LoadedSnapshotId.HasValue ? "1" : "0.4"); pointer-events: @(Model.LoadedSnapshotId.HasValue ? "auto" : "none");" title="@(Model.LoadedSnapshotId.HasValue ? "Yüklü raporu sil" : "Önce rapor yüklemelisiniz")" @(Model.LoadedSnapshotId.HasValue ? "" : "disabled")>
                <i class="fas fa-trash-alt me-1"></i> Sil
            </button>

        </div>

        @* ── İşlem İletileri Alanı (butonların hemen altında) ── *@
        <div id="actionAlertArea" style="margin-top:8px; margin-bottom:8px; display:none;"></div>

        @* ── TempData Server-Side Alerts ── *@
        @if (TempData["SuccessMessage"] is string sMsg2)
        {
            <div class="kasa-alert" style="border-left: 4px solid #10b981; background: rgba(16,185,129,0.08); padding: 10px 14px; border-radius: 8px; display: flex; align-items: center; gap: 10px; margin-bottom: 8px;">
                <i class="fas fa-check-circle" style="color: #10b981; font-size: 16px;"></i>
                <div style="font-size: 12px; font-weight: 600; color: #065f46;">@sMsg2</div>
            </div>
        }
        @if (TempData["ErrorMessage"] is string eMsg2)
        {
            <div class="kasa-alert" style="border-left: 4px solid #ef4444; background: rgba(239,68,68,0.08); padding: 10px 14px; border-radius: 8px; display: flex; align-items: center; gap: 10px; margin-bottom: 8px;">
                <i class="fas fa-times-circle" style="color: #ef4444; font-size: 16px;"></i>
                <div style="font-size: 12px; font-weight: 600; color: #991b1b;">@eMsg2</div>
            </div>
        }

        @* ── Yüklü Rapor Bilgi Çubuğu ── *@
        @if (Model.LoadedSnapshotId.HasValue)
        {
            <div id="loadedReportBar" style="margin-top: 10px; padding: 10px 16px; border-radius: 10px; background: linear-gradient(135deg, rgba(99,102,241,0.08), rgba(79,70,229,0.04)); border: 1px solid rgba(99,102,241,0.2); display: flex; align-items: center; gap: 10px; flex-wrap:wrap;">
                <div style="width:32px; height:32px; border-radius:8px; background:linear-gradient(135deg,#6366f1,#4f46e5); display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                    <i class="fas fa-file-alt" style="color:white; font-size:13px;"></i>
                </div>
                <div>
                    <div style="font-size:13px; font-weight:700; color:var(--text-primary, #111827);">
                        @Model.LoadedSnapshotName
                        <span style="font-size:11px; font-weight:500; color:var(--text-muted, #6b7280); margin-left:6px;">v@(Model.LoadedSnapshotVersion)</span>
                    </div>
                    <div style="font-size:11px; color:var(--text-muted, #6b7280);">Yüklü rapor — değişiklikleri "Güncelle" ile kaydedebilir veya "Sil" ile kaldırabilirsiniz</div>
                </div>
                <input type="hidden" id="loadedSnapshotId" value="@Model.LoadedSnapshotId" />
            </div>
        }

        @* ══════════════════════════════════════════════════════════════ *@
        @* ──  RAPORLAR PANELİ: Collapsible AJAX Report List           *@
        @* ══════════════════════════════════════════════════════════════ *@
        <div id="reportsPanel" style="display: none; margin-top: 12px; border-radius: 12px; border: 1px solid #d1d5db; background: #ffffff; overflow: hidden; box-shadow: 0 2px 12px rgba(0,0,0,0.08); transition: all 0.3s;">
            <div style="padding: 14px 18px; background: linear-gradient(135deg, #eef2ff, #e0e7ff); border-bottom: 1px solid #c7d2fe; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 8px;">
                <div style="display:flex; align-items:center; gap:8px;">
                    <i class="fas fa-database" style="color:#6366f1; font-size:14px;"></i>
                    <span style="font-size:13px; font-weight:700; color:#1e1b4b;">
                        Kayıtlı Raporlar
                        <span id="reportKasaTypeBadge" style="font-size:10px; font-weight:600; background:#6366f1; color:white; padding:2px 8px; border-radius:20px; margin-left:6px;">@(Model.KasaType ?? "Tümü")</span>
                    </span>
                </div>
                <div style="display:flex; align-items:center; gap:8px;">
                    <input type="date" id="reportSearchDate" style="font-size:11px; padding:4px 8px; border-radius:6px; border:1px solid #c7d2fe; background:#fff; color:#1e1b4b; width:130px;" title="Tarihe göre filtrele" />
                    <input type="text" id="reportSearchText" placeholder="Rapor ara..." style="font-size:11px; padding:4px 10px; border-radius:6px; border:1px solid #c7d2fe; background:#fff; color:#1e1b4b; width:140px;" />
                    <button type="button" id="btnSearchReports" style="font-size:11px; padding:4px 10px; border-radius:6px; background:linear-gradient(135deg,#6366f1,#4f46e5); color:white; border:none; cursor:pointer; font-weight:600;" title="Ara">
                        <i class="fas fa-search"></i>
                    </button>
                    <button type="button" id="btnClearSearch" style="font-size:11px; padding:4px 8px; border-radius:6px; background:#f5f3ff; color:#4338ca; border:1px solid #c7d2fe; cursor:pointer;" title="Filtreleri temizle">
                        <i class="fas fa-times"></i>
                    </button>
                    <span id="reportCountBadge" style="font-size:11px; color:#6366f1; font-weight:600;">Yükleniyor...</span>
                </div>
            </div>
            <div style="max-height: 300px; overflow-y: auto; background:#fff;">
                <table style="width:100%; border-collapse:collapse; font-size:12px;">
                    <thead>
                        <tr style="background:#f5f3ff; position:sticky; top:0; z-index:1;">
                            <th style="padding:8px 12px; text-align:left; font-weight:600; color:#4338ca; border-bottom:1px solid #c7d2fe;">Rapor Adı</th>
                            <th style="padding:8px 12px; text-align:center; font-weight:600; color:#4338ca; border-bottom:1px solid #c7d2fe; width:90px;">Tarih</th>
                            <th style="padding:8px 12px; text-align:center; font-weight:600; color:#4338ca; border-bottom:1px solid #c7d2fe; width:50px;">v</th>
                            <th style="padding:8px 12px; text-align:center; font-weight:600; color:#4338ca; border-bottom:1px solid #c7d2fe; width:80px;">Kayıt</th>
                            <th style="padding:8px 12px; text-align:center; font-weight:600; color:#4338ca; border-bottom:1px solid #c7d2fe; width:70px;"></th>
                        </tr>
                    </thead>
                    <tbody id="reportsTableBody">
                        <tr><td colspan="5" style="padding:20px; text-align:center; color:#6b7280;">Yükleniyor...</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="kasa-alert kasa-alert-info">
            <i class="fas fa-info-circle"></i>
            <div>Sonuç üretilmedi. Lütfen geçerli bir tarih ve veri seçtiğinizden emin olun.</div>
        </div>
    }
</div>
}

<!-- ═══════════════════════════════════════════════════════════════════ -->
<!-- Günlük Kasa Notu: Textarea → Hidden Input Sync                    -->
<!-- ═══════════════════════════════════════════════════════════════════ -->
<script>
(function() {
    // Her export formu submit edilmeden önce textarea değerini hidden input'lara kopyala
    document.addEventListener('submit', function(e) {
        // Sayfadaki tüm not textarea'larından değer al (Genel veya Sabah/Akşam hangisi varsa)
        var notInput = document.getElementById('kasaGunlukNot')
                    || document.getElementById('kasaGunlukNotSabahAksam');
        var notValue = notInput ? notInput.value : '';

        // Bu formda .rpt-gunluk-not sınıflı hidden input varsa değerini güncelle
        var hiddens = e.target.querySelectorAll('.rpt-gunluk-not');
        hiddens.forEach(function(h) { h.value = notValue; });
    });

    // ═══════════════════════════════════════════════════════════════════
    // File System Access API: "Farklı Kaydet" diyaloğu desteği
    // Chromium tabanlı tarayıcılarda (Chrome, Edge) çalışır.
    // Desteklenmeyen tarayıcılarda mevcut davranış (otomatik indirme) korunur.
    // ═══════════════════════════════════════════════════════════════════

    // Kasa tarih ve tür bilgisini formdan çıkar
    function getKasaInfo(form) {
        var dateInput = form.querySelector('input[name="SelectedDate"]');
        var typeInput = form.querySelector('input[name="KasaType"]');
        var dateVal = dateInput ? dateInput.value : '';
        var typeVal = typeInput ? typeInput.value : '';
        // DateOnly format: yyyy-MM-dd → dd.MM.yyyy
        var formattedDate = '';
        if (dateVal) {
            var parts = dateVal.split('-');
            if (parts.length === 3) {
                formattedDate = parts[2] + '.' + parts[1] + '.' + parts[0];
            } else {
                formattedDate = dateVal;
            }
        }
        return { date: formattedDate, type: typeVal || 'Kasa' };
    }

    // Kasa türünü Türkçe oku
    function kasaTuruLabel(type) {
        var t = (type || '').toLowerCase();
        if (t === 'sabah') return 'Sabah';
        if (t === 'aksam') return 'Aksam';
        if (t === 'genel') return 'Genel';
        return type || 'Kasa';
    }

    // Action'dan dosya tipi bilgisini çıkar
    function getSuggestedName(form) {
        var action = form.getAttribute('action') || '';
        var info = getKasaInfo(form);
        var kasaLabel = kasaTuruLabel(info.type);
        var prefix = info.date ? (info.date + ' Tarihli ' + kasaLabel + ' Kasa') : (kasaLabel + ' Kasa');

        if (action.indexOf('DownloadGenelRapor') !== -1)
            return { name: prefix + ' Genel Rapor.pdf', mime: 'application/pdf', ext: '.pdf' };
        if (action.indexOf('DownloadOzetRapor') !== -1)
            return { name: prefix + ' Ozet Rapor.pdf', mime: 'application/pdf', ext: '.pdf' };
        if (action.indexOf('DownloadBankaFisi') !== -1)
            return { name: prefix + ' Banka Fisi.pdf', mime: 'application/pdf', ext: '.pdf' };
        if (action.indexOf('DownloadBankaYazisi') !== -1) {
            var yaziTipi = form.querySelector('input[name="yaziTipi"]');
            var yaziLabel = yaziTipi ? yaziTipi.value : 'Yazisi';
            return { name: prefix + ' Banka ' + yaziLabel + '.pdf', mime: 'application/pdf', ext: '.pdf' };
        }
        if (action.indexOf('DownloadJson') !== -1)
            return { name: prefix + ' Veri.json', mime: 'application/json', ext: '.json' };
        if (action.indexOf('/Export') !== -1) {
            var formatInput = form.querySelector('input[name="format"]');
            var formatVal = formatInput ? formatInput.value : '';
            if (formatVal === '3') // Excel
                return { name: prefix + ' Rapor.xlsx', mime: 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet', ext: '.xlsx' };
            if (formatVal === '4') // CSV
                return { name: prefix + ' Rapor.csv', mime: 'text/csv', ext: '.csv' };
        }
        return null; // Tanınmayan form — normal davranış
    }

    // showSaveFilePicker desteği var mı?
    var hasSaveFilePicker = typeof window.showSaveFilePicker === 'function';

    if (hasSaveFilePicker) {
        // Export formlarını intercept et
        document.addEventListener('submit', function(e) {
            var form = e.target;
            var suggested = getSuggestedName(form);
            if (!suggested) return; // Bu form export formu değil, normal devam et

            e.preventDefault(); // Normal submit'i durdur

            // Form verilerini hazırla
            var formData = new FormData(form);
            var actionUrl = form.getAttribute('action');

            // Buton durumunu göster
            var submitBtn = form.querySelector('button[type="submit"]');
            var originalBtnHTML = submitBtn ? submitBtn.innerHTML : '';
            if (submitBtn) {
                submitBtn.disabled = true;
                submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i>Hazırlanıyor...';
            }

            // Fetch ile dosyayı al
            fetch(actionUrl, {
                method: 'POST',
                body: formData,
                credentials: 'same-origin'
            })
            .then(function(response) {
                if (!response.ok) throw new Error('Sunucu hatası: ' + response.status);
                return response.blob();
            })
            .then(function(blob) {
                // Farklı Kaydet diyaloğu
                var fileTypes = [];
                if (suggested.ext === '.pdf') {
                    fileTypes.push({ description: 'PDF Belgesi', accept: { 'application/pdf': ['.pdf'] } });
                } else if (suggested.ext === '.xlsx') {
                    fileTypes.push({ description: 'Excel Belgesi', accept: { 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet': ['.xlsx'] } });
                } else if (suggested.ext === '.csv') {
                    fileTypes.push({ description: 'CSV Dosyası', accept: { 'text/csv': ['.csv'] } });
                } else if (suggested.ext === '.json') {
                    fileTypes.push({ description: 'JSON Dosyası', accept: { 'application/json': ['.json'] } });
                }

                return window.showSaveFilePicker({
                    suggestedName: suggested.name,
                    types: fileTypes
                }).then(function(handle) {
                    return handle.createWritable().then(function(writable) {
                        return writable.write(blob).then(function() {
                            return writable.close();
                        });
                    });
                });
            })
            .then(function() {
                // Başarılı kayıt bildirimi
                if (submitBtn) {
                    submitBtn.innerHTML = '<i class="fas fa-check me-1"></i>Kaydedildi!';
                    submitBtn.style.background = 'rgba(16,185,129,0.15)';
                    submitBtn.style.color = '#059669';
                    setTimeout(function() {
                        submitBtn.innerHTML = originalBtnHTML;
                        submitBtn.disabled = false;
                        submitBtn.style.background = '';
                        submitBtn.style.color = '';
                    }, 2000);
                }
            })
            .catch(function(err) {
                // Kullanıcı iptal ettiyse (AbortError) sessizce devam et
                if (err && err.name === 'AbortError') {
                    if (submitBtn) {
                        submitBtn.innerHTML = originalBtnHTML;
                        submitBtn.disabled = false;
                    }
                    return;
                }

                // Gerçek hata — fallback olarak normal indirme yap
                console.warn('Farklı Kaydet başarısız, normal indirme yapılıyor:', err);
                if (submitBtn) {
                    submitBtn.innerHTML = originalBtnHTML;
                    submitBtn.disabled = false;
                }
                // Normal form submit ile devam et (fallback)
                form.submit();
            });
        }, true); // capture phase — ilk bizim listener çalışsın
    }
})();
</script>

<!-- ═══════════════════════════════════════════════════════════════════ -->
<!-- Negatif Tahsilat Tespit Modalı — Bankadan Çekme Önerisi           -->
<!-- ═══════════════════════════════════════════════════════════════════ -->
@{
    decimal negatifTahsilatDeger = 0m;
    if (Model.FormulaRun?.Outputs != null && Model.FormulaRun.Outputs.TryGetValue("bankaya_yatirilacak_tahsilat", out var _ntVal))
    {
        negatifTahsilatDeger = _ntVal;
    }
    var tahsilatNegatifMi = negatifTahsilatDeger < 0 && Model.HasResults;
    var oneriBankadanCekilecek = Math.Abs(negatifTahsilatDeger);
}
@if (tahsilatNegatifMi)
{
<div id="bankadanCekmeModal" style="position:fixed; inset:0; z-index:9999; background:rgba(0,0,0,0.55); backdrop-filter:blur(5px); display:flex; align-items:center; justify-content:center;">
    <div style="background:var(--card-bg, white); border-radius:16px; box-shadow:0 20px 60px rgba(0,0,0,0.3); max-width:520px; width:92%; overflow:hidden; animation: modalFadeIn 0.3s ease-out;">
        <!-- Header -->
        <div style="padding:20px 24px; background:linear-gradient(135deg, rgba(245,158,11,0.15) 0%, rgba(239,68,68,0.08) 100%); border-bottom:2px solid var(--kasa-warning);">
            <div style="display:flex; align-items:center; gap:12px;">
                <div style="width:44px; height:44px; border-radius:12px; background:rgba(245,158,11,0.2); display:flex; align-items:center; justify-content:center;">
                    <i class="fas fa-exclamation-triangle" style="font-size:20px; color:var(--kasa-warning);"></i>
                </div>
                <div>
                    <div style="font-size:16px; font-weight:800; color:var(--text-primary);">Bankadan Para Çekme Gerekli</div>
                    <div style="font-size:11px; color:var(--text-muted); margin-top:2px;">Nakit bakiye yetersiz — otomatik tespit</div>
                </div>
            </div>
        </div>
        <!-- Body -->
        <div style="padding:20px 24px;">
            <p style="font-size:13px; color:var(--text-secondary); line-height:1.6; margin:0 0 16px 0;">
                Elimizdeki toplam nakit miktarı ödemelerden az olduğu için bankadan para çekme işlemi yapılması gerekmektedir.
            </p>
            <!-- Negatif değer uyarısı -->
            <div style="padding:12px 16px; background:rgba(239,68,68,0.08); border-radius:10px; border-left:3px solid var(--kasa-danger); margin-bottom:16px;">
                <div style="font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:0.5px; color:var(--kasa-danger); margin-bottom:4px;">
                    <i class="fas fa-arrow-down me-1"></i>Bankaya Yatırılacak Tahsilat (Negatif)
                </div>
                <div style="font-size:22px; font-weight:800; color:var(--kasa-danger);">
                    @negatifTahsilatDeger.ToString("N2", System.Globalization.CultureInfo.GetCultureInfo("tr-TR")) <span class="money-currency" style="font-size:13px;">₺</span>
                </div>
            </div>
            <!-- Öneri ve düzenlenebilir input -->
            <div style="padding:14px 16px; background:rgba(16,185,129,0.06); border-radius:10px; border:1px solid rgba(16,185,129,0.2);">
                <label style="display:block; font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.5px; color:var(--text-muted); margin-bottom:8px;">
                    <i class="fas fa-university me-1" style="color:var(--kasa-warning);"></i>Bankadan Çekilecek Tutar
                </label>
                <div style="display:flex; align-items:center; gap:8px;">
                    <input type="number" id="bankadanCekmeTutar" step="0.01" min="0"
                           value="@oneriBankadanCekilecek.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)"
                           style="flex:1; padding:10px 14px; font-size:18px; font-weight:700; border:2px solid var(--kasa-success); border-radius:8px; background:var(--input-bg, white); color:var(--text-primary); text-align:right;" />
                    <span style="font-size:14px; font-weight:700; color:var(--text-muted);">₺</span>
                </div>
                <div style="font-size:10px; color:var(--text-muted); margin-top:6px;">
                    <i class="fas fa-info-circle me-1"></i>Önerilen minimum tutar: <strong>@oneriBankadanCekilecek.ToString("N2", System.Globalization.CultureInfo.GetCultureInfo("tr-TR")) ₺</strong>
                    — İsterseniz daha yüksek bir tutar girebilirsiniz (ör. kasada nakit kalması için).
                </div>
            </div>
        </div>
        <!-- Footer -->
        <div style="padding:14px 24px; border-top:1px solid var(--border-light); display:flex; justify-content:flex-end; gap:10px; background:rgba(0,0,0,0.02);">
            <button type="button" onclick="document.getElementById('bankadanCekmeModal').style.display='none'"
                    style="padding:8px 20px; border-radius:8px; border:1px solid var(--border-light); background:transparent; color:var(--text-secondary); font-size:13px; font-weight:600; cursor:pointer;">
                <i class="fas fa-times me-1"></i>Şimdilik Geç
            </button>
            <button type="button" id="bankadanCekmeOnayla"
                    style="padding:8px 24px; border-radius:8px; border:none; background:linear-gradient(135deg, var(--kasa-warning), #d97706); color:white; font-size:13px; font-weight:700; cursor:pointer; box-shadow:0 4px 12px rgba(245,158,11,0.3);">
                <i class="fas fa-check me-1"></i>Evet, Girişi Yap ve Yeniden Hesapla
            </button>
        </div>
    </div>
</div>
<style>
    @@keyframes modalFadeIn {
        from { opacity: 0; transform: scale(0.95); }
        to   { opacity: 1; transform: scale(1); }
    }
</style>
<script>
(function() {
    var btn = document.getElementById('bankadanCekmeOnayla');
    if (!btn) return;
    btn.addEventListener('click', function() {
        var tutar = parseFloat(document.getElementById('bankadanCekmeTutar').value) || 0;
        if (tutar <= 0) { alert('Lütfen geçerli bir tutar girin.'); return; }
        // BankadanCekilen input'unu bul ve doldur
        var input = document.querySelector('input[name="BankadanCekilen"]');
        if (input) {
            input.value = tutar.toFixed(2);
        }
        // Modalı kapat
        document.getElementById('bankadanCekmeModal').style.display = 'none';
        // Hesapla formunu submit et
        var form = input ? input.closest('form') : null;
        if (form) {
            form.submit();
        }
    });
})();
</script>
}

