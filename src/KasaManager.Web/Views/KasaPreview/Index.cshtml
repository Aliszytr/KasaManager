        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- ROW 4: Vergi Bilgileri (Vergiden Gelen + Vergi Kasa + Vergide  -->
        <!--         Biriken + Vergi Çalışanları)                           -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <div class="row g-3 mb-3">
            <div class="col-md-3">
                <div class="result-card result-card-warning" style="height: 100%;">
                    <div class="result-card-label">
                        <i class="fas fa-hand-holding-usd"></i> Vergiden Gelen
                    </div>
                    <div class="result-card-value" style="font-size: 20px;">
                        @PoolVal("vergiden_gelen") <span class="money-currency">₺</span>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="result-card result-card-warning" style="height: 100%;">
                    <div class="result-card-label">
                        <i class="fas fa-cash-register"></i> Vergi Kasa (bugünkü)
                    </div>
                    <div class="result-card-value" style="font-size: 20px;">
                        @(Model.VergiKasaBakiyeToplam.ToString("N2", System.Globalization.CultureInfo.GetCultureInfo("tr-TR"))) <span class="money-currency">₺</span>
                    </div>
                </div>
            </div>
            @{
                var vbSeed = ViewData["VergideBirikenSeed"] is decimal s ? s : 0m;
                var vbTVK = ViewData["VergideBirikenTotalVergiKasa"] is decimal tvk ? tvk : 0m;
                var vbTVG = ViewData["VergideBirikenTotalVergidenGelen"] is decimal tvg ? tvg : 0m;
                var vbCount = ViewData["VergideBirikenSnapshotCount"] is int c ? c : 0;
                var vbLastDate = ViewData["VergideBirikenLastDate"] as DateOnly?;
                var vbTooltip = $"İlk Seed: {vbSeed:N2} ₺\n+ Σ Vergi Kasa: {vbTVK:N2} ₺\n− Σ Vergiden Gelen: {vbTVG:N2} ₺\n= Vergide Biriken: {(Model.VergideBirikenKasa ?? 0m):N2} ₺\n({vbCount} kayıtlı kasa)";
            }
            <div class="col-md-3">
                <div class="result-card" style="border-left: 4px solid var(--kasa-warning); height: 100%;" title="@vbTooltip">
                    <div class="result-card-label">
                        <i class="fas fa-piggy-bank"></i> Vergide Biriken Kasa
                        <i class="fas fa-info-circle ms-1" style="font-size: 10px; opacity: 0.6; cursor: help;" title="@vbTooltip"></i>
                    </div>
                    <div class="result-card-value" style="font-size: 20px;">
                        @(Model.VergideBirikenKasa?.ToString("N2", System.Globalization.CultureInfo.GetCultureInfo("tr-TR")) ?? "—") <span class="money-currency">₺</span>
                    </div>
                    @if (vbCount > 0)
                    {
                        <div style="font-size: 10px; color: var(--text-muted); margin-top: 4px; line-height: 1.4;">
                            <span style="opacity: 0.7;">Seed: @vbSeed.ToString("N2", System.Globalization.CultureInfo.GetCultureInfo("tr-TR"))</span>
                            <span style="color: var(--kasa-success); margin-left: 4px;">+@vbTVK.ToString("N2", System.Globalization.CultureInfo.GetCultureInfo("tr-TR"))</span>
                            <span style="color: var(--kasa-danger); margin-left: 4px;">−@vbTVG.ToString("N2", System.Globalization.CultureInfo.GetCultureInfo("tr-TR"))</span>
                            <br/><span style="opacity: 0.5;">(@vbCount kasa@(vbLastDate.HasValue ? $", son: {vbLastDate.Value:dd.MM.yyyy}" : ""))</span>
                        </div>
                    }
                </div>
            </div>
            <div class="col-md-3">
                <div class="kasa-card" style="border-left: 4px solid var(--kasa-warning); border-radius: var(--radius-md); height: 100%;">
                    <div class="kasa-card-body" style="padding: 12px 16px;">
                        <div style="font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; color: var(--text-muted); margin-bottom: 8px;">
                            <i class="fas fa-users me-1"></i> Vergi Çalışanları
                        </div>
                        @if (Model.VergiKasaVeznedarlar?.Count > 0)
                        {
                            @foreach (var vz in Model.VergiKasaVeznedarlar)
                            {
                                <div style="font-size: 13px; font-weight: 600; padding: 2px 0;">
                                    <i class="fas fa-user-circle me-1" style="color: var(--kasa-warning); font-size: 11px;"></i>@vz
                                </div>
                            }
                            <div style="margin-top: 6px; padding-top: 6px; border-top: 1px solid var(--border-light); font-size: 14px; font-weight: 700; color: var(--kasa-warning);">
                                Toplam: @(Model.VergiKasaBakiyeToplam.ToString("N2", System.Globalization.CultureInfo.GetCultureInfo("tr-TR"))) ₺
                            </div>
                        }
                        else
                        {
                            <div style="font-size: 12px; color: var(--text-muted);">Çalışan bulunamadı</div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- ROW 4B: Bankaya Muhtemel Beklenen Olağan Girişler              -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <div class="row g-3 mb-3">
            <div class="col-12">
                <div class="kasa-card" style="border: 2px solid var(--kasa-info); border-radius: var(--radius-md); overflow: hidden;">
                    <div class="kasa-card-header" style="background: rgba(8,145,178,0.06); padding: 12px 20px;">
                        <h6 class="mb-0" style="color: var(--kasa-info); font-weight: 700;">
                            <i class="fas fa-arrow-circle-down me-2"></i>Bankaya Muhtemel Beklenen Olağan Girişler
                        </h6>
                    </div>
                    <div class="kasa-card-body" style="padding: 0;">
                        <div class="row g-0">
                            <div class="col-md-4" style="padding: 16px 20px; border-right: 1px solid var(--border-light);">
                                <div style="font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.6px; color: var(--text-muted); margin-bottom: 4px;">
                                    <i class="fas fa-exchange-alt me-1"></i> EFT Otomatik İade
                                </div>
                                <div class="money-value" style="font-size: 18px;">
                                    @PoolVal("eft_otomatik_iade") <span class="money-currency">₺</span>
                                </div>
                            </div>
                            <div class="col-md-4" style="padding: 16px 20px; border-right: 1px solid var(--border-light);">
                                <div style="font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.6px; color: var(--text-muted); margin-bottom: 4px;">
                                    <i class="fas fa-paper-plane me-1"></i> Gelen Havale
                                </div>
                                <div class="money-value" style="font-size: 18px;">
                                    @PoolVal("gelen_havale") <span class="money-currency">₺</span>
                                </div>
                            </div>
                            <div class="col-md-4" style="padding: 16px 20px;">
                                <div style="font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.6px; color: var(--text-muted); margin-bottom: 4px;">
                                    <i class="fas fa-undo me-1"></i> İade Kelimesi Giriş
                                </div>
                                <div class="money-value" style="font-size: 18px;">
                                    @PoolVal("iade_kelimesi_giris") <span class="money-currency">₺</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @* ═══ CrossDay Otomatik Eşleştirme Bildirimi ═══ *@
        @if (!string.IsNullOrEmpty(Model.CrossDayBildirim))
        {
        <div class="row g-3 mb-3">
            <div class="col-12">
                <div style="background: linear-gradient(135deg, rgba(34,197,94,0.12), rgba(16,185,129,0.08));
                            border: 1px solid rgba(34,197,94,0.35); border-radius: 12px; padding: 16px 20px;
                            display: flex; align-items: center; gap: 14px; animation: slideDown 0.4s ease-out;">
                    <div style="width: 44px; height: 44px; border-radius: 50%; background: rgba(34,197,94,0.2);
                                display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                        <i class="fas fa-exchange-alt" style="font-size: 18px; color: #22c55e;"></i>
                    </div>
                    <div style="flex: 1;">
                        <div style="font-size: 14px; font-weight: 700; color: #22c55e; margin-bottom: 2px;">
                            <i class="fas fa-bell me-1"></i> CrossDay Takip Bildirimi
                        </div>
                        <div style="font-size: 13px; color: var(--text-secondary);">
                            @Model.CrossDayBildirim
                        </div>
                    </div>
                    <a href="/HesapKontrol?tab=takipte" class="kasa-btn"
                       style="font-size: 11px; padding: 6px 14px; border-radius: 8px;
                              background: rgba(34,197,94,0.1); color: #22c55e;
                              border: 1px solid rgba(34,197,94,0.3); white-space: nowrap; text-decoration: none;">
                        <i class="fas fa-external-link-alt me-1"></i> Detaylar
                    </a>
                </div>
            </div>
        </div>
        }

        @* ═══ Akıllı Takip Korelasyonu — Takipten Çözülen Kayıtlar Bildirimi ═══ *@
        @if (!string.IsNullOrEmpty(Model.TakipCozumBildirim))
        {
        <div class="row g-3 mb-3">
            <div class="col-12">
                <div style="background: linear-gradient(135deg, rgba(8,145,178,0.12), rgba(59,130,246,0.08));
                            border: 1px solid rgba(8,145,178,0.35); border-radius: 12px; padding: 16px 20px;
                            display: flex; align-items: center; gap: 14px; animation: slideDown 0.4s ease-out;">
                    <div style="width: 44px; height: 44px; border-radius: 50%; background: rgba(8,145,178,0.2);
                                display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                        <i class="fas fa-sync-alt" style="font-size: 18px; color: #0891b2;"></i>
                    </div>
                    <div style="flex: 1;">
                        <div style="font-size: 14px; font-weight: 700; color: #0891b2; margin-bottom: 2px;">
                            <i class="fas fa-bell me-1"></i> Takip Çözüm Bildirimi
                        </div>
                        <div style="font-size: 13px; color: var(--text-secondary);">
                            @Model.TakipCozumBildirim
                        </div>
                        @if (Model.TakipCozumleri?.Any(x => x.Durum == "Geldi") == true)
                        {
                            <div style="margin-top: 6px; font-size: 11px; color: var(--text-muted);">
                                @foreach (var d in Model.TakipCozumleri.Where(x => x.Durum == "Geldi"))
                                {
                                    <span style="display: inline-block; margin-right: 8px; padding: 2px 8px; background: rgba(34,197,94,0.1); border: 1px solid rgba(34,197,94,0.3); border-radius: 6px; font-size: 10px; color: #22c55e; font-weight: 600;">
                                        @d.AnalizTarihi.ToString("dd.MM") @d.HesapTuru @d.Tutar.ToString("N2", System.Globalization.CultureInfo.GetCultureInfo("tr-TR")) ₺ ✅
                                    </span>
                                }
                            </div>
                        }
                    </div>
                    <a href="/HesapKontrol?tab=takipte" class="kasa-btn"
                       style="font-size: 11px; padding: 6px 14px; border-radius: 8px;
                              background: rgba(8,145,178,0.1); color: #0891b2;
                              border: 1px solid rgba(8,145,178,0.3); white-space: nowrap; text-decoration: none;">
                        <i class="fas fa-external-link-alt me-1"></i> Takip Detayları
                    </a>
                </div>
            </div>
        </div>
        }

        @if (kasaTypeClass == "sabah")
        {
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- ROW 4C: Bankaya Hesaplarına Beklenmeyen Olağandışı Akışlar     -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <div class="row g-3 mb-3">
            <div class="col-12">
                <div class="kasa-card" style="border: 2px solid var(--kasa-warning); border-radius: var(--radius-md); overflow: hidden;">
                    <div class="kasa-card-header" style="background: rgba(245,158,11,0.06); padding: 12px 20px;">
                        <h6 class="mb-0" style="color: var(--kasa-warning); font-weight: 700;">
                            <i class="fas fa-exclamation-triangle me-2"></i>Bankaya Hesaplarına Beklenmeyen (-,+) Olağandışı Akışlar
                        </h6>
                    </div>
                    <div class="kasa-card-body" style="padding: 0;">
                        <div class="row g-0">
                            <!-- SOL: Tahsilat -->
                            <div class="col-md-6" style="border-right: 2px solid var(--border-light);">
                                <div style="padding: 10px 20px; background: rgba(8,145,178,0.03); border-bottom: 1px solid var(--border-light);">
                                    <span style="font-size: 12px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.8px; color: var(--kasa-info);">
                                        <i class="fas fa-coins me-1"></i> Tahsilat
                                    </span>
                                </div>
                                <div style="display: flex; justify-content: space-between; align-items: center; padding: 12px 20px; border-bottom: 1px solid var(--border-light);">
                                    <span style="font-size: 13px; color: var(--text-muted); font-weight: 600;">
                                        <i class="fas fa-calendar-day me-2" style="color: var(--kasa-warning); width: 16px;"></i>Güne Ait Eksik/Fazla
                                    </span>
                                    <div style="text-align: right;">
                                        @{
                                            var efTahsilatVal = Model.ToplamFarkTahsilat != 0 ? Model.ToplamFarkTahsilat : (ResultValRaw("gune_ait_eksik_fazla_tahsilat"));
                                            var efTahsilatColor = efTahsilatVal > 0 ? "var(--kasa-success)" : efTahsilatVal < 0 ? "var(--kasa-danger)" : "inherit";
                                        }
                                        <span style="font-size: 16px; font-weight: 700; color: @efTahsilatColor;">@efTahsilatVal.ToString("N2", System.Globalization.CultureInfo.GetCultureInfo("tr-TR")) ₺</span>
                                        @if (!string.IsNullOrEmpty(Model.BreakdownMesajTahsilat))
                                        {
                                            <div style="font-size: 10px; color: var(--text-muted); margin-top: 2px;" title="@Model.BreakdownMesajTahsilat">
                                                <i class="fas fa-info-circle me-1" style="opacity: 0.6;"></i>@Model.BreakdownMesajTahsilat
                                            </div>
                                        }
                                    </div>
                                </div>
                                <div style="display: flex; justify-content: space-between; align-items: center; padding: 12px 20px; border-bottom: 1px solid var(--border-light);">
                                    <span style="font-size: 13px; color: var(--text-muted); font-weight: 600;">
                                        <i class="fas fa-history me-2" style="color: var(--kasa-warning); width: 16px;"></i>Dünden Eksik/Fazla
                                    </span>
                                    <span style="font-size: 16px; font-weight: 700;">@ResultVal("dunden_eksik_fazla_tahsilat") ₺</span>
                                </div>
                                <div style="display: flex; justify-content: space-between; align-items: center; padding: 12px 20px;">
                                    <span style="font-size: 13px; color: var(--text-muted); font-weight: 600;">
                                        <i class="fas fa-arrow-left me-2" style="color: var(--kasa-warning); width: 16px;"></i>Önceki Günden Gelen
                                        @{
                                            var takipDurumTahsilat = Model.TakipCozumleri?.FirstOrDefault(x => x.HesapTuru == KasaManager.Domain.Reports.HesapKontrol.BankaHesapTuru.Tahsilat);
                                        }
                                        @if (takipDurumTahsilat?.Durum == "Geldi")
                                        {
                                            <span style="font-size: 9px; padding: 1px 6px; background: rgba(34,197,94,0.15); color: #22c55e; border-radius: 4px; font-weight: 700; margin-left: 6px;">Geldi ✅</span>
                                        }
                                        else if (takipDurumTahsilat?.Durum == "TakipteDevam")
                                        {
                                            <span style="font-size: 9px; padding: 1px 6px; background: rgba(245,158,11,0.15); color: #f59e0b; border-radius: 4px; font-weight: 700; margin-left: 6px;">Takipte 📌</span>
                                        }
                                    </span>
                                    <span style="font-size: 16px; font-weight: 700;">@ResultVal("dunden_eksik_fazla_gelen_tahsilat") ₺</span>
                                </div>
                            </div>
                            <!-- SAĞ: Harç -->
                            <div class="col-md-6">
                                <div style="padding: 10px 20px; background: rgba(245,158,11,0.03); border-bottom: 1px solid var(--border-light);">
                                    <span style="font-size: 12px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.8px; color: var(--kasa-warning);">
                                        <i class="fas fa-gavel me-1"></i> Harç
                                    </span>
                                </div>
                                <div style="display: flex; justify-content: space-between; align-items: center; padding: 12px 20px; border-bottom: 1px solid var(--border-light);">
                                    <span style="font-size: 13px; color: var(--text-muted); font-weight: 600;">
                                        <i class="fas fa-calendar-day me-2" style="color: var(--kasa-warning); width: 16px;"></i>Güne Ait Eksik/Fazla
                                    </span>
                                    <div style="text-align: right;">
                                        @{
                                            var efHarcVal = Model.ToplamFarkHarc != 0 ? Model.ToplamFarkHarc : (ResultValRaw("gune_ait_eksik_fazla_harc"));
                                            var efHarcColor = efHarcVal > 0 ? "var(--kasa-success)" : efHarcVal < 0 ? "var(--kasa-danger)" : "inherit";
                                        }
                                        <span style="font-size: 16px; font-weight: 700; color: @efHarcColor;">@efHarcVal.ToString("N2", System.Globalization.CultureInfo.GetCultureInfo("tr-TR")) ₺</span>
                                        @if (!string.IsNullOrEmpty(Model.BreakdownMesajHarc))
                                        {
                                            <div style="font-size: 10px; color: var(--text-muted); margin-top: 2px;" title="@Model.BreakdownMesajHarc">
                                                <i class="fas fa-info-circle me-1" style="opacity: 0.6;"></i>@Model.BreakdownMesajHarc
                                            </div>
                                        }
                                    </div>
                                </div>
                                <div style="display: flex; justify-content: space-between; align-items: center; padding: 12px 20px; border-bottom: 1px solid var(--border-light);">
                                    <span style="font-size: 13px; color: var(--text-muted); font-weight: 600;">
                                        <i class="fas fa-history me-2" style="color: var(--kasa-warning); width: 16px;"></i>Dünden Eksik/Fazla
                                    </span>
                                    <span style="font-size: 16px; font-weight: 700;">@ResultVal("dunden_eksik_fazla_harc") ₺</span>
                                </div>
                                <div style="display: flex; justify-content: space-between; align-items: center; padding: 12px 20px;">
                                    <span style="font-size: 13px; color: var(--text-muted); font-weight: 600;">
                                        <i class="fas fa-arrow-left me-2" style="color: var(--kasa-warning); width: 16px;"></i>Önceki Günden Gelen
                                        @{
                                            var takipDurumHarc = Model.TakipCozumleri?.FirstOrDefault(x => x.HesapTuru == KasaManager.Domain.Reports.HesapKontrol.BankaHesapTuru.Harc);
                                        }
                                        @if (takipDurumHarc?.Durum == "Geldi")
                                        {
                                            <span style="font-size: 9px; padding: 1px 6px; background: rgba(34,197,94,0.15); color: #22c55e; border-radius: 4px; font-weight: 700; margin-left: 6px;">Geldi ✅</span>
                                        }
                                        else if (takipDurumHarc?.Durum == "TakipteDevam")
                                        {
                                            <span style="font-size: 9px; padding: 1px 6px; background: rgba(245,158,11,0.15); color: #f59e0b; border-radius: 4px; font-weight: 700; margin-left: 6px;">Takipte 📌</span>
                                        }
                                    </span>
                                    <span style="font-size: 16px; font-weight: 700;">@ResultVal("dunden_eksik_fazla_gelen_harc") ₺</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        }

