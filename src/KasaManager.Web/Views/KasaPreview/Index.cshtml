@model KasaManager.Web.Models.KasaPreviewViewModel
@{
    ViewData["Title"] = string.IsNullOrEmpty(Model.KasaType) ? "Kasa Preview" : $"{Model.KasaType} Kasa";

    var kasaTypeClass = (Model.KasaType ?? "").ToLowerInvariant() switch
    {
        "sabah" => "sabah",
        "aksam" => "aksam",
        "genel" => "genel",
        "ortak" => "ortak",
        _ => ""
    };

    // IBAN formatını okunabilir hale getirir: TR1234567890... → TR12 3456 7890 ...
    string FormatIban(string? iban)
    {
        if (string.IsNullOrWhiteSpace(iban)) return "—";
        var clean = iban.Replace(" ", "").Replace("-", "");
        var sb = new System.Text.StringBuilder();
        for (int i = 0; i < clean.Length; i++)
        {
            if (i > 0 && i % 4 == 0) sb.Append(' ');
            sb.Append(clean[i]);
        }
        return sb.ToString();
    }

    var kasaIcon = (Model.KasaType ?? "").ToLowerInvariant() switch
    {
        "sabah" => "fa-sun",
        "aksam" => "fa-moon",
        "genel" => "fa-chart-pie",
        "ortak" => "fa-layer-group",
        _ => "fa-calculator"
    };

    var kasaDisplayName = (Model.KasaType ?? "").ToLowerInvariant() switch
    {
        "sabah" => "Sabah Kasa",
        "aksam" => "Akşam Kasa",
        "genel" => "Genel Kasa",
        "ortak" => "Ortak (Özet) Kasa",
        _ => "Kasa Preview"
    };

    // Decimal → InvariantCulture string (export hidden input'lar için)
    string InvExp(decimal v) => v.ToString(System.Globalization.CultureInfo.InvariantCulture);

    // EFT Otomatik İade değeri (Günlük Kasa Notu placeholder için)
    var eftIadePoolEntry = Model.PoolEntries?.FirstOrDefault(p => p.CanonicalKey == "eft_otomatik_iade");
    var eftIadePlaceholder = eftIadePoolEntry != null && !string.IsNullOrEmpty(eftIadePoolEntry.Value) && eftIadePoolEntry.Value != "0"
        ? $"EFT iade {eftIadePoolEntry.Value}₺ UYAP girişi yapılacak"
        : "EFT iade bilgisi UYAP girişi yapılacak";
}

<!-- ═══════════════════════════════════════════════════════════════════ -->
<!-- HEADER: Kasa Type + Date                                           -->
<!-- ═══════════════════════════════════════════════════════════════════ -->
<div class="kasa-page-title d-flex align-items-center justify-content-between flex-wrap gap-3">
    <div class="d-flex align-items-center gap-3">
        <h2 class="mb-0">
            <i class="fas @kasaIcon text-kasa-primary me-2"></i>@kasaDisplayName
        </h2>
        @if (!string.IsNullOrEmpty(kasaTypeClass))
        {
            <span class="kasa-type-badge kasa-type-badge-@kasaTypeClass">
                <i class="fas @kasaIcon"></i> @Model.KasaType
            </span>
        }
    </div>
    @if (Model.IsAdminMode)
    {
        <span class="kasa-badge kasa-badge-danger">
            <i class="fas fa-flask me-1"></i>Admin Designer Modu
        </span>
    }
</div>

<!-- Draft Cache Bilgilendirme Banner -->
@if (ViewData["DraftInfo"] is string draftInfo && !string.IsNullOrEmpty(draftInfo))
{
    <div class="kasa-alert mb-3" style="background: linear-gradient(135deg, rgba(16,185,129,0.08), rgba(59,130,246,0.05)); border: 1px solid rgba(16,185,129,0.25); border-left: 4px solid var(--kasa-success,#10b981); border-radius: var(--radius-md,8px); padding: 12px 16px; display: flex; align-items: center; gap: 10px;">
        <i class="fas fa-history" style="color: var(--kasa-success,#10b981); font-size: 1.2rem; flex-shrink: 0;"></i>
        <div style="flex: 1; font-size: 0.85rem;">
            <strong style="color: var(--kasa-success,#10b981);">Önbellek Verisi</strong>
            <span style="color: var(--kasa-text-secondary,#94a3b8); margin-left: 4px;">@draftInfo</span>
        </div>
    </div>
}

<!-- Errors & Warnings -->
@if (Model.Errors.Count > 0)
{
    <div class="kasa-alert kasa-alert-danger mb-3">
        <i class="fas fa-exclamation-circle"></i>
        <div>
            @foreach (var err in Model.Errors)
            {
                <div>@err</div>
            }
        </div>
    </div>
}

@if (Model.Warnings.Count > 0)
{
    <div class="kasa-alert kasa-alert-info mb-3">
        <i class="fas fa-info-circle"></i>
        <div>
            @foreach (var w in Model.Warnings)
            {
                <div>@w</div>
            }
        </div>
    </div>
}

<!-- ═══════ KasaÜstRapor Panel (tüm kasa tipleri) ═══════ -->
@if (Model.UstRaporPanel != null)
{
    await Html.RenderPartialAsync("_KasaUstRaporPanel", Model.UstRaporPanel);
}

<!-- ═══════ Karşılama Kartı ═══════ -->
@if (!Model.IsDataLoaded)
{
    <div class="kasa-welcome-card">
        @if (Model.HasUploadedFiles)
        {
            <div class="kasa-welcome-icon has-data">
                <i class="fas fa-clipboard-check"></i>
            </div>
            <div class="kasa-welcome-body">
                <div class="kasa-welcome-title">
                    @if (Model.LastSnapshotDate.HasValue)
                    {
                        <text>En son <strong>@Model.LastSnapshotDate.Value.ToString("dd.MM.yyyy")</strong> tarihli snapshot kaydedildi</text>
                    }
                    else
                    {
                        <text>Dosyalar mevcut — henüz snapshot kaydedilmedi</text>
                    }
                </div>
                <div class="kasa-welcome-desc">
                    Rapor oluşturmak için tarih seçin ve "Verileri Getir" butonuna tıklayın
                </div>
            </div>
            <a asp-controller="Import" asp-action="Index" class="kasa-welcome-action">
                <i class="fas fa-upload"></i> Yeni Dosya Yükle
            </a>
        }
        else
        {
            <div class="kasa-welcome-icon no-data">
                <i class="fas fa-exclamation-triangle"></i>
            </div>
            <div class="kasa-welcome-body">
                <div class="kasa-welcome-title">Henüz dosya yüklenmedi</div>
                <div class="kasa-welcome-desc">
                    Kasa raporu oluşturabilmek için önce Excel dosyalarını yüklemeniz gerekmektedir
                </div>
            </div>
            <a asp-controller="Import" asp-action="Index" class="kasa-welcome-action">
                <i class="fas fa-folder-open"></i> Dosya Yüklemeye Git
            </a>
        }
    </div>
}

<!-- ═══════ Collapsible: Giriş Bölümleri (Hesapla sonrası gizlenir) ═══════ -->
@{
    var inputSectionHidden = Model.HasResults;
}

@if (Model.HasResults)
{
    <button class="kasa-detail-toggle" type="button"
            aria-expanded="false"
            onclick="toggleDetailSection(this, 'kasaInputSections')">
        <i class="fas fa-sliders-h"></i>
        Tarih Seçimi ve Manuel Girdiler
        <i class="fas fa-chevron-down detail-toggle-chevron"></i>
    </button>
}

<div id="kasaInputSections" style="@(inputSectionHidden ? "display:none;" : "")">

<!-- ═══════════════════════════════════════════════════════════════════ -->
<!-- ADIM 1: Tarih Seçimi ve Veri Yükleme                              -->
<!-- ═══════════════════════════════════════════════════════════════════ -->
<div class="kasa-card kasa-card-glow mb-4">
    <div class="kasa-card-header">
        <div class="kasa-step-header mb-0">
            <div class="kasa-step-number @(Model.IsDataLoaded ? "completed" : "active")">
                @(Model.IsDataLoaded ? "✓" : "1")
            </div>
            <div>
                <div class="kasa-step-title">Tarih Seçimi ve Veri Yükleme</div>
                <div class="kasa-step-subtitle">Rapor tarihini seçin ve Excel verilerini yükleyin</div>
            </div>
        </div>
    </div>
    <div class="kasa-card-body">
        <form asp-controller="KasaPreview" asp-action="LoadData" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="KasaType" />
            <input type="hidden" asp-for="IsAdminMode" />
            <input type="hidden" asp-for="AksamMesaiSonuModu" />

            <div class="row g-3 align-items-end">
                <div class="col-md-4 col-lg-3">
                    <label class="kasa-form-label">
                        <i class="fas fa-calendar-day me-1"></i>Rapor Tarihi
                    </label>
                    <input type="date" class="kasa-form-input"
                           asp-for="SelectedDate" />
                </div>

                @if (kasaTypeClass == "genel")
                {
                    <div class="col-md-4 col-lg-3">
                        <label class="kasa-form-label">
                            <i class="fas fa-calendar-alt me-1 text-success"></i>Dönem Başlangıcı
                        </label>
                        <input type="date" class="kasa-form-input"
                               asp-for="GenelKasaStartDate" />
                        @if (Model.DefaultGenelKasaBaslangicTarihiSeed.HasValue)
                        {
                            <small class="text-muted d-block mt-1" style="font-size:0.75rem;">
                                <i class="fas fa-info-circle"></i> Varsayılan: @Model.DefaultGenelKasaBaslangicTarihiSeed.Value.ToString("dd.MM.yyyy")
                            </small>
                        }
                    </div>
                    <div class="col-md-4 col-lg-3">
                        <label class="kasa-form-label">
                            <i class="fas fa-calendar-check me-1 text-warning"></i>Dönem Bitişi
                        </label>
                        <input type="date" class="kasa-form-input"
                               asp-for="GenelKasaEndDate" />
                        <small class="text-muted d-block mt-1" style="font-size:0.75rem;">
                            <i class="fas fa-info-circle"></i> Rapor tarihi ile aynı bırakılabilir
                        </small>
                    </div>
                }

                <div class="col-md-4 col-lg-3">
                    <label class="kasa-form-label">
                        <i class="fas fa-user me-1"></i>Kasayı Yapan
                    </label>
                    @if (Model.VeznedarOptions?.Count > 0)
                    {
                        <select class="kasa-form-input" asp-for="KasayiYapan"
                                onchange="document.querySelectorAll('input[name=KasayiYapan]').forEach(h=>h.value=this.value)">
                            <option value="">Seçiniz...</option>
                            @foreach (var v in Model.VeznedarOptions)
                            {
                                <option value="@v">@v</option>
                            }
                        </select>
                    }
                    else
                    {
                        <input type="text" class="kasa-form-input" asp-for="KasayiYapan"
                               placeholder="Veznedar adı"
                               oninput="document.querySelectorAll('input[name=KasayiYapan]').forEach(h=>h.value=this.value)" />
                    }
                </div>

                <div class="col-auto">
                    <button type="submit" class="kasa-btn kasa-btn-primary">
                        <i class="fas fa-download"></i> Veri Yükle
                    </button>
                </div>
            </div>

            @* ── Akşam Kasa: Mesai Sonu / Tam Gün Toggle ── *@
            @if (kasaTypeClass == "aksam")
            {
                <div class="row mt-3">
                    <div class="col-12">
                        <div style="display:inline-flex; align-items:center; gap:1rem; padding:0.6rem 1rem; border-radius:8px; background:var(--kasa-bg-subtle, rgba(255,255,255,0.05)); border:1px solid var(--kasa-border, rgba(255,255,255,0.1));">
                            <span style="font-size:0.85rem; font-weight:600; color:var(--kasa-text-secondary, #94a3b8);">
                                <i class="fas fa-clock me-1"></i>Akşam Kasa Modu:
                            </span>
                            <label style="display:inline-flex; align-items:center; gap:0.35rem; cursor:pointer; font-size:0.85rem; color:var(--kasa-text, #e2e8f0);">
                                <input type="radio" name="aksamModRadio" value="mesai"
                                       @(Model.AksamMesaiSonuModu ? "checked" : "")
                                       onchange="this.form.AksamMesaiSonuModu.value='true'" />
                                <i class="fas fa-business-time" style="color:#f59e0b;"></i> Mesai Sonu
                                <small style="color:var(--kasa-text-muted, #64748b);">(4 dosya)</small>
                            </label>
                            <label style="display:inline-flex; align-items:center; gap:0.35rem; cursor:pointer; font-size:0.85rem; color:var(--kasa-text, #e2e8f0);">
                                <input type="radio" name="aksamModRadio" value="tamgun"
                                       @(!Model.AksamMesaiSonuModu ? "checked" : "")
                                       onchange="this.form.AksamMesaiSonuModu.value='false'" />
                                <i class="fas fa-calendar-day" style="color:#10b981;"></i> Tam Gün
                                <small style="color:var(--kasa-text-muted, #64748b);">(7 dosya)</small>
                            </label>
                        </div>
                        @if (Model.AksamMesaiSonuModu)
                        {
                            <div class="mt-2" style="font-size:0.8rem; color:var(--kasa-text-muted, #64748b);">
                                <i class="fas fa-info-circle text-info"></i>
                                Mesai sonu modunda OnlineMasraf, OnlineHarç ve MasrafveReddiyat dosyaları atlanır.
                            </div>
                        }
                    </div>
                </div>
            }

            @* ── Excel Dosya Tarih Bilgi Şeridi ── *@
            @if (Model.UstRaporPanel?.DateEval != null)
            {
                var de = Model.UstRaporPanel.DateEval;
                var dosyaTarihi = de.ProposedDate;
                var secilenTarih = Model.SelectedDate;
                var dosyaSayisi = de.Sources?.Count(s => s.FileName != "(yok)" && s.HasDate) ?? 0;
                var toplamDosya = de.Sources?.Count(s => s.FileName != "(yok)") ?? 0;
                var tarihUyumlu = dosyaTarihi.HasValue && secilenTarih.HasValue && dosyaTarihi.Value == secilenTarih.Value;
                var tarihYok = !de.HasAnyDate;

                <div id="excelDosyaBilgiStrip" class="mt-3" style="border-radius: 10px; padding: 12px 16px; font-size: 0.82rem;
                    background: @(tarihYok ? "rgba(245,158,11,0.08)" : tarihUyumlu ? "rgba(16,185,129,0.06)" : "rgba(239,68,68,0.08)");
                    border: 1px solid @(tarihYok ? "rgba(245,158,11,0.25)" : tarihUyumlu ? "rgba(16,185,129,0.2)" : "rgba(239,68,68,0.25)");
                    ">
                    <div style="display:flex; align-items:center; gap:8px; flex-wrap:wrap;">
                        @* Dosya Sayısı *@
                        <span style="display:inline-flex; align-items:center; gap:4px; color: var(--kasa-text-secondary, #94a3b8);">
                            <i class="fas fa-folder-open" style="color:#6366f1;"></i>
                            <strong>@toplamDosya dosya</strong> yüklü
                        </span>

                        <span style="color: var(--kasa-text-muted, #475569);">•</span>

                        @* Tespit Edilen Tarih *@
                        @if (dosyaTarihi.HasValue)
                        {
                            <span style="display:inline-flex; align-items:center; gap:4px; color: var(--kasa-text-secondary, #94a3b8);">
                                <i class="fas fa-calendar-alt" style="color:#0ea5e9;"></i>
                                Dosya tarihi: <strong id="excelDetectedDate" data-date="@dosyaTarihi.Value.ToString("yyyy-MM-dd")"
                                    style="color: var(--kasa-text, #e2e8f0);">@dosyaTarihi.Value.ToString("dd.MM.yyyy")</strong>
                            </span>
                        }
                        else
                        {
                            <span style="display:inline-flex; align-items:center; gap:4px; color: var(--kasa-warning, #f59e0b);">
                                <i class="fas fa-exclamation-triangle"></i>
                                Dosyalarda tarih tespit edilemedi
                            </span>
                        }
                    </div>

                    @* Uyumsuzluk Uyarısı *@
                    <div id="excelTarihUyariKutusu" class="mt-2" style="display: @(tarihUyumlu || tarihYok ? "none" : "block");">
                        <div style="display:flex; align-items:flex-start; gap:8px; padding:8px 12px; border-radius:8px;
                            background:rgba(239,68,68,0.08); border:1px solid rgba(239,68,68,0.2);">
                            <i class="fas fa-exclamation-circle" style="color:#ef4444; margin-top:2px; flex-shrink:0;"></i>
                            <div>
                                <strong style="color:#ef4444; font-size:0.82rem;">DİKKAT — Tarih Uyumsuzluğu!</strong>
                                <div style="color: var(--kasa-text-secondary, #94a3b8); font-size:0.78rem; margin-top:2px;"
                                     id="excelTarihUyariMesaj">
                                    Seçilen rapor tarihi (<strong>@(secilenTarih?.ToString("dd.MM.yyyy") ?? "—")</strong>)
                                    ile Excel dosyalarındaki tarih (<strong>@(dosyaTarihi?.ToString("dd.MM.yyyy") ?? "—")</strong>) uyuşmuyor.
                                    Hesaplamada yanlış veriler kullanılabilir. Lütfen tarih seçimini veya dosyaları kontrol edin.
                                </div>
                            </div>
                        </div>
                    </div>

                    @* Uyumlu Bilgi *@
                    <div id="excelTarihUyumluKutusu" class="mt-1" style="display: @(tarihUyumlu ? "block" : "none");">
                        <span style="color:var(--kasa-success, #10b981); font-size:0.78rem;">
                            <i class="fas fa-check-circle"></i>
                            Dosya tarihi ile seçilen rapor tarihi uyumlu
                        </span>
                    </div>

                    @* Dosya Detayları (çakışma varsa) *@
                    @if (de.HasConflict && de.Sources != null)
                    {
                        <div class="mt-2" style="font-size:0.75rem; color: var(--kasa-text-muted, #64748b);">
                            <i class="fas fa-info-circle"></i> Dosya detayları:
                            @foreach (var src in de.Sources.Where(s => s.HasDate))
                            {
                                <span style="margin-left:6px;">
                                    <strong>@src.Kind</strong>: @string.Join(", ", src.DistinctDates.Select(d => d.ToString("dd.MM.yyyy")))
                                </span>
                            }
                        </div>
                    }
                </div>

                @* JS: Tarih değiştiğinde uyarı kutusunu güncelleyen script *@
                <script>
                (function() {
                    var dateInput = document.getElementById('SelectedDate');
                    var detectedEl = document.getElementById('excelDetectedDate');
                    var uyariBox = document.getElementById('excelTarihUyariKutusu');
                    var uyumluBox = document.getElementById('excelTarihUyumluKutusu');
                    var uyariMesaj = document.getElementById('excelTarihUyariMesaj');
                    var strip = document.getElementById('excelDosyaBilgiStrip');

                    if (!dateInput || !detectedEl) return;
                    var detectedDate = detectedEl.getAttribute('data-date'); // yyyy-MM-dd
                    if (!detectedDate) return;

                    function formatDate(ymd) {
                        var p = ymd.split('-');
                        return p.length === 3 ? (p[2] + '.' + p[1] + '.' + p[0]) : ymd;
                    }

                    dateInput.addEventListener('change', function() {
                        var selected = dateInput.value; // yyyy-MM-dd
                        var match = selected === detectedDate;

                        if (uyariBox) uyariBox.style.display = match ? 'none' : 'block';
                        if (uyumluBox) uyumluBox.style.display = match ? 'block' : 'none';

                        // Strip renk güncelle
                        if (strip) {
                            strip.style.background = match
                                ? 'rgba(16,185,129,0.06)' : 'rgba(239,68,68,0.08)';
                            strip.style.borderColor = match
                                ? 'rgba(16,185,129,0.2)' : 'rgba(239,68,68,0.25)';
                        }

                        // Uyarı metnini güncelle
                        if (uyariMesaj && !match) {
                            uyariMesaj.innerHTML =
                                'Seçilen rapor tarihi (<strong>' + formatDate(selected) + '</strong>) ' +
                                'ile Excel dosyalarındaki tarih (<strong>' + formatDate(detectedDate) + '</strong>) uyuşmuyor. ' +
                                'Hesaplamada yanlış veriler kullanılabilir. Lütfen tarih seçimini veya dosyaları kontrol edin.';
                        }
                    });
                })();
                </script>
            }

        </form>
    </div>
</div>

<!-- ═══════════════════════════════════════════════════════════════════ -->
<!-- ADIM 2: Manuel Girdiler ve Hesaplama                               -->
<!-- ═══════════════════════════════════════════════════════════════════ -->
@if (Model.IsDataLoaded)
{
<div class="kasa-card kasa-card-glow mb-4 kasa-fade-in">
    <div class="kasa-card-header">
        <div class="kasa-step-header mb-0">
            <div class="kasa-step-number @(Model.HasResults ? "completed" : "active")">
                @(Model.HasResults ? "✓" : "2")
            </div>
            <div>
                <div class="kasa-step-title">Manuel Girdiler ve Hesaplama</div>
                <div class="kasa-step-subtitle">Nakit tutarları ve diğer bilgileri girin, Hesapla'ya tıklayın</div>
            </div>
        </div>
    </div>
    <div class="kasa-card-body">
        <form asp-controller="KasaPreview" asp-action="Calculate" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="KasaType" />
            <input type="hidden" asp-for="IsAdminMode" />
            <input type="hidden" asp-for="AksamMesaiSonuModu" />
            <input type="hidden" asp-for="SelectedDate" />
            <input type="hidden" asp-for="KasayiYapan" />
            <input type="hidden" asp-for="HasSnapshot" />
            <input type="hidden" asp-for="IsDataLoaded" />
            <input type="hidden" name="GenelKasaStartDate" value="@(Model.GenelKasaStartDate?.ToString("yyyy-MM-dd"))" />
            <input type="hidden" name="GenelKasaEndDate" value="@(Model.GenelKasaEndDate?.ToString("yyyy-MM-dd"))" />

            <div class="row g-3">
                <div class="col-md-4 col-lg-3">
                    <label class="kasa-form-label">
                        <i class="fas fa-coins me-1"></i>Bozuk Para
                    </label>
                    <input type="number" step="0.01" class="kasa-form-input money-input"
                           asp-for="BozukPara" />
                </div>
                <div class="col-md-4 col-lg-3">
                    <label class="kasa-form-label">
                        <i class="fas fa-money-bill-wave me-1"></i>Nakit Para
                    </label>
                    <input type="number" step="0.01" class="kasa-form-input money-input"
                           asp-for="NakitPara" />
                </div>
                <div class="col-md-4 col-lg-3">
                    <label class="kasa-form-label">
                        <i class="fas fa-piggy-bank me-1"></i>Vergide Biriken Kasa
                    </label>
                    <input type="number" step="0.01" class="kasa-form-input money-input"
                           asp-for="VergideBirikenKasa" />
                </div>
                <div class="col-md-4 col-lg-3">
                    <label class="kasa-form-label">
                        <i class="fas fa-hand-holding-usd me-1"></i>Vergiden Gelen
                    </label>
                    <input type="number" step="0.01" class="kasa-form-input money-input"
                           asp-for="VergidenGelen" />
                </div>
                <div class="col-md-4 col-lg-3">
                    <label class="kasa-form-label">
                        <i class="fas fa-exclamation-triangle me-1"></i>Gelmeyen (D)
                    </label>
                    <input type="number" step="0.01" class="kasa-form-input money-input"
                           asp-for="GelmeyenD" />
                </div>
