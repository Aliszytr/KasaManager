                                </tr>
                                <tr>
                                    <td style="padding-left: 28px;"><i class="fas fa-minus text-muted me-1" style="font-size: 10px;"></i> Bankaya Yatırılacak Harç</td>
                                    <td class="text-end money-value">−@MuhFmt(muh_bankaya_yat_h) ₺</td>
                                    <td></td>
                                </tr>
                                <tr>
                                    <td style="padding-left: 28px;"><i class="fas fa-minus text-muted me-1" style="font-size: 10px;"></i> Online Harç</td>
                                    <td class="text-end money-value">−@MuhFmt(muh_online_h) ₺</td>
                                    <td></td>
                                </tr>
                                @if (muh_dunden_gelen_h != 0)
                                {
                                <tr style="background: rgba(245,158,11,0.04);">
                                    <td style="padding-left: 28px;"><i class="fas fa-minus text-warning me-1" style="font-size: 10px;"></i> Dünden Gelen Eksik/Fazla Harç</td>
                                    <td class="text-end money-value">−@MuhFmt(muh_dunden_gelen_h) ₺</td>
                                    <td><span style="font-size: 10px; color: var(--text-muted);"><i class="fas fa-history"></i> Önceki günden</span></td>
                                </tr>
                                }
                                <tr style="border-top: 2px solid var(--border-light); background: @(Math.Abs(muh_fark_h) < 0.01m ? "rgba(16,185,129,0.06)" : "rgba(239,68,68,0.06)");">
                                    <td><strong><i class="@MuhFarkIcon(muh_fark_h) me-1" style="@MuhFarkClass(muh_fark_h)"></i> Toplam Fark</strong></td>
                                    <td class="text-end money-value" style="font-weight: 700; font-size: 14px; @MuhFarkClass(muh_fark_h)">@MuhFmt(muh_fark_h) ₺</td>
                                    <td>
                                        @if (Math.Abs(muh_fark_h) < 0.01m)
                                        {
                                            <span style="font-size: 10px; color: var(--kasa-success);"><i class="fas fa-check"></i> Sorun yok</span>
                                        }
                                        else
                                        {
                                            <span style="font-size: 10px; color: var(--kasa-danger);"><i class="fas fa-exclamation-triangle"></i> Kontrol edin</span>
                                        }
                                    </td>
                                </tr>
                                @if (Math.Abs(muh_fark_h) >= 0.01m && muh_dunden_gelen_h > 0)
                                {
                                <tr style="background: @(Math.Abs(muh_olagan_disi_h) < 0.01m ? "rgba(16,185,129,0.04)" : "rgba(239,68,68,0.06)");">
                                    <td style="padding-left: 28px; font-size: 12px; font-weight: 600;">
                                        <i class="fas fa-exclamation-triangle me-1" style="color: @(Math.Abs(muh_olagan_disi_h) < 0.01m ? "var(--kasa-success)" : "var(--kasa-danger)")"></i>
                                        ⚠️ Olağan Dışı (Beklenmeyen) Fark
                                    </td>
                                    <td class="text-end money-value" style="font-size: 13px; font-weight: 700; @MuhFarkClass(muh_olagan_disi_h)">@MuhFmt(muh_olagan_disi_h) ₺</td>
                                    <td>
                                        @if (Math.Abs(muh_olagan_disi_h) >= 0.01m)
                                        {
                                            <span class="badge" style="font-size: 9px; background: @(muh_olagan_disi_h < 0 ? "var(--kasa-danger)" : "var(--kasa-success)"); color: white;">@(muh_olagan_disi_h < 0 ? "Eksik" : "Fazla")</span>
                                            <span style="font-size: 9px; color: var(--kasa-danger); margin-left: 4px;">Takibe alın</span>
                                        }
                                        else
                                        {
                                            <span style="font-size: 10px; color: var(--kasa-success);"><i class="fas fa-check"></i></span>
                                        }
                                    </td>
                                </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <!-- ─── REDDİYAT / STOPAJ KONTROL ─── -->
                    <div style="padding: 16px 20px 8px;">
                        <h6 style="font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; color: var(--kasa-primary); margin-bottom: 12px;">
                            <i class="fas fa-exchange-alt text-secondary me-1"></i> Reddiyat / Stopaj Kontrolü
                        </h6>
                        <table class="kasa-table" style="margin-bottom: 0;">
                            <thead>
                                <tr>
                                    <th style="width: 55%;">Kalem</th>
                                    <th class="text-end" style="width: 25%;">Tutar</th>
                                    <th style="width: 20%;"></th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td><strong><i class="fas fa-arrow-circle-up text-danger me-1"></i> Online Reddiyat</strong></td>
                                    <td class="text-end money-value" style="font-weight: 700; font-size: 14px;">@PoolVal("online_reddiyat") ₺</td>
