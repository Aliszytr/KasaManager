<!-- Güncelleme Onay Modalı                                             -->
<!-- ═══════════════════════════════════════════════════════════════════ -->
<div id="overwriteConfirmModal" style="display:none; position:fixed; inset:0; z-index:10000; background:rgba(0,0,0,0.6); backdrop-filter:blur(4px);">
    <div style="position:absolute; top:50%; left:50%; transform:translate(-50%,-50%); background:var(--card-bg, white); border-radius:16px; box-shadow:0 20px 60px rgba(0,0,0,0.3); max-width:460px; width:90%; overflow:hidden;">
        <div style="padding:24px 24px 16px;">
            <div style="display:flex; align-items:center; gap:14px; margin-bottom:16px;">
                <div style="width:48px; height:48px; border-radius:12px; background:linear-gradient(135deg,#f59e0b,#d97706); display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                    <i class="fas fa-exclamation-triangle" style="color:white; font-size:20px;"></i>
                </div>
                <div>
                    <div style="font-size:16px; font-weight:700; color:var(--text-primary, #111827);">Mevcut Rapor Bulundu</div>
                    <div style="font-size:12px; color:var(--text-muted, #6b7280); margin-top:2px;">Bu tarihte zaten kayıtlı bir rapor var</div>
                </div>
            </div>
            <div id="overwriteInfoBox" style="padding:14px 16px; border-radius:10px; background:rgba(245,158,11,0.06); border:1px solid rgba(245,158,11,0.2); margin-bottom:16px;">
                <div style="display:flex; align-items:center; gap:8px; margin-bottom:8px;">
                    <i class="fas fa-file-alt" style="color:#d97706; font-size:13px;"></i>
                    <span id="overwriteExistingName" style="font-size:13px; font-weight:600; color:#92400e;"></span>
                    <span id="overwriteExistingVersion" style="font-size:11px; font-weight:500; color:#b45309; background:rgba(245,158,11,0.15); padding:1px 8px; border-radius:10px;"></span>
                </div>
                <div style="font-size:12px; color:#78350f;">
                    <i class="fas fa-calendar-alt me-1"></i><span id="overwriteExistingTarih"></span>
                </div>
            </div>
            <div style="font-size:13px; color:var(--text-secondary, #6b7280); line-height:1.6;">
                Güncellemek isterseniz mevcut rapor pasif yapılır ve yeni versiyon oluşturulur. Eski versiyon kaybolmaz.
            </div>
        </div>
        <div style="padding:12px 24px 20px; display:flex; justify-content:flex-end; gap:10px; border-top:1px solid var(--border-light, #e5e7eb);">
            <button type="button" id="btnCancelOverwrite" class="kasa-btn kasa-btn-secondary">İptal</button>
            <button type="button" id="btnConfirmOverwrite" class="kasa-btn" style="background:linear-gradient(135deg,#10b981,#059669); color:white; border:none; font-weight:600; padding:10px 24px;">
                <i class="fas fa-sync-alt me-1"></i> Güncelle
            </button>
        </div>
    </div>
</div>

<script>
(function() {
    // ═══════════════════════════════════════════════════════════
    //  SAVE MODAL  —  Open/Close/Submit
    // ═══════════════════════════════════════════════════════════
    var openBtn = document.getElementById('btnOpenSaveModal');
    var closeBtn = document.getElementById('btnCloseSaveModal');
    var modal = document.getElementById('saveReportModal');
    var form = document.getElementById('saveReportForm');

    if (openBtn && modal) {
        openBtn.addEventListener('click', function() {
            modal.style.display = 'block';
            var nameInput = document.getElementById('saveRaporAdi');
            if (nameInput) setTimeout(function() { nameInput.focus(); }, 100);
        });
    }
    if (closeBtn && modal) {
        closeBtn.addEventListener('click', function() { modal.style.display = 'none'; });
    }
    if (modal) {
        modal.addEventListener('click', function(e) {
            if (e.target === modal) modal.style.display = 'none';
        });
    }

    // ── Form verilerini senkronize et ──
    function syncFormData() {
        var notInput = document.getElementById('kasaGunlukNot')
                    || document.getElementById('kasaGunlukNotSabahAksam');
        var notValue = notInput ? notInput.value : '';
        form.querySelectorAll('.rpt-gunluk-not').forEach(function(h) { h.value = notValue; });

        var genelForm = document.querySelector('form[action*="DownloadGenelRapor"]');
        if (genelForm) {
            form.querySelectorAll('.save-rpt-field').forEach(function(field) {
                var source = genelForm.querySelector('input[name="' + field.name + '"]');
                if (source) field.value = source.value;
            });
        }

        // ── Kullanıcı Girişleri (Ek Girdiler + Manuel Girdiler) ──
        // Orijinal hesapla formundaki input'lardan save formuna kopyala
        var userInputMappings = [
            ['RptKaydenTahsilat', 'KaydenTahsilat'],
            ['RptKaydenHarc', 'KaydenHarc'],
            ['RptBankadanCekilen', 'BankadanCekilen'],
            ['RptCNBCikamayan', 'CesitliNedenlerleBankadanCikamayanTahsilat'],
            ['RptBankayaYatirilacakTahsilatiDegistir', 'BankayaYatirilacakTahsilatiDegistir'],
            ['RptBankayaYatirilacakHarciDegistir', 'BankayaYatirilacakHarciDegistir'],
            ['RptBankayaGonderilmisDeger', 'BankayaGonderilmisDeger'],
            ['RptKasadaKalacakHedef', 'KasadaKalacakHedef'],
            ['RptBozukPara', 'BozukPara'],
            ['RptNakitPara', 'NakitPara'],
            ['RptGelmeyenD', 'GelmeyenD']
        ];
        userInputMappings.forEach(function(pair) {
            var saveField = form.querySelector('input[name="' + pair[0] + '"]');
            var srcInput = document.querySelector('input[name="' + pair[1] + '"]');
            if (saveField) {
                saveField.value = (srcInput && srcInput.value) ? srcInput.value : '0';
            }
        });

        // ── Validation İletileri (JSON serialize) ──
        var validationEl = document.getElementById('rptValidationMessagesJson');
        if (validationEl) {
            try {
                var msgs = [];
                document.querySelectorAll('[data-validation-code]').forEach(function(el) {
                    msgs.push({
                        severity: el.getAttribute('data-validation-severity') || 'Info',
                        code: el.getAttribute('data-validation-code') || '',
                        message: el.getAttribute('data-validation-message') || el.textContent.trim()
                    });
                });
                validationEl.value = msgs.length > 0 ? JSON.stringify(msgs) : '';
            } catch(e) { validationEl.value = ''; }
        }

        var inputsEl = document.getElementById('saveInputsJson');
        var outputsEl = document.getElementById('saveOutputsJson');
        var poolDataEl = document.querySelector('[data-pool-json]');
        if (poolDataEl && inputsEl) inputsEl.value = poolDataEl.getAttribute('data-pool-json') || '{}';
        var formulaOutputEl = document.querySelector('[data-output-json]');
        if (formulaOutputEl && outputsEl) outputsEl.value = formulaOutputEl.getAttribute('data-output-json') || '{}';
    }

    // ── AJAX Kaydet akışı ──
    function submitSaveForm(withOverwrite) {
        syncFormData();
        var confirmEl = document.getElementById('confirmOverwrite');
        if (confirmEl) confirmEl.value = withOverwrite ? 'true' : 'false';

        var submitBtn = document.getElementById('btnSubmitSave');
        if (submitBtn) {
            submitBtn.disabled = true;
            submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i> Kaydediliyor...';
        }

        var fd = new FormData(form);
        fetch(form.action, { method: 'POST', body: fd })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (data.needsConfirmation) {
                    // Onay gerekli — modalı göster
                    document.getElementById('saveReportModal').style.display = 'none';
                    showOverwriteConfirm(data);
                } else if (data.ok) {
                    // Başarılı kayıt/güncelleme
                    document.getElementById('saveReportModal').style.display = 'none';
                    showToast(data.message, 'success');
                    setTimeout(function() {
                        if (data.redirectUrl) window.location.href = data.redirectUrl;
                    }, 800);
                } else {
                    showToast(data.message || 'Kaydetme hatası', 'error');
                }
            })
            .catch(function(err) {
                showToast('Kaydetme hatası: ' + err.message, 'error');
            })
            .finally(function() {
                if (submitBtn) {
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = '<i class="fas fa-save me-1"></i> Kaydet';
                }
                if (confirmEl) confirmEl.value = 'false';
            });
    }

    // ── Onay modalı göster ──
    function showOverwriteConfirm(data) {
        var confirmModal = document.getElementById('overwriteConfirmModal');
        if (!confirmModal) return;
        document.getElementById('overwriteExistingName').textContent = data.existingName || '';
        document.getElementById('overwriteExistingVersion').textContent = 'v' + (data.existingVersion || '?');
        document.getElementById('overwriteExistingTarih').textContent = data.tarih || '';
        confirmModal.style.display = 'block';
    }

    // ── Onay modalı butonları ──
    var confirmModal = document.getElementById('overwriteConfirmModal');
    var btnConfirm = document.getElementById('btnConfirmOverwrite');
    var btnCancelOw = document.getElementById('btnCancelOverwrite');

    if (btnConfirm) {
        btnConfirm.addEventListener('click', function() {
            if (confirmModal) confirmModal.style.display = 'none';
            submitSaveForm(true);
        });
    }
    if (btnCancelOw && confirmModal) {
        btnCancelOw.addEventListener('click', function() {
            confirmModal.style.display = 'none';
            showToast('İşlem iptal edildi — verileriniz korunuyor', 'info');
        });
    }
    if (confirmModal) {
        confirmModal.addEventListener('click', function(e) {
            if (e.target === confirmModal) {
                confirmModal.style.display = 'none';
                showToast('İşlem iptal edildi — verileriniz korunuyor', 'info');
            }
        });
    }

    // ── Form submit'i AJAX'a çevir ──
    if (form) {
        form.addEventListener('submit', function(e) {
            e.preventDefault();
            submitSaveForm(false);
        });
    }

    // ═══════════════════════════════════════════════════════════
    //  REPORTS PANEL  —  Toggle + AJAX Load
    // ═══════════════════════════════════════════════════════════
    var toggleBtn = document.getElementById('btnToggleReports');
    var reportsPanel = document.getElementById('reportsPanel');
    var chevron = document.getElementById('reportsChevron');
    var tableBody = document.getElementById('reportsTableBody');
    var countBadge = document.getElementById('reportCountBadge');
    var panelOpen = false;
    var kasaType = '@(Model.KasaType ?? "")';

    if (toggleBtn && reportsPanel) {
        toggleBtn.addEventListener('click', function() {
            panelOpen = !panelOpen;
            reportsPanel.style.display = panelOpen ? 'block' : 'none';
            if (chevron) chevron.style.transform = panelOpen ? 'rotate(180deg)' : '';
            if (panelOpen) loadReports();
        });
    }

    // Search and Clear buttons
    var searchBtn = document.getElementById('btnSearchReports');
    var clearBtn = document.getElementById('btnClearSearch');
    var searchDateInput = document.getElementById('reportSearchDate');
    var searchTextInput = document.getElementById('reportSearchText');

    if (searchBtn) searchBtn.addEventListener('click', function() { loadReports(); });
    if (clearBtn) clearBtn.addEventListener('click', function() {
        if (searchDateInput) searchDateInput.value = '';
        if (searchTextInput) searchTextInput.value = '';
        loadReports();
    });
    // Enter key in search inputs
    [searchDateInput, searchTextInput].forEach(function(el) {
        if (el) el.addEventListener('keydown', function(e) {
            if (e.key === 'Enter') { e.preventDefault(); loadReports(); }
        });
    });

    function loadReports() {
        if (!tableBody) return;
        tableBody.innerHTML = '<tr><td colspan="5" style="padding:20px; text-align:center; color:var(--text-muted);"><i class="fas fa-spinner fa-spin me-2"></i>Yükleniyor...</td></tr>';

        var loadedId = '';
        var loadedEl = document.getElementById('loadedSnapshotId');
        if (loadedEl) loadedId = loadedEl.value;

        var url = '/KasaPreview/SearchReports?kasaType=' + encodeURIComponent(kasaType);
        if (searchDateInput && searchDateInput.value) url += '&searchDate=' + encodeURIComponent(searchDateInput.value);
        if (searchTextInput && searchTextInput.value.trim()) url += '&search=' + encodeURIComponent(searchTextInput.value.trim());

        fetch(url)
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (countBadge) countBadge.textContent = data.totalCount + ' rapor';

                if (!data.items || data.items.length === 0) {
                    tableBody.innerHTML = '<tr><td colspan="5" style="padding:24px; text-align:center; color:#6b7280; background:#fff;"><i class="fas fa-inbox me-2" style="font-size:16px;"></i>Kayıtlı rapor bulunamadı</td></tr>';
                    return;
                }

                var html = '';
                data.items.forEach(function(item) {
                    var isLoaded = loadedId && item.id === loadedId;
                    var rowBg = isLoaded ? 'background: rgba(99,102,241,0.06);' : '';
                    html += '<tr data-snapshot-id="' + item.id + '" style="border-bottom:1px solid #e5e7eb; cursor:pointer; transition: background 0.15s; color:#1f2937; ' + rowBg + '" ' +
                            'onmouseenter="this.style.background=\'#eef2ff\'" ' +
                            'onmouseleave="this.style.background=\'' + (isLoaded ? '#eef2ff' : '#fff') + '\'" ' +
                            'ondblclick="window.location.href=\'/KasaPreview/LoadSnapshot?id=' + item.id + '\'">';
                    html += '<td style="padding:8px 12px; color:#1f2937;">';
                    if (isLoaded) html += '<i class="fas fa-check-circle me-1" style="color:#6366f1; font-size:10px;"></i>';
                    html += '<span style="font-weight:' + (isLoaded ? '700' : '500') + '; color:#1e1b4b;">' + escapeHtml(item.name || 'İsimsiz') + '</span>';
                    if (item.notes) html += '<div style="font-size:10px; color:#6b7280; margin-top:2px; max-width:250px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">' + escapeHtml(item.notes) + '</div>';
                    html += '</td>';
                    html += '<td style="padding:8px 12px; text-align:center; font-size:12px; color:#374151;">' + item.raporTarihi + '</td>';
                    html += '<td style="padding:8px 12px; text-align:center;"><span style="font-size:10px; font-weight:600; background:#eef2ff; color:#4338ca; padding:1px 6px; border-radius:10px;">v' + item.version + '</span></td>';
                    html += '<td style="padding:8px 12px; text-align:center; font-size:11px; color:#6b7280;">' + item.calculatedAt + '</td>';
                    html += '<td style="padding:8px 12px; text-align:center; white-space:nowrap;">';
                    if (isLoaded) {
                        html += '<span style="font-size:10px; color:#6366f1; font-weight:600;">Yüklü</span>';
                    } else {
                        html += '<a href="/KasaPreview/LoadSnapshot?id=' + item.id + '" class="kasa-btn" style="font-size:10px; padding:3px 10px; background:linear-gradient(135deg,#6366f1,#4f46e5); color:white; border:none; text-decoration:none;">';
                        html += '<i class="fas fa-download me-1"></i>Yükle</a>';
                    }
                    html += '<button type="button" onclick="deleteFromPanel(\'' + item.id + '\')"  class="kasa-btn" style="font-size:10px; padding:3px 10px; background:linear-gradient(135deg,#ef4444,#dc2626); color:white; border:none; cursor:pointer; margin-left:4px;" title="Raporu sil">';
                    html += '<i class="fas fa-trash-alt"></i></button>';
                    html += '</td></tr>';
                });
                tableBody.innerHTML = html;
            })
            .catch(function(err) {
                tableBody.innerHTML = '<tr><td colspan="5" style="padding:20px; text-align:center; color:#dc2626;"><i class="fas fa-exclamation-triangle me-1"></i>Yükleme hatası: ' + err.message + '</td></tr>';
            });
    }

    // ═══════════════════════════════════════════════════════════
    //  UPDATE SNAPSHOT  —  Tam veri güncelleme (SaveReport + ConfirmOverwrite)
    // ═══════════════════════════════════════════════════════════
    var updateBtn = document.getElementById('btnUpdateSnapshot');
    if (updateBtn) {
        updateBtn.addEventListener('click', function() {
            var snapshotIdEl = document.getElementById('loadedSnapshotId');
            if (!snapshotIdEl || !snapshotIdEl.value) {
                showToast('Güncellenecek rapor yüklü değil', 'warning');
                return;
            }

            // Onay modalı göster — doğrudan güncelleme yap
            if (!form) {
                showToast('Kaydetme formu bulunamadı', 'error');
                return;
            }

            // Rapor adını al (yüklü rapor barındaki ad)
            var currentName = '';
            var nameDiv = document.querySelector('#loadedReportBar div div:first-child');
            if (nameDiv) {
                currentName = nameDiv.childNodes[0]?.textContent?.trim() || '';
            }
            var nameInput = document.getElementById('saveRaporAdi');
            if (nameInput && currentName) nameInput.value = currentName;

            // Doğrudan ConfirmOverwrite=true ile kaydet
            submitSaveForm(true);
        });
    }

    // ═══════════════════════════════════════════════════════════
    //  DELETE SNAPSHOT  —  AJAX with confirmation
    // ═══════════════════════════════════════════════════════════
    var deleteBtn = document.getElementById('btnDeleteSnapshot');
    if (deleteBtn) {
        deleteBtn.addEventListener('click', function() {
            var snapshotIdEl = document.getElementById('loadedSnapshotId');
            if (!snapshotIdEl || !snapshotIdEl.value) {
                showToast('⚠️ Silinecek rapor yüklü değil', 'warning');
                return;
            }

            if (!confirm('Bu raporu silmek istediğinizden emin misiniz?\n\nBu işlem geri alınabilir (soft delete).')) return;

            var token = getAntiForgeryToken();
            var fd = new FormData();
            fd.append('snapshotId', snapshotIdEl.value);
            fd.append('__RequestVerificationToken', token);

            deleteBtn.disabled = true;
            deleteBtn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i> Siliniyor...';

            fetch('/KasaPreview/DeleteSnapshot', { method: 'POST', body: fd })
                .then(function(r) { return r.json(); })
                .then(function(data) {
                    showToast(data.message, data.ok ? 'success' : 'error');
                    if (data.ok) {
                        // Remove loaded bar + disable Update/Delete
                        var bar = document.getElementById('loadedReportBar');
                        if (bar) bar.style.display = 'none';
                        updateBtn.style.opacity = '0.4';
                        updateBtn.style.pointerEvents = 'none';
                        deleteBtn.style.opacity = '0.4';
                        deleteBtn.style.pointerEvents = 'none';
                        if (panelOpen) loadReports();
                    }
                })
                .catch(function(err) {
                    showToast('❌ Silme hatası: ' + err.message, 'error');
                })
                .finally(function() {
                    deleteBtn.disabled = false;
                    deleteBtn.innerHTML = '<i class="fas fa-trash-alt me-1"></i> Sil';
                });
        });
    }

    // ═══════════════════════════════════════════════════════════
    //  HELPERS
    // ═══════════════════════════════════════════════════════════
    function getAntiForgeryToken() {
        var tokenEl = document.querySelector('input[name="__RequestVerificationToken"]');
        return tokenEl ? tokenEl.value : '';
    }

    function escapeHtml(str) {
        var div = document.createElement('div');
        div.textContent = str;
        return div.innerHTML;
    }

    // Paneldeki rapor satırından doğrudan silme
    window.deleteFromPanel = function(snapshotId) {
        if (!confirm('Bu raporu silmek istediğinizden emin misiniz?\n\nBu işlem geri alınabilir (soft delete).')) return;

        var token = getAntiForgeryToken();
        var fd = new FormData();
        fd.append('snapshotId', snapshotId);
        fd.append('__RequestVerificationToken', token);

        fetch('/KasaPreview/DeleteSnapshot', { method: 'POST', body: fd })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                showToast(data.message, data.ok ? 'success' : 'error');
                if (data.ok) {
                    // Eğer yüklü rapor siliniyorsa bar'ı gizle
                    var loadedIdEl = document.getElementById('loadedSnapshotId');
                    if (loadedIdEl && loadedIdEl.value === snapshotId) {
                        var bar = document.getElementById('loadedReportBar');
                        if (bar) bar.style.display = 'none';
                        var updateBtn = document.getElementById('btnUpdateSnapshot');
                        var deleteBtn = document.getElementById('btnDeleteSnapshot');
                        if (updateBtn) { updateBtn.style.opacity = '0.4'; updateBtn.style.pointerEvents = 'none'; }
                        if (deleteBtn) { deleteBtn.style.opacity = '0.4'; deleteBtn.style.pointerEvents = 'none'; }
                    }
                    loadReports(); // Panel'i yenile
                }
            })
            .catch(function(err) {
                showToast('Silme hatası: ' + err.message, 'error');
            });
    };

    function showToast(message, type) {
        var area = document.getElementById('actionAlertArea');
        if (!area) return;

        var icon = type === 'success' ? 'fa-check-circle' :
                   type === 'warning' ? 'fa-exclamation-triangle' : 'fa-times-circle';
        var borderColor = type === 'success' ? '#10b981' :
                          type === 'warning' ? '#f59e0b' : '#ef4444';
        var bgColor = type === 'success' ? 'rgba(16,185,129,0.1)' :
                      type === 'warning' ? 'rgba(245,158,11,0.1)' : 'rgba(239,68,68,0.1)';
        var textColor = type === 'success' ? '#065f46' :
                        type === 'warning' ? '#92400e' : '#991b1b';

        area.innerHTML = '<div style="border-left:4px solid ' + borderColor + '; background:' + bgColor + '; padding:10px 14px; border-radius:8px; display:flex; align-items:center; gap:10px;">' +
            '<i class="fas ' + icon + '" style="color:' + borderColor + '; font-size:16px;"></i>' +
            '<div style="font-size:12px; font-weight:600; color:' + textColor + ';">' + message + '</div>' +
            '<button onclick="this.parentElement.parentElement.style.display=\'none\'" style="margin-left:auto; background:none; border:none; cursor:pointer; color:' + textColor + '; font-size:14px; opacity:0.7;" title="Kapat">&times;</button>' +
            '</div>';
        area.style.display = 'block';
        area.scrollIntoView({ behavior: 'smooth', block: 'nearest' });

        setTimeout(function() {
            area.style.display = 'none';
        }, 6000);
    }
})();
</script>

