<!-- R16 FormulaEngine Designer (Admin Only)                            -->
<!-- ═══════════════════════════════════════════════════════════════════ -->
@if (Model.IsAdminMode)
{
<div class="kasa-card mb-4 kasa-fade-in" style="border-color: var(--kasa-danger); border-width: 2px;">
    <div class="kasa-card-header" style="background: rgba(239,68,68,0.05);">
        <h5 class="mb-0">
            <i class="fas fa-flask text-danger me-2"></i>Formül Designer (Admin)
        </h5>
        <span class="kasa-badge kasa-badge-danger">R16</span>
    </div>
    <div class="kasa-card-body">
        <form asp-controller="KasaPreview" asp-action="RunFormulaEngine" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="KasaType" />
            <input type="hidden" asp-for="IsAdminMode" />
            <input type="hidden" asp-for="SelectedDate" />
            <input type="hidden" asp-for="KasayiYapan" />
            <input type="hidden" asp-for="HasSnapshot" />
            <input type="hidden" asp-for="IsDataLoaded" />
            <input type="hidden" asp-for="BozukPara" />
            <input type="hidden" asp-for="NakitPara" />
            <input type="hidden" asp-for="VergideBirikenKasa" />
            <input type="hidden" asp-for="VergidenGelen" />
            <input type="hidden" asp-for="GelmeyenD" />

            <!-- DB FormulaSet Management -->
            @if (Model.DbFormulaSets?.Count > 0)
            {
                <div class="mb-3">
                    <label class="kasa-form-label">Kayıtlı Şablonlar</label>
                    <div class="d-flex gap-2 flex-wrap">
                        <select class="kasa-form-input" style="max-width: 300px;"
                                asp-for="DbFormulaSetId">
                            <option value="">Şablon Seçin...</option>
                            @foreach (var s in Model.DbFormulaSets)
                            {
                                <option value="@s.Id"
                                        data-scope="@s.ScopeType"
                                        data-active="@s.IsActive">
                                    @s.Name @(s.IsActive ? "★" : "") (@s.ScopeType)
                                </option>
                            }
                        </select>
                        <button type="submit" name="uiAction" value="dbLoad"
                                class="kasa-btn kasa-btn-secondary kasa-btn-sm">
                            <i class="fas fa-upload"></i> Yükle
                        </button>
                        <button type="submit" name="uiAction" value="dbUpdate"
                                class="kasa-btn kasa-btn-primary kasa-btn-sm">
                            <i class="fas fa-save"></i> Güncelle
                        </button>
                        <button type="submit" name="uiAction" value="dbActivate"
                                class="kasa-btn kasa-btn-success kasa-btn-sm">
                            <i class="fas fa-star"></i> Aktif Yap
                        </button>
                        <button type="submit" name="uiAction" value="dbCopy"
                                class="kasa-btn kasa-btn-secondary kasa-btn-sm">
                            <i class="fas fa-copy"></i> Kopyala
                        </button>
                        <button type="submit" name="uiAction" value="dbDelete"
                                class="kasa-btn kasa-btn-danger kasa-btn-sm"
                                onclick="return confirm('Bu şablonu silmek istediğinizden emin misiniz?')">
                            <i class="fas fa-trash"></i> Sil
                        </button>
                    </div>
                </div>
            }

            <!-- New Set -->
            <div class="row g-3 mb-3">
                <div class="col-md-4">
                    <label class="kasa-form-label">Şablon Adı</label>
                    <input type="text" class="kasa-form-input" asp-for="DbFormulaSetName"
                           placeholder="Yeni şablon adı..." />
                </div>
                <div class="col-md-3">
                    <label class="kasa-form-label">Kapsam (Scope)</label>
                    <select class="kasa-form-input" asp-for="DbScopeType">
                        <option value="Custom">Custom</option>
                        <option value="Sabah">Sabah</option>
                        <option value="Aksam">Aksam</option>
                        <option value="Genel">Genel</option>
                        <option value="Ortak">Ortak</option>
                    </select>
                </div>
                <div class="col-auto d-flex align-items-end">
                    <button type="submit" name="uiAction" value="dbSaveNew"
                            class="kasa-btn kasa-btn-success kasa-btn-sm">
                        <i class="fas fa-plus"></i> Yeni Şablon Kaydet
                    </button>
                </div>
            </div>

            <!-- Mappings -->
            @if (Model.Mappings?.Count > 0)
            {
                <div class="kasa-card mb-3">
                    <div class="kasa-card-header">
                        <h6 class="mb-0"><i class="fas fa-code-branch me-2"></i>Formül Satırları</h6>
                        <span class="kasa-badge kasa-badge-info">@Model.Mappings.Count adet</span>
                    </div>
                    <div class="kasa-card-body p-0" style="max-height: 400px; overflow-y: auto;">
                        <table class="kasa-table">
                            <thead>
                                <tr>
                                    <th style="width: 30%">Hedef Alan</th>
                                    <th style="width: 15%">Mod</th>
                                    <th>İfade / Kaynak</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (var i = 0; i < Model.Mappings.Count; i++)
                                {
                                    <tr>
                                        <td>
                                            <input type="hidden" name="Mappings[@i].RowId" value="@Model.Mappings[i].RowId" />
                                            <input type="hidden" name="Mappings[@i].IsHidden" value="@Model.Mappings[i].IsHidden.ToString().ToLower()" />
                                            <input type="text" class="kasa-form-input"
                                                   name="Mappings[@i].TargetKey"
                                                   value="@Model.Mappings[i].TargetKey" />
                                        </td>
                                        <td>
                                            <select class="kasa-form-input"
                                                    name="Mappings[@i].Mode">
                                                <option value="Formula" selected="@(Model.Mappings[i].Mode == "Formula")">Formula</option>
                                                <option value="Map" selected="@(Model.Mappings[i].Mode == "Map")">Map</option>
                                            </select>
                                        </td>
                                        <td>
                                            @if (Model.Mappings[i].Mode == "Map")
                                            {
                                                <input type="text" class="kasa-form-input"
                                                       name="Mappings[@i].SourceKey"
                                                       value="@Model.Mappings[i].SourceKey" />
                                                <input type="hidden" name="Mappings[@i].Expression" value="" />
                                            }
                                            else
                                            {
                                                <input type="text" class="kasa-form-input font-mono"
                                                       name="Mappings[@i].Expression"
                                                       value="@Model.Mappings[i].Expression" />
                                                <input type="hidden" name="Mappings[@i].SourceKey" value="" />
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }

            <!-- Run Engine -->
            <div class="d-flex gap-2">
                <button type="submit" name="uiAction" value="run"
                        class="kasa-btn kasa-btn-primary">
                    <i class="fas fa-play"></i> Formül Motorunu Çalıştır
                </button>
                <button type="submit" name="uiAction" value="loadSetV1"
                        class="kasa-btn kasa-btn-secondary kasa-btn-sm">
                    <i class="fas fa-history"></i> V1 Yükle
                </button>
                <button type="submit" name="uiAction" value="loadAksamContract"
                        class="kasa-btn kasa-btn-secondary kasa-btn-sm">
                    <i class="fas fa-file-contract"></i> Akşam Kontrat
                </button>
            </div>

            <!-- FormulaRun Results -->
            @if (Model.FormulaRun != null)
            {
                <div class="kasa-card mt-4">
                    <div class="kasa-card-header">
                        <h6 class="mb-0"><i class="fas fa-flask me-2"></i>Formül Motoru Çıktısı</h6>
                    </div>
                    <div class="kasa-card-body p-0">
                        <table class="kasa-table">
                            <thead>
                                <tr>
                                    <th>Çıktı Alan</th>
                                    <th class="text-end">Değer</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var kv in Model.FormulaRun.Outputs)
                                {
                                    <tr>
                                        <td>@kv.Key</td>
                                        <td class="text-end money-value">
                                            @kv.Value.ToString("N2", System.Globalization.CultureInfo.GetCultureInfo("tr-TR")) ₺
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        </form>
    </div>
</div>
}

<!-- ═══════════════════════════════════════════════════════════════════ -->
<!-- Pool Data Accordion (Debug/Advanced)                               -->
<!-- ═══════════════════════════════════════════════════════════════════ -->
@if (Model.PoolEntries?.Count > 0)
{
<div class="kasa-card mb-4" x-data="{ open: false }">
    <button type="button" class="kasa-accordion-toggle"
            @@click="open = !open"
            :aria-expanded="open.toString()">
        <span><i class="fas fa-database me-2"></i>HAM Veri (Pool) — @Model.PoolEntries.Count adet</span>
        <i class="fas fa-chevron-down"></i>
    </button>
    <div x-show="open" x-transition>
        <div class="kasa-card-body p-0" style="max-height: 500px; overflow-y: auto;">
            <table class="kasa-table">
                <thead>
                    <tr>
                        <th>Anahtar</th>
                        <th class="text-end">Değer</th>
                        <th>Kaynak</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model.PoolEntries.OrderBy(x => x.CanonicalKey))
                    {
                        <tr>
                            <td class="font-mono" style="font-size: 12.5px;">@p.CanonicalKey</td>
                            <td class="text-end money-value">@p.Value</td>
                            <td>
                                <span class="kasa-badge kasa-badge-info" style="font-size: 10px;">
                                    @(p.SourceName ?? p.Type.ToString())
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
}
