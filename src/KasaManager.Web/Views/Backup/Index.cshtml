@{
    ViewData["Title"] = "Veritabanı Yedekleme";
}

<div class="kasa-page-header">
    <div>
        <h1 class="kasa-page-title"><i class="fas fa-database me-2"></i>Veritabanı Yedekleme</h1>
        <p class="kasa-page-subtitle">Veritabanınızı yedekleyin ve güvende tutun</p>
    </div>
</div>

@if (TempData["Success"] is string success)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle me-1"></i> @success
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] is string error)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-triangle me-1"></i> @error
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row g-4">
    <div class="col-md-6">
        <div class="kasa-card">
            <div class="kasa-card-header">
                <h5><i class="fas fa-info-circle me-2"></i>Veritabanı Bilgileri</h5>
            </div>
            <div class="kasa-card-body">
                <table class="table table-sm mb-0">
                    <tr>
                        <td class="text-muted" style="width:40%">Provider</td>
                        <td>
                            <span class="badge bg-primary">
                                @(ViewBag.IsSqlite == true ? "SQLite" : "SQL Server")
                            </span>
                        </td>
                    </tr>
                    @if (ViewBag.IsSqlite != true)
                    {
                        <tr>
                            <td class="text-muted">Sunucu</td>
                            <td><strong>@ViewBag.ServerName</strong></td>
                        </tr>
                        <tr>
                            <td class="text-muted">Veritabanı</td>
                            <td><strong>@ViewBag.DatabaseName</strong></td>
                        </tr>
                    }
                    else
                    {
                        <tr>
                            <td class="text-muted">Konum</td>
                            <td><code style="font-size: 0.8em;">@ViewBag.DbPath</code></td>
                        </tr>
                    }
                    <tr>
                        <td class="text-muted">Boyut</td>
                        <td><strong>@(ViewBag.DbSize ?? "—")</strong></td>
                    </tr>
                    @if (ViewBag.IsSqlite == true && ViewBag.DbExists == true)
                    {
                        <tr>
                            <td class="text-muted">Son Değişiklik</td>
                            <td>@ViewBag.DbModified</td>
                        </tr>
                    }
                </table>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="kasa-card">
            <div class="kasa-card-header">
                <h5><i class="fas fa-download me-2"></i>Yedek İndir</h5>
            </div>
            <div class="kasa-card-body">
                @if (ViewBag.IsSqlite == true && ViewBag.DbExists != true)
                {
                    <div class="alert alert-warning mb-0">
                        <i class="fas fa-exclamation-triangle me-1"></i>
                        Veritabanı dosyası bulunamadı.
                    </div>
                }
                else
                {
                    <p class="text-muted mb-3">
                        @if (ViewBag.IsSqlite == true)
                        {
                            <text>Veritabanı dosyasının bir kopyası <strong>.db</strong> formatında indirilecektir.</text>
                        }
                        else
                        {
                            <text>SQL Server <code>BACKUP DATABASE</code> komutu çalıştırılarak <strong>.bak</strong> dosyası oluşturulup indirilecektir. Sıkıştırma (COMPRESSION) aktiftir.</text>
                        }
                    </p>
                    <form asp-action="DownloadBackup" method="post" id="backupForm">
                        <button type="submit" class="btn btn-primary btn-lg w-100" id="btnDownload">
                            <i class="fas fa-download me-2"></i>Yedek İndir
                            (@(ViewBag.IsSqlite == true ? ".db" : ".bak"))
                        </button>
                    </form>
                }
            </div>
        </div>
    </div>
</div>

<div class="mt-4">
    <div class="kasa-card">
        <div class="kasa-card-header">
            <h5><i class="fas fa-lightbulb me-2"></i>Yedekleme Önerileri</h5>
        </div>
        <div class="kasa-card-body">
            <ul class="mb-0">
                <li>Veritabanınızı <strong>düzenli olarak</strong> (haftada en az 1 kez) yedekleyin.</li>
                <li>Yedek dosyalarını <strong>farklı bir disk veya bulut depolama</strong>'da saklayın.</li>
                <li>Önemli değişikliklerden <strong>önce</strong> yedek almayı unutmayın.</li>
                <li>Yedek dosyalarını tarih ile adlandırarak saklayın.</li>
            </ul>
        </div>
    </div>
</div>

@section Scripts {
<script>
(function () {
    const form = document.getElementById('backupForm');
    const btn = document.getElementById('btnDownload');
    if (!form || !btn) return;

    const originalHtml = btn.innerHTML;

    form.addEventListener('submit', function () {
        // Butonu devre dışı bırak ve spinner göster
        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Yedekleniyor...';

        // Download cookie kontrolü — controller tamamlandığında cookie set eder
        const cookieName = 'KasaBackupComplete';
        const checkInterval = setInterval(function () {
            if (document.cookie.indexOf(cookieName + '=1') !== -1) {
                clearInterval(checkInterval);
                clearTimeout(failsafe);
                resetButton();
                // Cookie'yi temizle
                document.cookie = cookieName + '=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/;';
            }
        }, 500);

        // Failsafe: 60 saniye sonra butonu her halükarda sıfırla
        const failsafe = setTimeout(function () {
            clearInterval(checkInterval);
            resetButton();
        }, 60000);
    });

    function resetButton() {
        btn.disabled = false;
        btn.innerHTML = originalHtml;
    }
})();
</script>
}

