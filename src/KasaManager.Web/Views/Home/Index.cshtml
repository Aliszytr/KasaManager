@{
    ViewData["Title"] = "Dashboard";
}

<div class="kasa-page-title">
    <h2><i class="fas fa-th-large text-kasa-primary me-2"></i>Dashboard</h2>
    <p class="text-muted mb-0">Kasa hesaplama modüllerine hızlı erişim</p>
</div>

<!-- ═══════════════════════════════════════════════════════════════════ -->
<!-- KASA HESAPLAMA MODÜLLERİ — Intent-First Cards                     -->
<!-- ═══════════════════════════════════════════════════════════════════ -->
<div class="row g-4 mb-5">

    <!-- ☀️ Sabah Kasa -->
    <div class="col-md-6 col-lg-3">
        <a class="kasa-intent-card kasa-intent-sabah"
           asp-controller="KasaPreview" asp-action="Index" asp-route-kasaType="sabah">
            <div class="kasa-intent-icon">
                <i class="fas fa-sun"></i>
            </div>
            <div class="kasa-intent-body">
                <div class="kasa-intent-title">Sabah Kasa</div>
                <div class="kasa-intent-desc">Günün açılış hesaplaması</div>
            </div>
            <div class="kasa-intent-arrow">
                <i class="fas fa-arrow-right"></i>
            </div>
        </a>
    </div>

    <!-- 🌙 Akşam Kasa -->
    <div class="col-md-6 col-lg-3">
        <a class="kasa-intent-card kasa-intent-aksam"
           asp-controller="KasaPreview" asp-action="Index" asp-route-kasaType="aksam">
            <div class="kasa-intent-icon">
                <i class="fas fa-moon"></i>
            </div>
            <div class="kasa-intent-body">
                <div class="kasa-intent-title">Akşam Kasa</div>
                <div class="kasa-intent-desc">Gün sonu hesaplaması</div>
            </div>
            <div class="kasa-intent-arrow">
                <i class="fas fa-arrow-right"></i>
            </div>
        </a>
    </div>

    <!-- 📊 Genel Kasa -->
    <div class="col-md-6 col-lg-3">
        <a class="kasa-intent-card kasa-intent-genel"
           asp-controller="KasaPreview" asp-action="Index" asp-route-kasaType="genel">
            <div class="kasa-intent-icon">
                <i class="fas fa-chart-pie"></i>
            </div>
            <div class="kasa-intent-body">
                <div class="kasa-intent-title">Genel Kasa</div>
                <div class="kasa-intent-desc">Dönem mutabakat raporu</div>
            </div>
            <div class="kasa-intent-arrow">
                <i class="fas fa-arrow-right"></i>
            </div>
        </a>
    </div>

    <!-- 📋 Ortak Kasa (Özet) -->
    <div class="col-md-6 col-lg-3">
        <a class="kasa-intent-card kasa-intent-ortak"
           asp-controller="KasaPreview" asp-action="Index" asp-route-kasaType="ortak">
            <div class="kasa-intent-icon">
                <i class="fas fa-layer-group"></i>
            </div>
            <div class="kasa-intent-body">
                <div class="kasa-intent-title">Ortak Kasa</div>
                <div class="kasa-intent-desc">Özet kasa hesaplaması</div>
            </div>
            <div class="kasa-intent-arrow">
                <i class="fas fa-arrow-right"></i>
            </div>
        </a>
    </div>

</div>

<!-- ═══════════════════════════════════════════════════════════════════ -->
<!-- DİĞER MODÜLLER                                                     -->
<!-- ═══════════════════════════════════════════════════════════════════ -->
<h5 class="mb-3 text-muted"><i class="fas fa-grip-horizontal me-2"></i>Diğer Modüller</h5>
<div class="row g-4 mb-4">
    <div class="col-md-6 col-lg-4">
        <a class="kasa-select-card" asp-controller="Import" asp-action="Index">
            <div class="card-icon" style="background: rgba(8,145,178,0.1); color: var(--kasa-primary);">
                <i class="fas fa-file-upload"></i>
            </div>
            <div class="card-title">Dosya Yükleme</div>
            <div class="card-desc">Excel dosyalarını yükle ve import et</div>
        </a>
    </div>
    <div class="col-md-6 col-lg-4">
        <a class="kasa-select-card" asp-controller="KasaUstRapor" asp-action="Index">
            <div class="card-icon" style="background: rgba(99,102,241,0.1); color: var(--kasa-secondary);">
                <i class="fas fa-file-alt"></i>
            </div>
            <div class="card-title">KasaÜstRapor</div>
            <div class="card-desc">Üst rapor oluştur ve snapshot kaydet</div>
        </a>
    </div>
    <div class="col-md-6 col-lg-4">
        <a class="kasa-select-card" asp-controller="Comparison" asp-action="Index">
            <div class="card-icon" style="background: rgba(139,92,246,0.1); color: var(--kasa-accent);">
                <i class="fas fa-balance-scale"></i>
            </div>
            <div class="card-title">Karşılaştırma</div>
            <div class="card-desc">Banka-Online dosya karşılaştırması</div>
        </a>
    </div>
    <div class="col-md-6 col-lg-4">
        <a class="kasa-select-card" asp-controller="GenelKasaRapor" asp-action="Index">
            <div class="card-icon" style="background: rgba(245,158,11,0.1); color: var(--kasa-warning);">
                <i class="fas fa-chart-bar"></i>
            </div>
            <div class="card-title">Genel Kasa Rapor</div>
            <div class="card-desc">Mutabakat raporu oluştur</div>
        </a>
    </div>
    <div class="col-md-6 col-lg-4">
        <a class="kasa-select-card" asp-controller="KasaSettings" asp-action="Index">
            <div class="card-icon" style="background: rgba(100,116,139,0.1); color: var(--text-secondary);">
                <i class="fas fa-cog"></i>
            </div>
            <div class="card-title">Ayarlar</div>
            <div class="card-desc">Global ayarlar, IBAN ve varsayılanlar</div>
        </a>
    </div>
    <div class="col-md-6 col-lg-4">
        <a class="kasa-select-card" asp-controller="KasaPreview" asp-action="Designer">
            <div class="card-icon" style="background: rgba(239,68,68,0.08); color: var(--kasa-danger);">
                <i class="fas fa-flask"></i>
            </div>
            <div class="card-title">Formül Designer (Admin)</div>
            <div class="card-desc">Kasa şablonları ve formül yönetimi</div>
        </a>
    </div>
</div>
