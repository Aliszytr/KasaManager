@model KasaManager.Web.Controllers.ChangePasswordViewModel
@{
    ViewData["Title"] = "Şifre Değiştir";
}

<div class="kasa-page-header">
    <div>
        <h1 class="kasa-page-title"><i class="fas fa-key me-2"></i>Şifre Değiştir</h1>
        <p class="kasa-page-subtitle">Hesap şifrenizi güncelleyin</p>
    </div>
</div>

@if (TempData["Success"] is string success)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle me-1"></i> @success
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="kasa-card" style="max-width: 500px;">
    <div class="kasa-card-body">
        <form asp-action="ChangePassword" method="post">
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="CurrentPassword" class="form-label">Mevcut Şifre</label>
                <input asp-for="CurrentPassword" type="password" class="form-control" />
                <span asp-validation-for="CurrentPassword" class="text-danger"></span>
            </div>

            <hr class="my-3" />

            <div class="mb-3">
                <label asp-for="NewPassword" class="form-label">Yeni Şifre</label>
                <input asp-for="NewPassword" type="password" class="form-control" placeholder="En az 6 karakter" />
                <span asp-validation-for="NewPassword" class="text-danger"></span>
            </div>

            <div class="mb-4">
                <label asp-for="ConfirmPassword" class="form-label">Yeni Şifre (Tekrar)</label>
                <input asp-for="ConfirmPassword" type="password" class="form-control" />
                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary">
                <i class="fas fa-save me-1"></i> Şifreyi Değiştir
            </button>
        </form>
    </div>
</div>
