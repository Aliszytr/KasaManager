{
  "Database": {
    "Provider": "SqlServer",
    "AutoInstanceResolve": true,
    "PreferredInstance": ""
  },
  "ConnectionStrings": {
    "SqlConnection": "Server=localhost;Database=KasaManager;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "LegacyDatabase": {
    "Enabled": false
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:5000"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "Microsoft.Hosting.Lifetime": "Information",
      "KasaManager": "Warning",
      "KasaManager.Application.Orchestration": "Information",
      "KasaManager.Web.Controllers": "Information",
      "DbBootstrap": "Information"
    },
    "Console": {
      "FormatterName": "simple",
      "FormatterOptions": {
        "SingleLine": true,
        "TimestampFormat": "HH:mm:ss "
      }
    }
  },
  "AllowedHosts": "*"
}
